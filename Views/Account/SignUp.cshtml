@{
    ViewData["Title"] = "Sign Up";
    Layout = null; // Standalone — matches Login.cshtml exactly
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up — GadgetVault</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; font-family: 'Inter', 'Segoe UI', sans-serif; }

        body {
            background-color: #09090b;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 24px;
        }

        /* Identical subtle grid pattern to Login */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
            z-index: 0;
        }

        .login-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 400px;
        }

        /* Logo — identical to Login */
        .logo-area {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 40px;
        }
        .logo-icon {
            width: 36px;
            height: 36px;
            background-color: #23a476;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 20px rgba(35,164,118,0.35);
        }
        .logo-text {
            font-size: 1.35rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.03em;
        }
        .logo-text span { color: #23a476; }

        /* Card — identical to Login */
        .login-card {
            background: #111113;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 20px;
            padding: 36px 36px 32px;
        }

        .card-heading {
            font-size: 1.3rem;
            font-weight: 700;
            color: #f1f5f9;
            margin-bottom: 6px;
            letter-spacing: -0.02em;
        }
        .card-sub {
            font-size: 0.82rem;
            color: #64748b;
            margin-bottom: 28px;
        }

        label.field-label {
            display: block;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #475569;
            margin-bottom: 7px;
        }

        .auth-input {
            display: block;
            width: 100%;
            background: #0e0e10;
            border: 1px solid #1e1e24;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: 0.875rem;
            font-family: 'Inter', sans-serif;
            color: #e2e8f0;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
            margin-bottom: 18px;
        }
        .auth-input::placeholder { color: #334155; }
        .auth-input:focus {
            border-color: #23a476;
            box-shadow: 0 0 0 3px rgba(35,164,118,0.15);
        }

        /* Password hint */
        .pwd-hint {
            font-size: 0.75rem;
            color: #334155;
            margin-top: -12px;
            margin-bottom: 20px;
        }

        /* Primary button — identical to Login */
        .btn-signin {
            width: 100%;
            padding: 12px 20px;
            background: #23a476;
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.875rem;
            font-weight: 700;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: background 0.18s, box-shadow 0.18s, transform 0.15s;
            box-shadow: 0 4px 14px rgba(35,164,118,0.3);
            letter-spacing: 0.01em;
        }
        .btn-signin:hover {
            background: #1e8f66;
            box-shadow: 0 6px 20px rgba(35,164,118,0.4);
            transform: translateY(-1px);
        }
        .btn-signin:active { transform: translateY(0); }

        /* Footer links */
        .card-footer-links {
            text-align: center;
            margin-top: 24px;
        }
        .card-footer-links p {
            font-size: 0.82rem;
            color: #475569;
        }
        .card-footer-links a {
            color: #23a476;
            font-weight: 600;
            text-decoration: none;
        }
        .card-footer-links a:hover { color: #2dd480; }

        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 28px;
            font-size: 0.8rem;
            color: #334155;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.18s;
        }
        .back-link:hover { color: #94a3b8; }
    </style>
</head>
<body>
    <div class="login-container">
        <!-- Logo -->
        <div class="logo-area">
            <div class="logo-icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="white">
                    <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
            </div>
            <p class="logo-text">Gadget<span>Vault</span></p>
        </div>

        <!-- Card -->
        <div class="login-card">
            <h1 class="card-heading">Create your account</h1>
            <p class="card-sub">Join GadgetVault and access your workspace.</p>

            <form asp-controller="Account" asp-action="SignUp" method="post">
                <label class="field-label" for="signup-name">Full Name</label>
                <input id="signup-name" class="auth-input" type="text" name="username" placeholder="Jane Dela Cruz" required autocomplete="name" />

                <label class="field-label" for="signup-email">Work Email</label>
                <input id="signup-email" class="auth-input" type="email" name="email" placeholder="you@company.com" required autocomplete="email" />

                <label class="field-label" for="signup-password">Password</label>
                <input id="signup-password" class="auth-input" type="password" name="password" placeholder="Min. 8 characters" required autocomplete="new-password" style="margin-bottom: 8px;" />
                <p class="pwd-hint">Use 8+ characters with a mix of letters and numbers.</p>

                <button type="submit" class="btn-signin">Create Account</button>
            </form>

            <div class="card-footer-links">
                <p>Already have an account? <a asp-controller="Account" asp-action="Login">Sign In</a></p>
            </div>
        </div>

        <a href="/" class="back-link">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Home
        </a>
    </div>
</body>
</html>






