@using GadgetVault.Data
@inject ApplicationDbContext DbContext
@{
    var settings = DbContext.SystemSettings.FirstOrDefault();
    var brandName = settings?.CompanyName ?? "GadgetVault";
    var brandColor = settings?.PrimaryColorHex ?? "#23a476";
    var logoUrl = settings?.LogoUrl;
}
<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50 dark:bg-[#09090b]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @brandName</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'gv-brand': '@brandColor',
                    }
                }
            }
        }
    </script>
    <!-- âš¡ FOUC Blocker: stamp .dark on <html> BEFORE render so no flash -->
    <script>
        (function() {
            var t = localStorage.getItem('theme') || 'dark';
            if (t === 'dark') document.documentElement.classList.add('dark');
            else document.documentElement.classList.remove('dark');
        })();
    </script>
    <style>
        :root {
            --brand-color: @brandColor;
        }
        /* Light mode base */
        .hover-brand:hover { color: color-mix(in srgb, var(--brand-color) 75%, black) !important; }
        .bg-gv-brand { background-color: var(--brand-color) !important; }
        .text-gv-brand { color: color-mix(in srgb, var(--brand-color) 85%, black) !important; }
        .border-gv-brand { border-color: var(--brand-color) !important; }
        .bg-gv-brand-light { background-color: color-mix(in srgb, var(--brand-color) 12%, transparent) !important; }
        .border-gv-brand-light { border-color: color-mix(in srgb, var(--brand-color) 25%, transparent) !important; }
        .text-gv-brand-dark { color: color-mix(in srgb, var(--brand-color) 60%, black) !important; }
        .text-gv-brand-light { color: color-mix(in srgb, var(--brand-color) 90%, white) !important; }

        /* Dark mode overrides */
        .dark .text-gv-brand { color: color-mix(in srgb, var(--brand-color) 85%, white) !important; }
        .dark .text-gv-brand-dark { color: color-mix(in srgb, var(--brand-color) 75%, white) !important; }
        .dark .hover-brand:hover { color: color-mix(in srgb, var(--brand-color) 85%, white) !important; }
        .dark .bg-gv-brand-light { background-color: color-mix(in srgb, var(--brand-color) 15%, transparent) !important; }
        .dark .border-gv-brand-light { border-color: color-mix(in srgb, var(--brand-color) 30%, transparent) !important; }
    </style>
</head>
<body class="m-0 p-0 h-full flex font-sans overflow-hidden bg-slate-50 dark:bg-[#09090b] text-slate-900 dark:text-neutral-200 transition-colors duration-300"
      style="font-family:'Inter','Segoe UI',sans-serif;">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         GLOBAL SIDEBAR
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <!-- Mobile Backdrop -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-black/50 z-40 md:hidden hidden backdrop-blur-sm transition-opacity duration-300" onclick="toggleSidebar()"></div>

    <aside id="sidebar-main" 
           class="fixed inset-y-0 left-0 z-50 w-64 shrink-0 border-r border-slate-200 dark:border-[#1e1e24] bg-white dark:bg-[#111113] flex flex-col h-full 
                  -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out">

        <!-- Brand -->
        <div class="h-16 flex items-center justify-between px-5 border-b border-slate-200 dark:border-[#1e1e24] shrink-0 select-none transition-colors duration-300">
            <div class="flex items-center gap-2.5">
                @if (!string.IsNullOrEmpty(logoUrl))
                {
                    <img src="@logoUrl" alt="@brandName Logo" style="width:28px;height:28px;border-radius:7px;object-fit:cover;" />
                }
                else
                {
                    <div style="background:@brandColor;width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px @(brandColor)4D">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="white">
                            <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                        </svg>
                    </div>
                }
                <span class="font-extrabold text-base tracking-tight text-slate-900 dark:text-white transition-colors duration-300">@brandName</span>
            </div>
            <!-- Close button (mobile only) -->
            <button class="md:hidden p-2 text-slate-400 hover:text-slate-600" onclick="toggleSidebar()">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <!-- Navigation -->
        <nav id="sidebar-nav" class="flex-1 overflow-y-auto py-5 px-3" style="scrollbar-width:thin;scrollbar-color:#1e293b transparent;" aria-label="Main navigation">

            @{
                var reqPath = Context.Request.Path.Value?.TrimEnd('/') ?? "";
                string NavLink(string href, string label, string iconPath, bool isStorke = true) {
                    var active = reqPath.Equals(href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
                    var cls = active
                        ? "flex items-center gap-2.5 px-3 py-2 rounded-lg text-[0.8125rem] font-bold shadow-sm border"
                        : "flex items-center gap-2.5 px-3 py-2 rounded-lg text-[0.8125rem] font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-white transition-all duration-200 border-transparent border";
                    
                    var activeStyle = active ? $"background-color: var(--brand-color); border-color: var(--brand-color); color: #fff;" : "";
                    
                    return $@"<a href=""{href}"" class=""{cls}"" style=""{activeStyle}"">
                        <svg width=""16"" height=""16"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor"" stroke-width=""2.2"" class=""shrink-0""><path stroke-linecap=""round"" stroke-linejoin=""round"" d=""{iconPath}""/></svg>
                        {label}</a>";
                }

                // --- RBAC Implementation ---
                var roleIdClaim = User.FindFirst("RoleId")?.Value;
                Dictionary<string, Dictionary<string, bool>> permsDict = null;
                if (!string.IsNullOrEmpty(roleIdClaim)) {
                    var roleObj = DbContext.Roles.Find(int.Parse(roleIdClaim));
                    if (roleObj != null && !string.IsNullOrEmpty(roleObj.Permissions) && roleObj.Permissions.StartsWith("{")) {
                        try {
                            permsDict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, Dictionary<string, bool>>>(roleObj.Permissions);
                        } catch { }
                    }
                }

                bool CanView(string module) {
                    if (User.IsInRole("Admin")) return true;
                    if (permsDict != null && permsDict.TryGetValue(module, out var p)) {
                        return p.TryGetValue("canView", out var v) && v;
                    }
                    return false;
                }

                var fullName = User.FindFirst("FullName")?.Value ?? "New User";
                var roleName = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Guest";
                var profilePic = User.FindFirst("ProfilePictureUrl")?.Value;
            }

            <!-- OVERVIEW -->
            @if (CanView("SystemDashboard") || CanView("MyDashboard"))
            {
                <div class="mb-5">
                    <p class="text-[0.65rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2.5 mb-1.5 transition-colors duration-300">Overview</p>
                    @if (CanView("MyDashboard"))
                    {
                        var dashAction = roleName switch {
                            "Warehouse Manager" => "WarehouseManager",
                            "WarehouseManager" => "WarehouseManager",
                            "SystemManager" => "Admin",
                            "System Manager" => "Admin",
                            "Supplier" => "SupplierDashboard",
                            _ => "Admin"
                        };
                        @Html.Raw(NavLink($"/Dashboard/{dashAction}", "My Dashboard", "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"))
                    }
                </div>
            }

            <!-- ADMINISTRATION -->
            @if (CanView("UserManagement") || CanView("RolesPermissions") || CanView("MasterData") || CanView("SecurityLogs") || CanView("SystemLogs") || CanView("CompanySettings"))
            {
                <div class="mb-5">
                    <p class="text-[0.65rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2.5 mb-1.5 transition-colors duration-300">Administration</p>
                    @if (CanView("UserManagement")) { @Html.Raw(NavLink("/Dashboard/UserManagement", "User Management", "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z")) }
                    @if (CanView("RolesPermissions")) { @Html.Raw(NavLink("/Dashboard/RolesPermissions", "Roles & Permissions", "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")) }
                    @if (CanView("MasterData")) { @Html.Raw(NavLink("/Dashboard/MasterData", "Master Data", "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4")) }
                    
                    @if (CanView("SecurityLogs") || CanView("SystemLogs") || CanView("CompanySettings"))
                    {
                        <details class="group mt-1">
                            <summary class="flex items-center justify-between px-3 py-2 rounded-lg text-[0.8125rem] font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-white cursor-pointer transition-all duration-200 list-none">
                                <div class="flex items-center gap-2.5">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    System Settings
                                </div>
                                <svg class="w-3.5 h-3.5 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                            </summary>
                            <div class="pl-7 mt-1 flex flex-col gap-1 border-l border-slate-100 dark:border-[#1e1e24] ml-5">
                                @if (CanView("CompanySettings")) { @Html.Raw(NavLink("/Dashboard/CompanySettings", "Branding & Identity", "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4")) }
                                @if (CanView("SecurityLogs")) { @Html.Raw(NavLink("/Dashboard/SecurityLogs", "Security Logs", "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")) }
                                @if (CanView("SystemLogs")) { @Html.Raw(NavLink("/Dashboard/SystemLogs", "Event Audits", "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z")) }
                            </div>
                        </details>
                    }
                </div>
            }

            <!-- WAREHOUSE MODULES -->
            @if (CanView("ProductCatalog") || CanView("LiveInventory") || CanView("ReceiveStock") || CanView("PickPack") || CanView("StockAdjustments"))
            {
                <div class="mb-5">
                    <p class="text-[0.65rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2.5 mb-1.5 transition-colors duration-300">Warehouse</p>
                    @if (CanView("ProductCatalog")) { @Html.Raw(NavLink("/Dashboard/ProductCatalog", "Product Catalog", "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z")) }
                    @if (CanView("LiveInventory")) { @Html.Raw(NavLink("/Warehouse/LiveInventory", "Live Inventory", "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7")) }
                    @if (CanView("ReceiveStock")) { @Html.Raw(NavLink("/Dashboard/ReceiveStock", "Receive Stock", "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")) }
                    @if (CanView("PickPack")) { @Html.Raw(NavLink("/Warehouse/Fulfillment", "Pick & Pack", "M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4")) }
                    @if (CanView("StockAdjustments") && !User.IsInRole("WarehouseStaff")) { @Html.Raw(NavLink("/Dashboard/StockAdjustments", "Stock Adjustments", "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4")) }
                </div>
            }

            <!-- COMMERCIAL -->
            @if (CanView("BusinessDirectory") || CanView("PurchaseOrders") || CanView("SalesOrders"))
            {
                <div class="mb-5">
                    <p class="text-[0.65rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2.5 mb-1.5 transition-colors duration-300">Commercial</p>
                    @if (CanView("BusinessDirectory")) { @Html.Raw(NavLink("/Dashboard/BusinessDirectory", "Business Directory", "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4")) }
                    @if (CanView("PurchaseOrders")) { @Html.Raw(NavLink("/Dashboard/PurchaseOrders", "Purchase Orders", "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z")) }
                    @if (CanView("SalesOrders")) { @Html.Raw(NavLink("/SalesOrder", "Sales Orders", "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z")) }
                </div>
            }

            <!-- SUPPLIER PORTAL -->
            @if (roleName == "Supplier" && (CanView("SuppOrders") || CanView("SuppCompanyInfo")))
            {
                <div class="mb-5">
                    <p class="text-[0.65rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2.5 mb-1.5 transition-colors duration-300">Supplier Access</p>
                    @if (CanView("SuppOrders")) { @Html.Raw(NavLink("/Dashboard/SupplierPortal", "My Orders", "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z")) }
                    @if (CanView("SuppOrderHistory")) { @Html.Raw(NavLink("/Dashboard/OrderHistory", "Order History", "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")) }
                    @if (CanView("SuppCatalog")) { @Html.Raw(NavLink("/Dashboard/SupplierCatalog", "My Catalog", "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z")) }
                    @if (CanView("SuppCompanyInfo")) { @Html.Raw(NavLink("/Dashboard/SupplierProfile", "Company Info", "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")) }
                </div>
            }

        </nav>

        <!-- Sidebar footer — profile snapshot -->
        @{
            var initials = "??";
            if (!string.IsNullOrWhiteSpace(fullName))
            {
                var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                initials = parts.Length > 1 
                    ? (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper()
                    : parts[0][0].ToString().ToUpper();
            }
        }
        <div class="p-3 border-t border-slate-200 dark:border-[#1e1e24] shrink-0 transition-colors duration-300">
            <a asp-controller="Dashboard" asp-action="MyProfile" class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors duration-200 text-none">
                @if (!string.IsNullOrEmpty(profilePic)) {
                    <img src="@profilePic" alt="Profile" style="width:28px;height:28px;border-radius:50%;object-fit:cover;border:1px solid @(brandColor)4D;" />
                } else {
                    <div style="width:28px;height:28px;border-radius:50%;background:@(brandColor)26;border:1px solid @(brandColor)4D;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.65rem;font-weight:700;color:@brandColor;">@initials</div>
                }
                <div class="min-w-0">
                    <p class="text-[0.75rem] font-semibold text-slate-900 dark:text-slate-200 m-0 truncate transition-colors duration-300">@fullName</p>
                    <p class="text-[0.7rem] text-slate-500 dark:text-slate-400 m-0">@(roleName == "Vendor" ? "Supplier" : roleName)</p>
                </div>
            </a>
        </div>
    </aside>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         MAIN WRAPPER
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <div class="flex flex-col flex-1 min-w-0 md:pl-[256px]" id="dashboard-root">

        <!-- TOP HEADER -->
        <header class="h-16 shrink-0 bg-white dark:bg-[#09090b] border-b border-slate-200 dark:border-[#1e1e24] flex items-center justify-between px-4 lg:px-7 transition-colors duration-300">
            <div class="flex items-center gap-4">
                <!-- Hamburger Menu Button -->
                <button class="md:hidden p-2 text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" onclick="toggleSidebar()">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
                <div class="text-[0.7rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest transition-colors duration-300">
                    @ViewData["Title"]
                </div>
            </div>

            <div class="flex items-center gap-4">
                <!-- Theme Toggle -->
                <button id="themeToggleBtn" onclick="toggleTheme()" title="Toggle Theme" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 p-2 rounded-lg transition-colors duration-200">
                    <!-- Moon (shown in dark mode â€” click to go light) -->
                    <svg id="icon-moon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                    <!-- Sun (shown in light mode â€” click to go dark) -->
                    <svg id="icon-sun" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </button>

                <!-- Notification Bell (Phase 5) -->
                @if (User.IsInRole("Admin") || User.IsInRole("WarehouseManager") || User.IsInRole("WarehouseStaff") || User.IsInRole("SalesAndProcurement"))
                {
                    @await Component.InvokeAsync("NotificationBell")
                }

                <div class="h-5 w-px bg-slate-200 dark:bg-slate-800 transition-colors duration-300"></div>

                <!-- Profile Dropdown -->
                <div class="relative" id="profileDropdownWrapper">
                    <button onclick="toggleProfileMenu()" class="flex items-center gap-3 bg-transparent border-none cursor-pointer">
                        <div class="text-right">
                            <div class="text-[0.8rem] font-bold text-slate-900 dark:text-slate-200 transition-colors duration-300">@fullName</div>
                            <div class="text-[0.7rem] text-slate-500 dark:text-slate-400">@roleName</div>
                        </div>
                        @if (!string.IsNullOrEmpty(profilePic)) {
                            <img src="@profilePic" alt="Profile" style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:1px solid @(brandColor)4D;" />
                        } else {
                            <div style="width:34px;height:34px;border-radius:50%;background:@(brandColor)26;border:1px solid @(brandColor)4D;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:@brandColor;">@initials</div>
                        }
                    </button>
                    <!-- Dropdown -->
                    <div id="profileDropdownMenu" class="hidden absolute right-0 top-[120%] w-52 bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl shadow-xl z-50 overflow-hidden transition-colors duration-300">
                        <div class="px-4 py-3 border-b border-slate-100 dark:border-[#1e1e24]">
                            <p class="text-[0.85rem] font-bold text-slate-900 dark:text-slate-100 m-0">@fullName</p>
                            <p class="text-[0.75rem] text-slate-500 dark:text-slate-400 mt-0.5 truncate">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                        </div>
                        <a asp-controller="Dashboard" asp-action="MyProfile"
                           class="flex items-center gap-2.5 px-4 py-2.5 text-[0.83rem] font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors text-decoration-none hover-brand">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            My Profile
                        </a>
                        <div class="border-t border-slate-100 dark:border-[#1e1e24] py-1">
                            <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" class="hidden"></form>
                            <a href="javascript:void(0)" onclick="confirmLogout()"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-[0.83rem] font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors text-decoration-none">
                                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                                Log Out
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main id="page-main" class="flex-1 overflow-y-auto p-4 md:p-8">
            @RenderBody()
        </main>
    </div>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         GLOBAL CONFIRMATION MODAL
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <div id="globalConfirmModal" style="display:none;position:fixed;inset:0;z-index:999;display:none;align-items:center;justify-content:center;padding:16px;background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);">
        <div style="background:#111113;border:1px solid #1e1e24;border-radius:20px;box-shadow:0 25px 50px rgba(0,0,0,0.7);max-width:380px;width:100%;padding:24px;transform:scale(0.95);transition:transform 0.2s;" id="confirmModalInner">
            <div style="display:flex;align-items:flex-start;gap:16px;margin-bottom:20px;">
                <div style="width:40px;height:40px;border-radius:50%;background:rgba(239,68,68,0.15);flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div>
                    <h3 id="confirmModalTitle" style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 4px;">Are you sure?</h3>
                    <p id="confirmModalText" style="font-size:0.83rem;color:#94a3b8;margin:0;line-height:1.5;">This action cannot be undone.</p>
                </div>
            </div>
            <div style="display:flex;justify-content:flex-end;gap:10px;">
                <button onclick="closeConfirm()" style="padding:9px 18px;font-size:0.83rem;font-weight:700;color:#94a3b8;background:#27272a;border:none;border-radius:10px;cursor:pointer;font-family:inherit;">Cancel</button>
                <button id="confirmModalBtn" style="padding:9px 18px;font-size:0.83rem;font-weight:700;color:#fff;background:#ef4444;border:none;border-radius:10px;cursor:pointer;font-family:inherit;box-shadow:0 4px 14px rgba(239,68,68,0.3);">Confirm</button>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         GLOBAL TOAST NOTIFICATION SYSTEM
         ═══════════════════════════════════════════════════════ -->
    <div id="gv-toast-container" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function showSuccessToast(title, message) { _gvToast(title, message, '#10b981', 'M5 13l4 4L19 7'); }
        function showErrorToast(title, message)   { _gvToast(title, message, '#ef4444', 'M6 18L18 6M6 6l12 12'); }
        function showInfoToast(title, message)    { _gvToast(title, message, 'var(--brand-color)', 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'); }
        function _gvToast(title, msg, color, icon) {
            const c = document.getElementById('gv-toast-container');
            const t = document.createElement('div');
            t.style.cssText = `background:#1a1a1f;border:1px solid ${color}40;border-left:3px solid ${color};border-radius:12px;padding:14px 18px;min-width:300px;max-width:380px;box-shadow:0 8px 30px rgba(0,0,0,0.4);display:flex;align-items:flex-start;gap:12px;pointer-events:auto;opacity:0;transform:translateX(20px);transition:all 0.3s ease;`;
            t.innerHTML = `<svg width="18" height="18" style="flex-shrink:0;margin-top:1px;color:${color}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="${icon}"/></svg><div style="flex:1"><div style="font-size:0.82rem;font-weight:700;color:#f1f5f9;margin-bottom:2px;">${title}</div>${msg ? `<div style="font-size:0.75rem;color:#94a3b8;line-height:1.4;">${msg}</div>` : ''}</div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#64748b;cursor:pointer;padding:0;margin-left:8px;flex-shrink:0;font-size:1rem;line-height:1;">×</button>`;
            c.appendChild(t);
            requestAnimationFrame(() => { t.style.opacity = '1'; t.style.transform = 'translateX(0)'; });
            setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(20px)'; setTimeout(() => t.remove(), 350); }, 4500);
        }
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar-main');
            const backdrop = document.getElementById('sidebar-backdrop');
            
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                backdrop.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                backdrop.classList.add('hidden');
            }
        }

        // â”€â”€ Profile dropdown â”€â”€
        function toggleProfileMenu() {
            const m = document.getElementById('profileDropdownMenu');
            m.classList.toggle('hidden');
        }
        document.addEventListener('click', function(e) {
            const w = document.getElementById('profileDropdownWrapper');
            if (w && !w.contains(e.target)) {
                const m = document.getElementById('profileDropdownMenu');
                if (m) m.classList.add('hidden');
            }
        });

        // ── Global Confirmation Modal ──
        // Override the flex-display bug: modal uses display:none by default
        // site.js showConfirm / closeConfirm will handle it via classList — but we
        // need to use display:flex here since we use inline styles.
        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('globalConfirmModal');
            if (modal) modal.style.display = 'none';
        });

        function confirmLogout() {
            if (typeof showConfirm === 'function') {
                showConfirm(
                    'Confirm Logout',
                    'Are you sure you want to end your session and log out of GadgetVault?',
                    function() {
                        document.getElementById('logoutForm').submit();
                    }
                );
            } else {
                // Fallback if site.js isn't loaded correctly
                if (confirm('Are you sure you want to log out?')) {
                    document.getElementById('logoutForm').submit();
                }
            }
        }

        // --- Sidebar Scroll Persistence & Auto-Expansion ---
        (function() {
            const sidebarNav = document.getElementById('sidebar-nav');
            if (!sidebarNav) return;

            // Restore scroll position
            const savedScroll = sessionStorage.getItem('sidebar-scroll');
            if (savedScroll) {
                sidebarNav.scrollTop = parseInt(savedScroll, 10);
            }

            // Save scroll position on scroll
            sidebarNav.addEventListener('scroll', function() {
                sessionStorage.setItem('sidebar-scroll', sidebarNav.scrollTop);
            }, { passive: true });

            // Auto-expand parent <details> if child is active
            const currentPath = window.location.pathname.toLowerCase().replace(/\/$/, "");
            const links = sidebarNav.querySelectorAll('a');
            links.forEach(link => {
                const href = link.getAttribute('href').toLowerCase().replace(/\/$/, "");
                if (currentPath === href) {
                    let parent = link.closest('details');
                    if (parent) {
                        parent.open = true;
                    }
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>


