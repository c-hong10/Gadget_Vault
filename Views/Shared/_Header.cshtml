@using GadgetVault.Data
@inject ApplicationDbContext DbContext
@{
    var settings = DbContext.SystemSettings.FirstOrDefault();
    var brandName = settings?.CompanyName ?? "GadgetVault";
    var logoUrl = settings?.LogoUrl;
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom box-shadow">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrEmpty(logoUrl))
                {
                    <img src="@logoUrl" alt="@brandName Logo" style="height: 30px; border-radius: 4px; object-fit: cover;" />
                }
                <strong>@brandName</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex">
                <ul class="navbar-nav me-auto">
                    <!-- Links -->
                </ul>
            </div>

            <!-- Forced Visibility Sign In Button -->
            <div style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); z-index: 1060;">
                <a class="nav-link nav-btn-started" asp-area="" asp-controller="Account" asp-action="Login" 
                   style="display: flex !important; align-items: center; justify-content: center; font-weight: 700; color: #ffffff !important; white-space: nowrap;">
                    Sign In
                </a>
            </div>
        </div>
    </nav>
</header>







