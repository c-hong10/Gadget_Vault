@using GadgetVault.Data
@inject ApplicationDbContext DbContext
@{
    var settings = DbContext.SystemSettings.FirstOrDefault();
    var brandName = settings?.CompanyName ?? "GadgetVault";
    var logoUrl = settings?.LogoUrl;
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom box-shadow">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrEmpty(logoUrl))
                {
                    <img src="@logoUrl" alt="@brandName Logo" style="height: 30px; border-radius: 4px; object-fit: cover;" />
                }
                <strong>@brandName</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav">
                    <li class="nav-item d-flex align-items-center">
                        <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login" style="font-weight: 600;">Sign In</a>
                    </li>
                    <li class="nav-item ms-3 d-flex align-items-center">
                        <a class="btn nav-btn-started" asp-area="" asp-controller="Account" asp-action="SignUp">Get Started</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>






