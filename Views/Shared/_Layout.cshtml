<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GadgetVault</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GadgetVault.styles.css" asp-append-version="true" />
</head>
<style>
    :root {
        --primary-green: #0a3124;
        --secondary-green: #115740;
        --accent-green: #23a476;
        --light-green: #f2f7f5;
        --dark-green: #061f17;
        --text-dark: #121c19;
        --white: #ffffff;
    }
        .navbar-custom {
            background-color: #0b3d2c !important;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: #ffffff !important;
            font-weight: 500;
        }
        .navbar-custom .nav-link:hover {
            color: #23a476 !important;
        }
        .footer-custom {
            background-color: #0b3d2c;
            color: #d1e8df;
            border-top: none;
            padding: 20px 0;
            margin-top: auto;
        }
        .footer-custom a {
            color: #23a476;
            text-decoration: none;
        }
        .footer-custom a:hover {
            color: #ffffff;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }
        main {
            flex: 1;
        }
        .nav-btn-started {
            background-color: #23a476; 
            color: #ffffff !important; 
            font-weight: 600; 
            border-radius: 30px; 
            padding: 8px 24px; 
            box-shadow: 0 4px 10px rgba(35, 164, 118, 0.3); 
            transition: all 0.3s ease;
        }
        .nav-btn-started:hover {
            background-color: #ffffff;
            color: #23a476 !important;
            transform: translateY(-2px);
        }
    </style>
<body>
    <partial name="_Header" />
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom text-center">
        <div class="container">
            &copy; 2026 - GadgetVault IWMS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
