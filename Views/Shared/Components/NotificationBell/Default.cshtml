@using GadgetVault.ViewComponents
@model List<LowStockNotification>

@{
    var count = Model.Count;
}

<div class="relative inline-block text-left" id="notificationBellWrapper">
    <!-- Bell Button -->
    <button onclick="toggleNotifications()" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 p-2 rounded-lg transition-colors duration-200 relative">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
        @if (count > 0)
        {
            <span class="absolute top-[3px] right-[5px] w-2 h-2 bg-red-500 rounded-full border border-white dark:border-[#09090b] animate-pulse"></span>
        }
    </button>

    <!-- Dropdown -->
    <div id="notificationDropdown" class="hidden absolute right-0 mt-3 w-80 bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl z-50 overflow-hidden transform origin-top-right transition-all duration-200 scale-95 opacity-0">
        <div class="px-5 py-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-white/5 flex items-center justify-between">
            <h3 class="text-xs font-black text-slate-900 dark:text-white uppercase tracking-widest">Notifications</h3>
            @if (count > 0)
            {
                <span class="bg-red-500 text-white text-[10px] font-black px-2 py-0.5 rounded-full">@count ALERT@(count > 1 ? "S" : "")</span>
            }
        </div>

        <div class="max-h-[300px] overflow-y-auto divide-y divide-slate-100 dark:divide-slate-800/60">
            @if (count > 0)
            {
                @foreach (var item in Model)
                {
                    <a href="/Warehouse/LiveInventory?filter=low" class="flex items-start gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <div class="shrink-0 w-8 h-8 rounded-lg bg-red-100 dark:bg-red-500/10 flex items-center justify-center">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="2.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center justify-between gap-2">
                                <p class="text-[0.8rem] font-bold text-slate-900 dark:text-slate-100 truncate">@item.ProductName</p>
                                @{
                                    var statusColor = item.CurrentQty == 0 ? "text-red-600" : "text-orange-500";
                                }
                                <span class="text-[10px] font-black uppercase @statusColor shrink-0">@item.StatusLabel</span>
                            </div>
                            <p class="text-[0.7rem] text-slate-400 mt-0.5 font-medium truncate">SKU: @item.SKU · Loc: @item.LocationLabel</p>
                            <p class="text-[0.7rem] text-slate-500 mt-1 font-medium">Qty: <span class="font-bold @statusColor">@item.CurrentQty</span> <span class="opacity-50">/ Limit: @item.Threshold</span></p>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="px-5 py-12 text-center">
                    <div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#94a3b8" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">No Critical Alerts</p>
                    <p class="text-[0.7rem] text-slate-500 mt-1 font-medium">All inventory levels are healthy.</p>
                </div>
            }
        </div>

        <a href="/Warehouse/LiveInventory" class="block w-full py-3 text-center text-[10px] font-black text-slate-400 hover:text-gv-brand uppercase tracking-widest bg-slate-50/50 dark:bg-white/5 border-t border-slate-100 dark:border-slate-800 transition-colors">
            View Live Inventory →
        </a>
    </div>
</div>

<script>
    function toggleNotifications() {
        const d = document.getElementById('notificationDropdown');
        if (d.classList.contains('hidden')) {
            d.classList.remove('hidden');
            setTimeout(() => {
                d.classList.remove('scale-95', 'opacity-0');
            }, 10);
        } else {
            d.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                d.classList.add('hidden');
            }, 200);
        }
    }

    document.addEventListener('click', function(e) {
        const w = document.getElementById('notificationBellWrapper');
        if (w && !w.contains(e.target)) {
            const d = document.getElementById('notificationDropdown');
            if (d && !d.classList.contains('hidden')) {
                d.classList.add('scale-95', 'opacity-0');
                setTimeout(() => d.classList.add('hidden'), 200);
            }
        }
    });
</script>
