@model IEnumerable<StockLevel>
@using GadgetVault.Data
@inject ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Live Inventory";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var inventory = Model ?? Enumerable.Empty<StockLevel>();
    var settings = DbContext.SystemSettings.FirstOrDefault() ?? new SystemSettings();
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">

    <!-- PAGE HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Live Inventory</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Real-time monitoring of physical stock across all warehouse zones.</p>
        </div>
        <div class="flex items-center gap-3">
             <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-xs font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                Live Updates Enabled
            </div>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm flex flex-col">

        <!-- Toolbar -->
        <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#111113]/50">
            <div class="flex flex-1 flex-col sm:flex-row gap-3">
                <!-- Search -->
                <div class="relative w-full sm:w-80">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                         width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
                    </svg>
                    <input type="text" id="inventory-search" oninput="filterInventory()" placeholder="Search by SKU, name or zone..."
                           class="w-full pl-9 pr-4 py-2 bg-white dark:bg-[#09090b] border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                
                @if (User.IsInRole("Admin") || User.IsInRole("SystemManager"))
                {
                    <button onclick="openThresholdModal()" class="flex items-center gap-2 px-4 py-2 bg-white dark:bg-[#1c1c1f] border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Threshold Settings
                    </button>
                }
            </div>
            <div class="text-xs font-medium text-slate-400 dark:text-slate-500">
                Displaying @inventory.Count() stock points
            </div>
        </div>

        <!-- THRESHOLD SETTINGS MODAL -->
        <div id="threshold-modal" class="fixed inset-0 z-50 hidden">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="closeThresholdModal()"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-[#111113] rounded-3xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
                <div class="px-8 pt-8 pb-4">
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white">Inventory Thresholds</h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Global alert settings for stock levels.</p>
                </div>
                
                <div class="px-8 py-6 flex flex-col gap-5">
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Low Stock Threshold (Orange Alert)</label>
                        <input type="number" id="low-threshold-input" value="@settings.LowStockThreshold" 
                               class="w-full px-4 py-3 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm font-semibold text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all" />
                        <p class="text-[10px] text-slate-400">Products at or below this quantity will show as "Low Stock".</p>
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">In Stock Threshold (Green Active)</label>
                        <input type="number" id="instock-threshold-input" value="@settings.InStockThreshold" 
                               class="w-full px-4 py-3 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm font-semibold text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all" />
                        <p class="text-[10px] text-slate-400">Products above this quantity will show as "In Stock".</p>
                    </div>
                </div>

                <div class="px-8 py-6 bg-slate-50 dark:bg-slate-900/50 flex justify-end gap-3">
                    <button onclick="closeThresholdModal()" class="px-5 py-2 text-sm font-bold text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">Cancel</button>
                    <button onclick="saveThresholds()" id="save-thresholds-btn" class="px-6 py-2 bg-gv-brand text-white text-sm font-bold rounded-xl shadow-lg shadow-emerald-500/20 hover:scale-105 transition-all">Save Changes</button>
                </div>
            </div>
        </div>

        <!-- INVENTORY TABLE -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm whitespace-nowrap" id="inventory-table">
                <thead>
                    <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 w-16">Image</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">SKU</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Product Name</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Category</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Location</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Qty on Hand</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("SystemManager"))
                        {
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-center">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var item in inventory)
                    {
                        var (statusBg, statusText, statusBorder, dotColor, statusLabel) = item.Quantity switch
                        {
                            0 => ("bg-red-100 dark:bg-red-500/10", "text-red-700 dark:text-red-400", "border-red-200 dark:border-red-500/20", "bg-red-500", "No Stock"),
                            _ when item.Quantity <= settings.LowStockThreshold => ("bg-orange-100 dark:bg-orange-500/10", "text-orange-700 dark:text-orange-400", "border-orange-200 dark:border-orange-500/20", "bg-orange-500", "Low Stock"),
                            _ => ("bg-green-100 dark:bg-green-500/10", "text-green-700 dark:text-green-400", "border-green-200 dark:border-green-500/20", "bg-green-500", "In Stock")
                        };

                        <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group inventory-row">
                            <td class="px-6 py-4">
                                <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 overflow-hidden flex items-center justify-center">
                                    @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt="" class="w-full h-full object-cover"/>
                                    }
                                    else
                                    {
                                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="text-slate-400">
                                            <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs font-bold text-slate-500 dark:text-slate-400">@item.Product?.SKU</td>
                            <td class="px-6 py-4">
                                <div class="font-semibold text-slate-800 dark:text-slate-200">@item.Product?.Name</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-medium text-slate-500 dark:text-slate-400 px-2 py-1 rounded-md bg-slate-100 dark:bg-slate-800">
                                    @(item.Product?.Category?.Name ?? "General")
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-xs font-bold text-slate-700 dark:text-slate-300">
                                        @item.Location?.Zone - @item.Location?.Aisle
                                    </span>
                                    <span class="text-[10px] text-slate-400 uppercase tracking-tighter">
                                        Rack: @item.Location?.Rack | Bin: @item.Location?.Bin
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold border @statusBg @statusText @statusBorder">
                                    <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                                    @statusLabel (@item.Quantity)
                                </span>
                            </td>
                            @if (User.IsInRole("Admin") || User.IsInRole("SystemManager"))
                            {
                                <td class="px-6 py-4 text-center">
                                    @if (item.Quantity == 0)
                                    {
                                        <button onclick="deleteRecord(@item.Id, '@item.Product?.Name', '@item.Location?.Zone-@item.Location?.Aisle')"
                                                class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all group/btn"
                                                title="Clear Empty Record">
                                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="group-hover/btn:scale-110 transition-transform">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] font-bold text-slate-300 dark:text-slate-600 uppercase tracking-widest">Locked</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function openThresholdModal() {
    document.getElementById('threshold-modal').classList.remove('hidden');
}

function closeThresholdModal() {
    document.getElementById('threshold-modal').classList.add('hidden');
}

function saveThresholds() {
    const low = document.getElementById('low-threshold-input').value;
    const instock = document.getElementById('instock-threshold-input').value;
    const btn = document.getElementById('save-thresholds-btn');
    
    btn.disabled = true;
    btn.innerText = 'Saving...';

    const formData = new FormData();
    formData.append('lowThreshold', low);
    formData.append('inStockThreshold', instock);
    formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

    fetch('/Warehouse/UpdateThresholds', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message);
            btn.disabled = false;
            btn.innerText = 'Save Changes';
        }
    })
    .catch(err => {
        console.error(err);
        alert('An error occurred while saving.');
        btn.disabled = false;
        btn.innerText = 'Save Changes';
    });
}

function filterInventory() {
    const search = document.getElementById('inventory-search').value.toLowerCase();
    const rows = document.querySelectorAll('.inventory-row');
    
    rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        row.style.display = text.includes(search) ? '' : 'none';
    });
}

function deleteRecord(id, productName, location) {
    if (typeof showConfirm === 'function') {
        showConfirm(
            'Clear Empty Record',
            `You are about to remove the empty inventory slot for ${productName} in ${location}. This action cannot be undone.`,
            function() {
                const formData = new FormData();
                formData.append('inventoryId', id);
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

                fetch('/Warehouse/DeleteEmptyStockRecord', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(err => console.error(err));
            }
        );
    } else {
        // Fallback
        if (confirm(`Clear record for ${productName}?`)) {
            // ... standard form submit ...
        }
    }
}
</script>

@Html.AntiForgeryToken()
