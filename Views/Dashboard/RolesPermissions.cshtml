@{
    ViewData["Title"] = "Roles & Permissions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Roles & Permissions</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage system access levels and granular permissions.</p>
        </div>
        <button class="flex items-center justify-center gap-2 px-4 py-2 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-sm transition-all shrink-0">
            Create Role
        </button>
    </div>

    <!-- Roles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Role 1 -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">System Admin</h3>
                <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-bold rounded-md">3 Users</span>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400 border-b border-slate-100 dark:border-slate-800 pb-4">Full access to all system modules, configurations, and user management.</p>
            <div class="flex flex-col gap-3 mt-2">
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">User Management</span>
                    <input type="checkbox" checked disabled class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">System Configuration</span>
                    <input type="checkbox" checked disabled class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
            </div>
            <button class="mt-4 w-full py-2 text-sm font-bold text-white bg-gv-brand hover:opacity-90 rounded-lg transition-colors border border-transparent shadow-sm">Edit Permissions</button>
        </div>

        <!-- Role 2 -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">Warehouse Manager</h3>
                <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-bold rounded-md">8 Users</span>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400 border-b border-slate-100 dark:border-slate-800 pb-4">Full access to inventory, receiving, and master data configurations.</p>
            <div class="flex flex-col gap-3 mt-2">
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Edit Master Data</span>
                    <input type="checkbox" checked class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Approve Adjustments</span>
                    <input type="checkbox" checked class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
            </div>
            <button class="mt-4 w-full py-2 text-sm font-bold text-white bg-gv-brand hover:opacity-90 rounded-lg transition-colors border border-transparent shadow-sm">Edit Permissions</button>
        </div>

        <!-- Role 3 -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">Warehouse Staff</h3>
                <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-bold rounded-md">24 Users</span>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400 border-b border-slate-100 dark:border-slate-800 pb-4">Restricted access to operational workflows like pick, pack, and ship.</p>
            <div class="flex flex-col gap-3 mt-2">
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">View Inventory</span>
                    <input type="checkbox" checked class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
                <label class="flex items-center justify-between cursor-pointer">
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Approve Adjustments</span>
                    <input type="checkbox" class="accent-[#23a476] w-4 h-4" style="accent-color: var(--brand-color);" />>
                </label>
            </div>
            <button class="mt-4 w-full py-2 text-sm font-bold text-white bg-gv-brand hover:opacity-90 rounded-lg transition-colors border border-transparent shadow-sm">Edit Permissions</button>
        </div>
    </div>
</div>






