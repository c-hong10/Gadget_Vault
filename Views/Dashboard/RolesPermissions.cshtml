@using Microsoft.AspNetCore.Html
@model IEnumerable<GadgetVault.Models.Role>
@{
    ViewData["Title"] = "Roles & Permissions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Roles & Permissions</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage system access levels and granular permissions.</p>
        </div>
        <button onclick="openCreateRoleModal()" class="flex items-center justify-center gap-2 px-4 py-2 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-sm transition-all shrink-0">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" /></svg>
            Create Role
        </button>
    </div>

    <!-- Roles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (Model != null && Model.Any())
        {
            foreach (var role in Model)
            {
                <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-6 shadow-sm flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">@role.Name</h3>
                        <span class="px-2 py-1 bg-slate-100 dark:bg-[#1e1e24] text-slate-600 dark:text-slate-400 text-xs font-bold rounded-md">
                            @(role.Users?.Count ?? 0) Users
                        </span>
                    </div>
                    <p class="text-sm text-slate-500 dark:text-slate-400 border-b border-slate-100 dark:border-[#1e1e24] pb-4 flex-1">
                        @role.Description
                    </p>
                    <div class="flex flex-col gap-1.5 mt-2">
                        <div class="flex items-center justify-between text-xs font-medium text-slate-500 dark:text-slate-400">
                            <span>Security Coverage</span>
                            <span class="text-gv-brand font-bold">@(role.Permissions?.Split(',', StringSplitOptions.RemoveEmptyEntries).Length ?? 0) Keys</span>
                        </div>
                        <div class="w-full bg-slate-100 dark:bg-[#1e1e24] h-1 rounded-full overflow-hidden">
                            <div class="bg-gv-brand h-full transition-all duration-500" style="width: @((role.Permissions?.Split(',', StringSplitOptions.RemoveEmptyEntries).Length ?? 0) * 5)%"></div>
                        </div>
                    </div>
                    <button onclick="openEditRoleModal(@role.Id, '@role.Name', '@role.Description', '@role.Permissions')"
                       class="mt-4 w-full py-2.5 text-center text-sm font-bold text-white bg-gv-brand hover:opacity-90 rounded-lg transition-colors border border-transparent shadow-sm">
                        Edit Permissions
                    </button>
                </div>
            }
        }
    </div>
</div>

<!-- Create Role Modal -->
<div id="createRoleModal" class="hidden fixed inset-0 bg-slate-900/60 dark:bg-black/70 backdrop-blur-sm flex items-center justify-center z-50 p-4">
    <div class="w-full max-w-md bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between">
            <div>
                <h2 class="text-base font-bold text-slate-900 dark:text-white">Create New Role</h2>
                <p class="text-xs text-slate-400 mt-0.5">Define a new system access level.</p>
            </div>
            <button onclick="closeCreateRoleModal()" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div class="p-6">
            <form method="post" asp-action="CreateRole" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Role Name</label>
                    <input type="text" name="name" required placeholder="e.g. Sales Director"
                        class="w-full bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-[#1e1e24]/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Description</label>
                    <textarea name="description" rows="3" required placeholder="Describe the access level..."
                        class="w-full bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-[#1e1e24]/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="closeCreateRoleModal()"
                        class="flex-1 py-2.5 px-4 bg-slate-100 dark:bg-[#1e1e24] text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="flex-[2] py-2.5 px-4 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                        Save Role
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Role Modal -->
<div id="editRoleModal" class="hidden fixed inset-0 bg-slate-900/60 dark:bg-black/70 backdrop-blur-sm flex items-center justify-center z-50 p-4">
    <div class="w-full max-w-2xl bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl overflow-hidden max-h-[90vh] flex flex-col">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between shrink-0">
            <div>
                <h2 class="text-base font-bold text-slate-900 dark:text-white">Permissions: <span id="edit-role-title"></span></h2>
                <p class="text-xs text-slate-400 mt-0.5">Map granular access to the system modules.</p>
            </div>
            <button onclick="closeEditRoleModal()" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div class="p-6 overflow-y-auto">
            <form method="post" asp-action="UpdateRole" class="space-y-6" id="updateRoleForm">
                <input type="hidden" name="id" id="edit-role-id" />
                <input type="hidden" name="name" id="edit-role-name" />
                <input type="hidden" name="description" id="edit-role-desc" />

                <div class="space-y-8">
                    @PermissionGroup("Overview", "indigo", "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6", new[] {
                        ("Overview_MyDashboard", "My Dashboard", "Personalized role-specific dashboard")
                    })

                    @PermissionGroup("Administration", "blue", "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4", new[] {
                        ("Admin_UserManagement", "User Management", "Manage accounts and roles"),
                        ("Admin_RolesPermissions", "Roles & Permissions", "Configure security keys"),
                        ("Admin_MasterData", "Master Data", "Entity master tables"),
                        ("Admin_SecurityLogs", "Security Logs", "Audit of security events"),
                        ("Admin_SystemLogs", "System Logs", "Technical telemetry stream"),
                        ("Admin_CompanySettings", "Company Settings", "Branding and global config")
                    })

                    @PermissionGroup("Warehouse", "emerald", "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4", new[] {
                        ("Wh_ProductCatalog", "Product Catalog", "Manage SKUs and inventory"),
                        ("Wh_LiveInventory", "Live Inventory", "Real-time stock level tracking"),
                        ("Wh_ReceiveStock", "Receive Stock", "Process incoming shipments"),
                        ("Wh_PickPack", "Pick & Pack", "Fulfillment and picking lists"),
                        ("Wh_StockAdjustments", "Stock Adjustments", "Quantity corrections")
                    })

                    @PermissionGroup("Commercial", "amber", "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z", new[] {
                        ("Comm_BusinessDirectory", "Business Directory", "Partner and vendor directory"),
                        ("Comm_PurchaseOrders", "Purchase Orders", "Procurement workflows"),
                        ("Comm_SalesOrders", "Sales Orders", "Client transaction management")
                    })

                    @PermissionGroup("Supplier Access", "rose", "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", new[] {
                        ("Supp_MyOrders", "My Orders", "Supplier shipment tracking"),
                        ("Supp_OrderHistory", "Order History", "Completed order records"),
                        ("Supp_MyCatalog", "My Catalog", "Specific vendor product line"),
                        ("Supp_CompanyInfo", "Company Info", "Supplier profile settings")
                    })
                </div>

                <div class="flex gap-3 pt-4 sticky bottom-0 bg-white dark:bg-[#111113] py-4 border-t border-slate-100 dark:border-[#1e1e24] shrink-0">
                    <button type="button" onclick="closeEditRoleModal()"
                        class="flex-1 py-2.5 px-4 bg-slate-100 dark:bg-[#1e1e24] text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="flex-[2] py-2.5 px-4 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                        Update Role Configuration
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    IHtmlContent PermissionGroup(string title, string color, string iconPath, (string key, string label, string desc)[] items)
    {
        var groupId = $"group-{title.Replace("&", "").Replace(" ", "-").ToLower()}";
        var groupHtml = $@"
        <div class=""permission-group"" id=""{groupId}"">
            <div class=""flex items-center justify-between mb-4"">
                <div class=""flex items-center gap-3"">
                    <div class=""w-8 h-8 rounded-lg bg-{color}-50 dark:bg-{color}-900/20 flex items-center justify-center text-{color}-500"">
                        <svg width=""18"" height=""18"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor"" stroke-width=""2""><path d=""{iconPath}""/></svg>
                    </div>
                    <h3 class=""text-sm font-bold text-slate-800 dark:text-slate-100"">{title}</h3>
                </div>
                <label class=""flex items-center gap-2 cursor-pointer group/selectall"">
                    <span class=""text-[0.65rem] font-bold text-slate-400 group-hover/selectall:text-gv-brand transition-colors uppercase tracking-wider"">Select All</span>
                    <input type=""checkbox"" onchange=""toggleGroup(this, '{groupId}')"" 
                        class=""w-3.5 h-3.5 rounded border-slate-300 text-gv-brand focus:ring-gv-brand accent-gv-brand cursor-pointer"" />
                </label>
            </div>
            <div class=""grid grid-cols-1 sm:grid-cols-2 gap-3 pl-11"">";

        foreach (var item in items)
        {
            groupHtml += $@"
                <label class=""flex items-start gap-3 p-3 rounded-xl border border-slate-100 dark:border-[#1e1e24]/60 hover:bg-slate-50 dark:hover:bg-[#1e1e24]/30 transition-all cursor-pointer group"">
                    <div class=""mt-0.5"">
                        <input type=""checkbox"" name=""selectedPermissions"" value=""{item.key}"" data-perm-key=""{item.key}""
                            class=""w-4 h-4 rounded border-slate-300 text-gv-brand focus:ring-gv-brand accent-gv-brand"" />
                    </div>
                    <div class=""min-w-0"">
                        <p class=""text-[0.7rem] font-bold text-slate-700 dark:text-slate-200 group-hover:text-gv-brand transition-colors"">{item.label}</p>
                        <p class=""text-[0.6rem] text-slate-400 dark:text-slate-500 leading-relaxed truncate"">{item.desc}</p>
                    </div>
                </label>";
        }

        groupHtml += "</div></div>";
        return new HtmlString(groupHtml);
    }
}

<script>
    function openCreateRoleModal() {
        document.getElementById('createRoleModal').classList.remove('hidden');
    }
    function closeCreateRoleModal() {
        document.getElementById('createRoleModal').classList.add('hidden');
    }

    function toggleGroup(selectAllCb, groupId) {
        const group = document.getElementById(groupId);
        const checkboxes = group.querySelectorAll('input[name="selectedPermissions"]');
        checkboxes.forEach(cb => {
            cb.checked = selectAllCb.checked;
        });
    }

    function openEditRoleModal(id, name, desc, permissions) {
        document.getElementById('edit-role-id').value = id;
        document.getElementById('edit-role-name').value = name;
        document.getElementById('edit-role-desc').value = desc;
        document.getElementById('edit-role-title').innerText = name;

        const checkboxes = document.querySelectorAll('#editRoleModal input[name="selectedPermissions"]');
        checkboxes.forEach(cb => cb.checked = false);
        
        const selectAlls = document.querySelectorAll('#editRoleModal input[onchange^="toggleGroup"]');
        selectAlls.forEach(cb => cb.checked = false);

        if (permissions) {
            const permList = permissions.split(',');
            permList.forEach(key => {
                const cb = document.querySelector(`#editRoleModal input[data-perm-key="${key}"]`);
                if (cb) cb.checked = true;
            });
        } else {
            // Seeding logic (Default states)
            if (name === 'Admin') {
                checkboxes.forEach(cb => cb.checked = true);
            } else if (name === 'Warehouse Manager' || name === 'WarehouseManager') {
                checkGroup('Overview_MyDashboard');
                checkPrefix('Wh_');
                checkPrefix('Comm_');
            } else if (name === 'Warehouse Staff' || name === 'WarehouseStaff') {
                checkPrefix('Wh_');
            } else if (name === 'SalesAndProcurement') {
                checkGroup('Wh_ProductCatalog');
                checkGroup('Wh_LiveInventory');
                checkPrefix('Comm_');
            } else if (name === 'Supplier') {
                checkGroup('Overview_MyDashboard');
                checkPrefix('Supp_');
            }
        }

        // Auto-check "Select All" if all in group checked
        const groups = document.querySelectorAll('.permission-group');
        groups.forEach(group => {
            const items = group.querySelectorAll('input[name="selectedPermissions"]');
            const selectAll = group.querySelector('input[onchange^="toggleGroup"]');
            const allChecked = Array.from(items).every(i => i.checked);
            if (allChecked && items.length > 0) selectAll.checked = true;
        });

        document.getElementById('editRoleModal').classList.remove('hidden');
    }

    function checkGroup(key) {
        const cb = document.querySelector(`#editRoleModal input[data-perm-key="${key}"]`);
        if (cb) cb.checked = true;
    }

    function checkPrefix(prefix) {
        const checkboxes = document.querySelectorAll(`#editRoleModal input[data-perm-key^="${prefix}"]`);
        checkboxes.forEach(cb => cb.checked = true);
    }

    function closeEditRoleModal() {
        document.getElementById('editRoleModal').classList.add('hidden');
    }
</script>
