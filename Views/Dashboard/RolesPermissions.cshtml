@using Microsoft.AspNetCore.Html
@model IEnumerable<GadgetVault.Models.Role>
@{
    ViewData["Title"] = "Roles & Permissions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-8 pb-12">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Access Control Matrix</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Define granular View and Edit permissions across system modules.</p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="savePermissions()" class="flex items-center justify-center gap-2 px-6 py-3 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-2xl shadow-xl shadow-gv-brand/20 transition-all shrink-0 active:scale-95">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" /></svg>
                Deploy Configuration
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        
        <!-- Left Column: Role Selector -->
        <div class="lg:col-span-1 space-y-4">
            <div class="flex items-center justify-between px-2 mb-2">
                <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">System Roles</h3>
                <button onclick="openCreateRoleModal()" class="text-gv-brand hover:text-gv-brand-dark transition-colors">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" /></svg>
                </button>
            </div>
            
            <div class="flex flex-col gap-2" id="role-selector">
                @foreach (var role in Model)
                {
                    <button onclick="selectRole(@role.Id, '@role.Name', '@role.Permissions')" 
                            data-role-id="@role.Id"
                            class="role-btn group flex flex-col items-start gap-1 p-4 rounded-2xl border transition-all text-left bg-white dark:bg-[#111113] border-slate-200 dark:border-[#1e1e24] hover:border-gv-brand/50">
                        <span class="text-sm font-bold text-slate-900 dark:text-white group-[.active]:text-white">@role.Name</span>
                        <span class="text-[10px] text-slate-500 dark:text-slate-500 group-[.active]:text-white/70">@(role.Users?.Count ?? 0) Active Users</span>
                    </button>
                }
            </div>
        </div>

        <!-- Right Column: Permission Matrix -->
        <div class="lg:col-span-3">
            <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-[2rem] shadow-sm overflow-hidden flex flex-col min-h-[600px]">
                
                <!-- Matrix Header -->
                <div class="px-8 py-6 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between bg-slate-50/50 dark:bg-black/20">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl bg-gv-brand/10 flex items-center justify-center text-gv-brand">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        </div>
                        <div>
                            <h2 class="text-lg font-black text-slate-900 dark:text-white tracking-tight" id="active-role-display">Select a Role</h2>
                            <p class="text-xs text-slate-500 dark:text-slate-400">Configure module-specific access rights.</p>
                        </div>
                    </div>
                </div>

                <!-- Matrix Table -->
                <form id="permission-form" class="flex-1 overflow-x-auto">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="RoleId" id="active-role-id" />
                    
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50 dark:bg-[#1e1e24]/30 border-b border-slate-100 dark:border-[#1e1e24]">
                                <th class="px-8 py-5 text-xs font-black uppercase tracking-[0.2em] text-slate-400">System Module</th>
                                <th class="px-8 py-5 text-xs font-black uppercase tracking-[0.2em] text-slate-400 text-center">View Access</th>
                                <th class="px-8 py-5 text-xs font-black uppercase tracking-[0.2em] text-slate-400 text-center">Edit / Create</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50 dark:divide-[#1e1e24]">
                            @CategoryHeader("Overview")
                            @MatrixRow("System Dashboard", "SystemDashboard", "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")
                            @MatrixRow("My Dashboard", "MyDashboard", "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")

                            @CategoryHeader("Administration")
                            @MatrixRow("User Management", "UserManagement", "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z")
                            @MatrixRow("Roles & Permissions", "RolesPermissions", "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
                            @MatrixRow("Master Data", "MasterData", "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4")
                            @MatrixRow("Security Logs", "SecurityLogs", "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
                            @MatrixRow("System Logs", "SystemLogs", "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z")
                            @MatrixRow("Company Settings", "CompanySettings", "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z")

                            @CategoryHeader("Warehouse")
                            @MatrixRow("Product Catalog", "ProductCatalog", "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")
                            @MatrixRow("Live Inventory", "LiveInventory", "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z")
                            @MatrixRow("Receive Stock", "ReceiveStock", "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4")
                            @MatrixRow("Pick & Pack", "PickPack", "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4")
                            @MatrixRow("Stock Adjustments", "StockAdjustments", "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4")

                            @CategoryHeader("Commercial")
                            @MatrixRow("Business Directory", "BusinessDirectory", "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4")
                            @MatrixRow("Purchase Orders", "PurchaseOrders", "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z")
                            @MatrixRow("Sales Orders", "SalesOrders", "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.407 2.651 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.407-2.651-1M12 16V15")

                            @CategoryHeader("Supplier Access")
                            @MatrixRow("My orders", "SuppOrders", "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z")
                            @MatrixRow("Order history", "SuppOrderHistory", "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
                            @MatrixRow("My catalog", "SuppCatalog", "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10")
                            @MatrixRow("Company info", "SuppCompanyInfo", "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
                        </tbody>
                    </table>
                </form>

                <!-- Placeholder state -->
                <div id="matrix-placeholder" class="flex-1 flex flex-col items-center justify-center p-12 text-center">
                    <div class="w-20 h-20 rounded-full bg-slate-50 dark:bg-[#1e1e24] flex items-center justify-center text-slate-300 mb-4 animate-pulse">
                        <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" /></svg>
                    </div>
                    <h3 class="text-lg font-bold text-slate-400">No Role Selected</h3>
                    <p class="text-sm text-slate-500 max-w-xs mt-2">Choose a system role from the left column to begin adjusting granular permissions.</p>
                </div>

            </div>
        </div>
    </div>
</div>

@functions {
    IHtmlContent CategoryHeader(string title)
    {
        var html = $@"
        <tr class=""bg-slate-50/30 dark:bg-[#1e1e24]/10"">
            <td colspan=""3"" class=""px-8 py-3 text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 border-y border-slate-100 dark:border-[#1e1e24]"">
                {title}
            </td>
        </tr>";
        return new HtmlString(html);
    }

    IHtmlContent MatrixRow(string label, string key, string iconPath)
    {
        var html = $@"
        <tr class=""hover:bg-slate-50/50 dark:hover:bg-[#1e1e24]/30 transition-all group"">
            <td class=""px-8 py-5"">
                <div class=""flex items-center gap-4"">
                    <div class=""w-8 h-8 rounded-xl bg-slate-100 dark:bg-[#1e1e24] flex items-center justify-center text-slate-400 group-hover:bg-gv-brand/10 group-hover:text-gv-brand transition-all"">
                        <svg width=""16"" height=""16"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor"" stroke-width=""2.5""><path d=""{iconPath}"" /></svg>
                    </div>
                    <span class=""text-sm font-bold text-slate-700 dark:text-slate-200"">{label}</span>
                </div>
            </td>
            <td class=""px-8 py-5 text-center"">
                <label class=""relative inline-flex items-center cursor-pointer"">
                    <input type=""checkbox"" name=""Permissions[{key}][canView]"" data-module=""{key}"" data-perm=""canView"" class=""sr-only peer"">
                    <div class=""w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-[#1e1e24] peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-gv-brand""></div>
                </label>
            </td>
            <td class=""px-8 py-5 text-center"">
                <label class=""relative inline-flex items-center cursor-pointer"">
                    <input type=""checkbox"" name=""Permissions[{key}][canEdit]"" data-module=""{key}"" data-perm=""canEdit"" class=""sr-only peer"">
                    <div class=""w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-[#1e1e24] peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-gv-brand""></div>
                </label>
            </td>
        </tr>";
        return new HtmlString(html);
    }
}

<script>
    let activeRoleId = null;

    function selectRole(id, name, permissions) {
        activeRoleId = id;
        
        // UI Updates
        document.querySelectorAll('.role-btn').forEach(btn => {
            btn.classList.remove('active', 'bg-gv-brand', 'border-gv-brand');
            if(btn.dataset.roleId == id) {
                btn.classList.add('active', 'bg-gv-brand', 'border-gv-brand');
            }
        });

        document.getElementById('active-role-id').value = id;
        document.getElementById('active-role-display').innerText = name;
        document.getElementById('permission-form').classList.remove('hidden');
        document.getElementById('matrix-placeholder').classList.add('hidden');

        // Reset all checkboxes
        document.querySelectorAll('#permission-form input[type="checkbox"]').forEach(cb => cb.checked = false);

        // Load Existing Permissions
        if (permissions && permissions.trim() !== '') {
            try {
                if (permissions.startsWith('{')) {
                    // Modern JSON Format
                    const perms = JSON.parse(permissions);
                    for (const module in perms) {
                        setPerm(module, perms[module].canView, perms[module].canEdit);
                    }
                } else {
                    // Legacy Comma-Separated Format Fallback
                    const list = permissions.split(',');
                    list.forEach(key => {
                        // In legacy, we assume presence means both View and Edit for simplicity during migration
                        setPerm(key, true, true);
                    });
                }
            } catch (e) {
                console.error("Failed to parse permissions", e);
            }
        } else {
            // Apply Role-Specific Presets (If new role or no permissions set)
            applyPresets(name);
        }
    }

    function applyPresets(name) {
        if (name === 'Admin') {
            document.querySelectorAll('#permission-form input[type="checkbox"]').forEach(cb => cb.checked = true);
        } else if (name === 'Warehouse Staff' || name === 'WarehouseStaff') {
            setPerm('MyDashboard', true, false);
            setPerm('ProductCatalog', true, false);
            setPerm('LiveInventory', true, false);
            setPerm('ReceiveStock', true, true);
            setPerm('PickPack', true, true);
            setPerm('PurchaseOrders', true, false);
        } else if (name === 'Warehouse Manager' || name === 'WarehouseManager') {
            setPerm('SystemDashboard', true, false);
            setPerm('MyDashboard', true, false);
            setPerm('ProductCatalog', true, true);
            setPerm('LiveInventory', true, true);
            setPerm('ReceiveStock', true, true);
            setPerm('PickPack', true, true);
            setPerm('StockAdjustments', true, true);
        } else if (name === 'Sales & Procurement' || name === 'SalesAndProcurement') {
            setPerm('SystemDashboard', true, false);
            setPerm('MyDashboard', true, false);
            setPerm('BusinessDirectory', true, true);
            setPerm('PurchaseOrders', true, true);
            setPerm('SalesOrders', true, true);
            setPerm('ProductCatalog', true, false);
        } else if (name === 'Supplier') {
            setPerm('MyDashboard', true, false);
            setPerm('SuppCatalog', true, false);
            setPerm('SuppOrders', true, false);
        }
    }

    function setPerm(module, canView, canEdit) {
        const viewCb = document.querySelector(`input[data-module="${module}"][data-perm="canView"]`);
        const editCb = document.querySelector(`input[data-module="${module}"][data-perm="canEdit"]`);
        if (viewCb) viewCb.checked = canView;
        if (editCb) editCb.checked = canEdit;
    }

    function savePermissions() {
        if (!activeRoleId) {
            alert("Please select a role to configure first.");
            return;
        }

        const obj = {};
        document.querySelectorAll('#permission-form input[type="checkbox"]').forEach(cb => {
            const module = cb.dataset.module;
            const perm = cb.dataset.perm;
            if (!obj[module]) obj[module] = {};
            obj[module][perm] = cb.checked;
        });

        // Visual feedback
        const btn = document.querySelector('button[onclick="savePermissions()"]');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = `<svg class="animate-spin h-4 w-4 text-white inline-block mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Deploying...`;
        btn.disabled = true;

        fetch('/Dashboard/UpdatePermissions', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify({ roleId: parseInt(activeRoleId), permissions: obj })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showSuccessToast("Configuration Deployed", "Permissions for this role have been updated across the system.");
            } else {
                showErrorToast("Deploy Failed", data.message || "Unknown error occurred.");
            }
        })
        .catch(err => {
            console.error(err);
            alert("Connection error while deploying permissions.");
        })
        .finally(() => {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        });
    }

    function openCreateRoleModal() { alert("Create Role function triggered."); }

    // On Load
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('permission-form').classList.add('hidden');
    });
</script>

<style>
    .role-btn.active {
        box-shadow: 0 20px 25px -5px rgba(var(--brand-color-rgb), 0.2);
    }
    .role-btn.active span { color: white !important; }
</style>
