@{
    ViewData["Title"] = "Warehouse Manager";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<script src="https://cdn.tailwindcss.com"></script>

    <!-- Toasts -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            @TempData["Error"]
        </div>
    }

    <!-- ┌──────────────────────────────────────────────────────
         │  PAGE HEADER
         └────────────────────────────────────────────────────── -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">

            <!-- left: title block -->
            <div>
                <!-- FLOOR & ASSET COMMAND pill -->
                <span class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-widest
                             bg-yellow-400 text-yellow-900 px-3 py-1.5 rounded-full mb-3 shadow-sm dark:shadow-none">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                        <path d="M5.5 1L8 4H3L5.5 1z" fill="currentColor"/>
                        <rect x="2" y="4.5" width="7" height="4.5" rx="1" fill="currentColor" opacity="0.8"/>
                    </svg>
                    Floor &amp; Asset Command
                </span>

                <!-- main title -->
                <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-tight">
                    Warehouse
                    <span class="text-gv-brand">Command Center</span>
                </h1>

                <!-- subtitle -->
                <p class="text-sm text-slate-500 dark:text-slate-400 dark:text-slate-500 mt-1.5 font-medium max-w-xl leading-relaxed">
                    Monitor live floor operations, real-time asset valuation, and approve stock adjustments.
                </p>
            </div>

            <!-- right: action button -->
            <div class="shrink-0 mt-1">
                <a href="/Dashboard/StockAdjustments"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl
                               bg-gv-brand text-white text-sm font-bold
                               shadow-lg
                               hover:opacity-90 hover:-translate-y-0.5
                               transition-all duration-200
                               outline-none border-none no-underline">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                    </svg>
                    Manual Stock Adjustment
                </a>
            </div>
        </div>
        <!-- ┌──────────────────────────────────────────────────────
             │  KPI CARDS — 4 columns
             └────────────────────────────────────────────────────── -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">

            <!-- Card 1: Total Inventory Value -->
            <a href="/Dashboard/WarehouseStaff" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                        hover:scale-105 hover:shadow-xl transition-all duration-300 group">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gv-brand to-emerald-400 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div class="w-9 h-9 rounded-xl bg-gv-brand-light flex items-center justify-center shrink-0">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="12" fill="#23a476">₱</text>
                        </svg>
                    </div>
                    <div class="flex-1 text-right">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1">Inventory Value</p>
                        <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@(((decimal)ViewBag.InventoryValue).ToString("C0", new System.Globalization.CultureInfo("en-PH")))</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">View Assets →</p>
                    </div>
                </div>
                <div class="mt-3 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
                    <span class="w-1.5 h-1.5 rounded-full bg-gv-brand inline-block"></span>
                    <span class="text-[10px] font-bold text-gv-brand uppercase tracking-widest">Real-time valuation</span>
                </div>
            </a>

            <!-- Card 2: Low Stock Alerts (yellow) -->
            <a href="/Dashboard/PurchaseOrders" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                        hover:scale-105 hover:shadow-xl transition-all duration-300 group">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-yellow-400 to-amber-400 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div class="w-9 h-9 rounded-xl bg-yellow-50 flex items-center justify-center shrink-0">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <path d="M9 2.5L1.5 15h15L9 2.5z" stroke="#f59e0b" stroke-width="1.6" stroke-linejoin="round"/>
                            <path d="M9 8v4M9 13.5v.5" stroke="#f59e0b" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <div class="flex-1 text-right">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1">Critical Alerts</p>
                        <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@ViewBag.LowStockCount</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">View Alerts →</p>
                    </div>
                </div>
                <div class="mt-3 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 inline-block"></span>
                    <span class="text-[10px] font-bold text-yellow-600 uppercase tracking-widest text-right">Reorder Needed</span>
                </div>
            </a>

            <!-- Card 3: Pending Orders (blue) -->
            <a href="/Dashboard/PurchaseOrders" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                        hover:scale-105 hover:shadow-xl transition-all duration-300 group">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-400 to-sky-500 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <rect x="2" y="2" width="14" height="14" rx="2.5" stroke="#3b82f6" stroke-width="1.6"/>
                            <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#3b82f6" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <div class="flex-1 text-right">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1">Pending POs</p>
                        <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@ViewBag.PendingOrders</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">View Orders →</p>
                    </div>
                </div>
                <div class="mt-3 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
                    <span class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Awaiting Action</span>
                </div>
            </a>

            <!-- Card 4: Active Floor Staff (purple) - Static Info Card -->
            <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px] transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-violet-400 to-purple-500 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div class="w-9 h-9 rounded-xl bg-violet-50 flex items-center justify-center shrink-0">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <circle cx="7"  cy="6"  r="3"   stroke="#7c3aed" stroke-width="1.6"/>
                            <path d="M1 17c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="#7c3aed" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <div class="flex-1 text-right">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1">Floor Staff</p>
                        <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@ViewBag.ActiveStaffCount</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">Live Aggregate</p>
                    </div>
                </div>
                <div class="mt-3 flex items-center justify-end gap-1.5 opacity-60">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse inline-block"></span>
                    <span class="text-[10px] font-bold text-violet-600 uppercase tracking-widest">Active Routes</span>
                </div>
            </div>
        </div>

        <!-- ┌──────────────────────────────────────────────────────
             │  SPLIT LAYOUT — 50 / 50
             └────────────────────────────────────────────────────── -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- ╔══════════════════════════════════════════════════
                 ║  LEFT — LIVE PICK-PACK-SHIP OPERATIONS
                 ╚══════════════════════════════════════════════════ -->
            <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800
                            overflow-hidden flex flex-col"
                     aria-labelledby="ops-heading">

                <!-- card header -->
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                    <div class="flex items-center gap-3">
                        <div class="w-1 h-7 rounded-full bg-blue-500 shrink-0"></div>
                        <div>
                            <h2 id="ops-heading"
                                class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight">
                                Live Pick-Pack-Ship Operations
                            </h2>
                            <p class="text-xs text-slate-400 dark:text-slate-500 font-medium mt-0.5">Active floor tasks — real-time</p>
                        </div>
                    </div>
                    <!-- live pulse indicator -->
                    <span class="flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span>
                        Live Feed
                    </span>
                </div>

                <!-- table -->
                <div class="overflow-x-auto flex-1">
                    <table class="w-full text-sm" aria-label="Active floor operations">
                        <thead>
                            <tr class="bg-slate-50 dark:bg-black/30 border-b border-slate-200 dark:border-slate-800">
                                <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3 whitespace-nowrap">Task ID</th>
                                <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3 whitespace-nowrap">Customer</th>
                                <th class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3 whitespace-nowrap">Type</th>
                                <th class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3 whitespace-nowrap">Status</th>
                                <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3 whitespace-nowrap">Date</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @foreach (var order in (List<SalesOrder>)ViewBag.ActiveOperations)
                            {
                                <tr class="hover:bg-slate-50/70 dark:bg-slate-800/30 transition-colors duration-150 group">
                                    <td class="px-5 py-4">
                                        <span class="font-bold text-slate-900 dark:text-white text-xs group-hover:text-gv-brand transition-colors">#@order.SONumber</span>
                                    </td>
                                    <td class="px-5 py-4">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-7 h-7 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center shrink-0">
                                                <span class="text-xs font-extrabold text-indigo-600">@order.Customer?.CompanyName.Substring(0, 1)</span>
                                            </div>
                                            <div>
                                                <div class="font-semibold text-slate-800 dark:text-slate-200 text-xs">@order.Customer?.CompanyName</div>
                                                <div class="text-[10px] text-slate-400 dark:text-slate-500">Sales Order Ref</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-5 py-4 text-center">
                                        <span class="inline-block px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                                                     bg-slate-100 text-slate-600 border border-slate-200 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700">
                                            Standard
                                        </span>
                                    </td>
                                    <td class="px-5 py-4 text-center">
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                                                     @(order.Status == SOStatus.Picking ? "bg-blue-50 text-blue-600 border border-blue-100" : "bg-emerald-50 text-emerald-600 border border-emerald-100")">
                                            <span class="w-1 h-1 rounded-full @(order.Status == SOStatus.Picking ? "bg-blue-500 animate-pulse" : "bg-emerald-500") inline-block"></span>
                                            @order.Status.ToString()
                                        </span>
                                    </td>
                                    <td class="px-5 py-4">
                                        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-tight">@order.OrderDate.ToString("MMM dd, yyyy")</div>
                                    </td>
                                </tr>
                            }
                            @if (!((List<SalesOrder>)ViewBag.ActiveOperations).Any())
                            {
                                <tr>
                                    <td colspan="5" class="py-12 text-center text-slate-400 italic font-medium">No active fulfillment tasks found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- card footer -->
                <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50
                            flex items-center justify-between">
                    <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">Showing 5 most recent activities</span>
                    <a href="/Dashboard/StockAdjustments" class="text-xs font-bold text-gv-brand hover:text-gv-mid transition-colors">
                        View audit history →
                    </a>
                </div>
            </section>

            <!-- ╔══════════════════════════════════════════════════
                 ║  RIGHT — SYSTEM ACTIVITY FEED
                 ╚══════════════════════════════════════════════════ -->
            <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800
                            overflow-hidden flex flex-col"
                     aria-labelledby="adj-heading">

                <!-- card header -->
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                    <div class="flex items-center gap-3">
                        <div class="w-1 h-7 rounded-full bg-orange-500 shrink-0"></div>
                        <div>
                            <h2 id="adj-heading"
                                class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight">
                                System-Wide Activity Feed
                            </h2>
                            <p class="text-xs text-slate-400 dark:text-slate-500 font-medium mt-0.5">Live stock movements & arrivals</p>
                        </div>
                    </div>
                    <span class="text-xs font-bold text-orange-600 bg-orange-50 border border-orange-100 px-2.5 py-1 rounded-full">
                        Live Data
                    </span>
                </div>

                <!-- transactions feed -->
                <div class="flex-1 divide-y divide-slate-100 dark:divide-slate-800/60 overflow-y-auto">
                    @foreach (var t in (List<InventoryTransaction>)ViewBag.RecentActivity)
                    {
                        <div class="px-6 py-5 flex gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors duration-150">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5 
                                        @(t.Type == TransactionType.StockIn ? "bg-emerald-100 text-emerald-600" : "bg-red-100 text-red-600")">
                                @if (t.Type == TransactionType.StockIn) {
                                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                                } else {
                                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1 flex-wrap">
                                    <span class="text-xs font-extrabold uppercase tracking-wide px-2 py-0.5 rounded-full border
                                                 @(t.Type == TransactionType.StockIn ? "text-emerald-600 bg-emerald-50 border-emerald-100" : "text-red-600 bg-red-50 border-red-100")">
                                        @t.Type.ToString()
                                    </span>
                                    <span class="text-xs font-bold text-slate-400 dark:text-slate-500">@t.ReferenceId</span>
                                </div>
                                <p class="text-sm font-bold text-slate-900 dark:text-white leading-snug">
                                    @t.Product?.Name
                                </p>
                                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5">
                                    @t.Notes
                                    <span class="font-bold ml-1 @(t.Type == TransactionType.StockIn ? "text-emerald-600" : "text-red-600")">
                                        Qty: @(t.Type == TransactionType.StockIn ? "+" : "-")@t.Quantity
                                    </span>
                                </p>
                                <div class="flex items-center justify-between mt-2">
                                    <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">
                                        @t.Timestamp.ToLocalTime().ToString("MMM dd, hh:mm tt")
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!((List<InventoryTransaction>)ViewBag.RecentActivity).Any()) {
                        <div class="px-6 py-12 text-center text-slate-400 italic font-medium">No activity recorded yet.</div>
                    }
                </div>

                <!-- card footer -->
                <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50
                            flex items-center justify-between">
                    <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">Latest ledger updates</span>
                    <a href="/Dashboard/StockAdjustments" class="text-xs font-bold text-gv-brand hover:text-gv-mid transition-colors">
                        View all transactions →
                    </a>
                </div>
            </section>

        </div><!-- /split layout -->









