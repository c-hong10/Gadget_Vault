@{
    ViewData["Title"] = "Receive Stock (Inbound)";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6 h-full">

    <!-- Toasts -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">Receive Stock</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 transition-colors duration-300">Scan or manually enter inbound inventory drops.</p>
        </div>
    </div>

    <!-- TOUCH-FRIENDLY ACTION BAR (Warehouse Staff) -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-5 shadow-sm dark:shadow-none transition-colors duration-300">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-3">Quick Actions</p>
        <div class="flex flex-col sm:flex-row gap-3">
            <!-- Primary: Scan Incoming PO -->
            <button id="btn-scan-po"
                    class="flex-1 flex items-center justify-center gap-3 py-5 rounded-xl
                           bg-gv-brand text-white font-extrabold text-base
                           shadow-lg 
                           hover:bg-gv-brand active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h4v16H3V4zm6 0h2v16H9V4zm4 0h1v16h-1V4zm3 0h5v16h-5V4z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z" opacity="0"/>
                </svg>
                Scan Incoming PO
            </button>
        </div>
    </div>

    <!-- Layout Grid -->

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ════════ LEFT COLUMN: RECEIVING FORM ════════ -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            
            <!-- MANUAL LOGGING FORM -->
            <div id="manual-form-container" class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-[#1e1e24] p-6 flex flex-col gap-5 transition-colors duration-300">
                <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight border-b border-slate-200 dark:border-[#1e1e24] pb-3 transition-colors duration-300">
                    Log Manual Shipment
                </h2>

                <form asp-controller="Warehouse" asp-action="LogManualShipment" method="post" class="flex flex-col gap-4">
                    @Html.AntiForgeryToken()
                    
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Product (SKU)</label>
                        <select name="productId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#111113] border border-slate-300 dark:border-[#1e1e24] rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Choose Product --</option>
                            @foreach (var p in (List<Product>)ViewBag.Products) {
                                <option value="@p.Id">@p.Name (@p.SKU)</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Quantity</label>
                        <input type="number" name="quantity" min="1" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#111113] border border-slate-300 dark:border-[#1e1e24] rounded-xl text-sm text-slate-900 dark:text-white" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Storage Zone</label>
                        <select name="locationId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#111113] border border-slate-300 dark:border-[#1e1e24] rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Select Zone --</option>
                            @foreach (var loc in (List<WarehouseLocation>)ViewBag.Locations) {
                                <option value="@loc.Id">@loc.Zone - @loc.Aisle</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Supplier</label>
                        <select name="supplierId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#111113] border border-slate-300 dark:border-[#1e1e24] rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Select Supplier --</option>
                            @foreach (var s in (List<BusinessPartner>)ViewBag.Suppliers) {
                                <option value="@s.Id">@s.CompanyName</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="w-full py-3 bg-gv-brand text-white text-sm font-extrabold rounded-xl shadow-lg active:scale-95 transition-all border-none">
                        Log Shipment
                    </button>
                </form>
            </div>

            <div class="bg-slate-50 dark:bg-black/40 rounded-2xl border border-slate-200 dark:border-[#1e1e24] p-5">
                <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Or Receive via PO</h3>

                <div class="flex flex-col gap-3">
                    <select id="po-select" name="poId" onchange="onPoDropdownChange()"
                            class="w-full px-4 py-3 bg-white dark:bg-[#111113]/30 border border-slate-300 dark:border-[#1e1e24] rounded-xl text-sm font-semibold transition-all focus:border-gv-brand focus:ring-1 focus:ring-gv-brand outline-none">
                        <option value="">-- Select Shipped / Acknowledged PO --</option>
                        @foreach (var po in (List<PurchaseOrder>)ViewBag.AcknowledgedOrders) {
                            <option value="@po.Id" data-ponumber="@po.PONumber">@po.PONumber (@po.Supplier?.CompanyName)</option>
                        }
                    </select>
                    <p class="text-[10px] text-slate-400 italic px-1">Selecting a PO will open the detailed receiving station.</p>
                </div>

                <!-- Hidden banner for scanner feedback in sidebar -->
                <div id="scan-po-banner" class="hidden mt-3 flex items-start gap-2.5 px-4 py-3 rounded-xl border text-xs font-semibold">
                    <svg class="shrink-0 mt-0.5" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span id="scan-po-banner-text"></span>
                </div>
            </div>
        </div>

        <!-- ════════ RIGHT COLUMN: INBOUND LOGS ════════ -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-[#1e1e24] flex flex-col h-full overflow-hidden transition-colors duration-300">
                
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-[#1e1e24] transition-colors duration-300">
                    @{
                        var recentLogs = (List<InventoryTransaction>)ViewBag.RecentTransactions;
                        var todayCount = recentLogs.Sum(t => t.Quantity);
                    }
                    <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Recent Inbound Logs
                    </h2>
                    <span class="px-2.5 py-1 rounded-full bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 text-xs font-bold text-gv-brand dark:text-gv-brand-light transition-colors duration-300">
                        Today: @todayCount Items
                    </span>
                </div>

                <div class="overflow-x-auto flex-1">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-50/80 dark:bg-[#111113]/50 border-b border-slate-100 dark:border-[#1e1e24] transition-colors duration-300">
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Timestamp</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">SKU</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Product Name</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Qty</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Zone</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Received By</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-[#1e1e24] transition-colors duration-300" id="inbound-tbody">
                            @foreach (var t in (List<InventoryTransaction>)ViewBag.RecentTransactions)
                            {
                                <tr class="inbound-row hover:bg-slate-50/60 dark:hover:bg-[#1e1e24]/30 transition-colors duration-150">
                                    <td class="px-6 py-4 font-mono text-xs text-slate-500 dark:text-slate-400 transition-colors duration-300">@t.Timestamp.ToLocalTime().ToString("hh:mm tt")</td>
                                    <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-700 dark:text-slate-300 transition-colors duration-300">@t.Product?.SKU</td>
                                    <td class="px-6 py-4 font-semibold text-slate-900 dark:text-slate-200 transition-colors duration-300">@t.Product?.Name</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="inline-flex items-center justify-end gap-1.5">
                                            <span class="font-black text-slate-900 dark:text-white transition-colors duration-300">@t.Quantity</span>
                                            <span class="flex items-center justify-center w-4 h-4 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-[10px] font-bold text-gv-brand-dark dark:text-gv-brand-light transition-colors duration-300">+</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600 dark:text-slate-400 text-xs font-bold transition-colors duration-300">@t.Location?.Zone</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-block px-2.5 py-1 text-xs font-semibold rounded-md bg-slate-100 dark:bg-[#1e1e24] text-slate-700 dark:text-slate-300 transition-colors duration-300">@t.ReferenceId</span>
                                    </td>
                                </tr>
                            }
                            @if (!((List<InventoryTransaction>)ViewBag.RecentTransactions).Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 italic">No inbound transactions logged today.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Table Footer / Pagination -->
                <div class="px-6 py-4 border-t border-slate-200 dark:border-[#1e1e24] bg-slate-50/50 dark:bg-[#111113]/30 flex items-center justify-between">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest" id="pagination-info">
                        Showing 1-10 of @recentLogs.Count() logs
                    </p>
                    <div class="flex items-center gap-2">
                        <button onclick="changePage(-1)" id="btn-prev" class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white disabled:opacity-50 transition-all">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
                        </button>
                        <div id="page-numbers" class="flex items-center gap-1">
                            <!-- Page numbers injected here -->
                        </div>
                        <button onclick="changePage(1)" id="btn-next" class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white disabled:opacity-50 transition-all">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- SCANNER MODAL -->
<div id="scanner-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-[#0c0c0e]/80 backdrop-blur-md transition-all duration-300">
    <div class="relative w-full max-w-lg bg-[#0c0c0e] border border-slate-800 dark:border-[#1e1e24] rounded-3xl shadow-2xl overflow-hidden flex flex-col mx-4">
        
        <!-- Header -->
        <div class="p-6 border-b border-slate-800 dark:border-[#1e1e24] flex items-center justify-between">
            <div>
                <h3 class="text-xl font-extrabold text-white tracking-tight">QR Code Scanner</h3>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mt-1">Ready for capture</p>
            </div>
            <button onclick="stopScanner()" class="p-2 rounded-xl bg-slate-800 dark:bg-[#1e1e24] dark:bg-[#1e1e24] text-slate-400 hover:text-white transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <!-- Scanner Viewport -->
        <div class="relative aspect-square bg-black overflow-hidden flex items-center justify-center">
            <div id="reader" class="w-full h-full"></div>
            
            <!-- Scanning Square Overlay -->
            <div id="scanner-overlay" class="absolute inset-0 pointer-events-none flex items-center justify-center">
                <div class="w-2/3 h-2/3 border-2 border-gv-brand/50 rounded-3xl relative">
                    <!-- Corners -->
                    <div class="absolute -top-1 -left-1 w-6 h-6 border-t-4 border-l-4 border-gv-brand rounded-tl-xl"></div>
                    <div class="absolute -top-1 -right-1 w-6 h-6 border-t-4 border-r-4 border-gv-brand rounded-tr-xl"></div>
                    <div class="absolute -bottom-1 -left-1 w-6 h-6 border-b-4 border-l-4 border-gv-brand rounded-bl-xl"></div>
                    <div class="absolute -bottom-1 -right-1 w-6 h-6 border-b-4 border-r-4 border-gv-brand rounded-br-xl"></div>
                    
                    <!-- Animated Laser Line -->
                    <div class="absolute inset-x-4 top-1/2 h-[2px] bg-gv-brand shadow-[0_0_15px_rgba(var(--brand-color-rgb),0.8)] animate-[scan_2s_infinite_ease-in-out]"></div>
                </div>
            </div>

            <!-- Success Flash Overlay -->
            <div id="success-flash" class="absolute inset-0 bg-emerald-500/0 pointer-events-none transition-all duration-300"></div>
        </div>

        <!-- Controls -->
        <div class="p-6 bg-[#0c0c0e] border-t border-slate-800 dark:border-[#1e1e24] flex items-center justify-between">
            <button id="btn-torch" onclick="toggleTorch()" class="flex items-center gap-3 px-5 py-3 rounded-2xl bg-slate-800 dark:bg-[#1e1e24] dark:bg-[#1e1e24] text-slate-300 font-bold text-sm dark:hover:bg-[#1e1e24] transition-all">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Torch Off
            </button>
            <p class="text-[10px] text-slate-500 font-medium italic">Align barcode inside the frame</p>
        </div>
    </div>
</div>

<!-- UNIFIED "ONE-STOP" RECEIVING MODAL -->
<div id="modal-po-verify" class="hidden fixed inset-0 z-[110] flex items-center justify-center bg-black/80 backdrop-blur-md transition-all duration-300">
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-[2rem] shadow-2xl w-full max-w-2xl mx-4 overflow-hidden transform transition-all flex flex-col max-h-[90vh]">
        
        <!-- Header -->
        <div class="p-8 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between bg-slate-50/50 dark:bg-black/20">
            <div>
                <h3 id="verify-po-number" class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">PO-XXXX-XXX</h3>
                <p id="verify-po-supplier" class="text-sm font-bold text-gv-brand uppercase tracking-widest mt-1">Supplier Name</p>
            </div>
            <div class="w-12 h-12 rounded-2xl bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto p-8 flex flex-col gap-8">
            
            <!-- Items Section -->
            <div>
                <div class="flex items-center justify-between mb-4 px-1">
                    <h4 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Line Items to Verify</h4>
                    <span id="verify-po-items-count" class="px-2 py-0.5 rounded-full bg-slate-100 dark:bg-[#1e1e24] text-[10px] font-bold text-slate-500">0 Items</span>
                </div>
                
                <div class="border border-slate-100 dark:border-[#1e1e24] rounded-2xl overflow-hidden bg-white dark:bg-black/10">
                    <table class="w-full text-left text-xs">
                        <thead>
                            <tr class="bg-slate-50/50 dark:bg-[#1e1e24]/50 border-b border-slate-100 dark:border-[#1e1e24]">
                                <th class="px-5 py-3 font-bold text-slate-400">Product</th>
                                <th class="px-5 py-3 font-bold text-slate-400">SKU</th>
                                <th class="px-5 py-3 font-bold text-slate-400 text-right">Qty</th>
                            </tr>
                        </thead>
                        <tbody id="verify-po-items-list" class="divide-y divide-slate-50 dark:divide-[#1e1e24]">
                            <!-- Items injected here -->
                        </tbody>
                    </table>
                    <div id="verify-loading" class="hidden p-8 flex flex-col items-center gap-3 text-slate-400">
                        <div class="w-6 h-6 border-2 border-slate-300 border-t-gv-brand rounded-full animate-spin"></div>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Fetching Order Contents...</span>
                    </div>
                </div>
            </div>

            <!-- Destination Section -->
            <div class="bg-slate-50 dark:bg-black/40 border border-slate-100 dark:border-[#1e1e24] rounded-3xl p-6 flex flex-col gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 flex items-center justify-center text-xs font-black">!</div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-900 dark:text-white">Destination Location</h4>
                        <p class="text-[10px] text-slate-500 dark:text-slate-400">Choose where these items will be staged/stored.</p>
                    </div>
                </div>

                <select id="verify-location-id" class="w-full px-4 py-3.5 bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl text-sm font-semibold shadow-sm outline-none focus:ring-2 focus:ring-gv-brand/20 focus:border-gv-brand transition-all">
                    <option value="">-- Select Warehouse Zone --</option>
                    @foreach (var loc in (List<WarehouseLocation>)ViewBag.Locations) {
                        <option value="@loc.Id">@loc.Zone - @loc.Aisle (@loc.Rack)</option>
                    }
                </select>
            </div>

        </div>

        <!-- Footer -->
        <div class="p-8 border-t border-slate-100 dark:border-[#1e1e24] flex gap-4 bg-slate-50/50 dark:bg-black/20">
            <button onclick="closePoVerify()" class="flex-1 py-4 text-slate-500 dark:text-slate-400 font-bold text-sm hover:text-slate-800 dark:hover:text-white transition-all bg-transparent border-none">
                Cancel
            </button>
            <button onclick="confirmAndReceivePO()" id="btn-confirm-receive" class="flex-[2] py-4 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-black text-sm rounded-2xl shadow-xl shadow-slate-900/10 dark:shadow-none hover:scale-[1.02] active:scale-[0.98] transition-all border-none">
                Confirm & Receive Stock
            </button>
        </div>
    </div>
</div>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
    let html5QrCode;
    let isTorchOn   = false;
    let currentPage = 1;
    const pageSize  = 10;

    document.addEventListener('DOMContentLoaded', function () {
        const btnScan = document.getElementById('btn-scan-po');
        if (btnScan) btnScan.addEventListener('click', startScanner);

        const productSelect = document.querySelector('select[name="productId"]');
        if (productSelect) productSelect.focus();

        renderTable();
    });

    /* ── Pagination ─────────────────────────────────────────────── */
    function renderTable() {
        const rows  = Array.from(document.querySelectorAll('.inbound-row'));
        rows.forEach(r => r.classList.add('hidden'));
        const start = (currentPage - 1) * pageSize;
        const end   = start + pageSize;
        rows.slice(start, end).forEach(r => r.classList.remove('hidden'));
        const total  = rows.length;
        const infoEl = document.getElementById('pagination-info');
        if (infoEl) infoEl.innerText = `Showing ${total === 0 ? 0 : start + 1}-${Math.min(end, total)} of ${total} logs`;
        const btnPrev = document.getElementById('btn-prev');
        const btnNext = document.getElementById('btn-next');
        if (btnPrev) btnPrev.disabled = currentPage === 1;
        if (btnNext) btnNext.disabled = end >= total;
        const totalPages    = Math.ceil(total / pageSize);
        const pageContainer = document.getElementById('page-numbers');
        if (pageContainer) {
            pageContainer.innerHTML = '';
            for (let i = 1; i <= totalPages; i++) {
                const btn   = document.createElement('button');
                btn.innerText = i;
                btn.className = `w-8 h-8 rounded-lg text-xs font-bold transition-all ${i === currentPage ? 'bg-gv-brand text-white' : 'text-slate-400 hover:bg-slate-100 dark:hover:bg-[#1e1e24]'}`;
                btn.onclick = () => { currentPage = i; renderTable(); };
                pageContainer.appendChild(btn);
            }
        }
    }
    function changePage(dir) { currentPage += dir; renderTable(); }

    /* ══════════════════════════════════════════════════════════════
       SCANNER ENGINE  — PO-ONLY MODE
    ══════════════════════════════════════════════════════════════ */
    let isProcessingScan = false; // Global soft-lock — prevents duplicate frames & deadlocks

    async function startScanner() {
        isProcessingScan = false; // Always reset lock when (re)opening scanner
        document.getElementById('scanner-modal').classList.remove('hidden');
        html5QrCode = new Html5Qrcode("reader");

        // Square qrbox matches QR code geometry; QR_CODE only — no glare-prone 1D formats
        const config = {
            fps: 15,
            qrbox: { width: 280, height: 280 },
            formatsToSupport: [
                Html5QrcodeSupportedFormats.QR_CODE
            ]
        };

        try {
            await html5QrCode.start({ facingMode: "environment" }, config, onScanSuccess);
        } catch (err) {
            console.error("Scanner start failed:", err);
            alert("Camera access denied or not available. Please allow camera permissions and try again.");
            isProcessingScan = false;
            document.getElementById('scanner-modal').classList.add('hidden');
        }
    }

    function stopScannerUI() {
        // Hide the modal immediately — synchronous, no camera interaction
        document.getElementById('scanner-modal').classList.add('hidden');
        isTorchOn = false;
    }

    function stopScannerHardware() {
        // Fire-and-forget camera stop — never await this inside onScanSuccess
        if (html5QrCode && html5QrCode.isScanning) {
            html5QrCode.stop().catch(err => console.warn("Camera stop (bg):", err));
        }
    }

    async function stopScanner() {
        // Full stop used by the X button — can safely await here
        stopScannerUI();
        if (html5QrCode && html5QrCode.isScanning) {
            try { await html5QrCode.stop(); } catch(e) { /* already stopped */ }
        }
        isProcessingScan = false;
    }

    async function toggleTorch() {
        if (!html5QrCode || !html5QrCode.isScanning) return;
        try {
            isTorchOn = !isTorchOn;
            await html5QrCode.applyVideoConstraints({ advanced: [{ torch: isTorchOn }] });
            const btn = document.getElementById('btn-torch');
            if (btn) btn.innerText = isTorchOn ? 'Torch On' : 'Torch Off';
        } catch (err) { console.error("Torch not supported:", err); }
    }

    /* ══════════════════════════════════════════════════════════════
       SCAN SUCCESS — SOFT-LOCK PATTERN (UI first, hardware later)
       Fixes the async deadlock: never await camera stop inside this
       callback, or the Promise chain freezes and no modal fires.
    ══════════════════════════════════════════════════════════════ */
    function onScanSuccess(decodedText, decodedResult) {
        // 1. Lock Guard: Instantly block duplicate frames to prevent race conditions
        if (isProcessingScan) return;

        const cleanCode = decodedText.trim().toUpperCase();
        console.log("SUCCESSFUL DECODE:", cleanCode); 

        if (cleanCode.startsWith("PO-")) {
            isProcessingScan = true; // Lock logically

            // 2. Feedback (Sync)
            if (navigator.vibrate) navigator.vibrate(100);
            
            // 3. PRIORITIZE UI: Hide scanner and trigger modal IMMEDIATELY
            // This happens before we even touch the camera hardware stop logic
            stopScannerUI();
            handlePOScan(cleanCode);

            // 4. SOFT-STOP CAMERA: Attempt to stop in background, ignoring all errors
            // We do not await this, so a hardware deadlock won't freeze the UI
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop()
                    .then(() => console.log("Camera stopped successfully."))
                    .catch(err => console.warn("Camera stop ignored/deadlocked:", err));
            }

        } else {
            // Invalid barcode handling with 2s cooldown
            isProcessingScan = true;
            showBanner('error', `❌ Invalid Barcode: "${decodedText.trim()}". Please scan a valid Purchase Order QR code.`);
            setTimeout(() => { isProcessingScan = false; }, 2000);
        }
    }

    function handlePOScan(scannedUpper) {
        const poSelect = document.getElementById('po-select');
        let matchedOpt = null;

        for (let i = 0; i < poSelect.options.length; i++) {
            const attr = (poSelect.options[i].getAttribute('data-ponumber') || '').toUpperCase().trim();
            if (attr === scannedUpper) { matchedOpt = poSelect.options[i]; break; }
        }

        if (matchedOpt) {
            openPoVerifyModal(matchedOpt);
        } else {
            showBanner('error',
                `Error: PO "${scannedUpper}" is not in a Shipped/Acknowledged status or does not exist.`
            );
        }
    }

    /* ══════════════════════════════════════════════════════════════
       UNIFIED RECEIVING MODAL LOGIC
    ══════════════════════════════════════════════════════════════ */
    let _activePoId  = null;
    let _activePoNum = null;

    async function openPoVerifyModal(opt) {
        _activePoId  = opt.value;
        _activePoNum = opt.getAttribute('data-ponumber');

        const rawText  = opt.innerText || '';
        const supplier = rawText.includes('(')
            ? rawText.split('(').pop().replace(')', '').trim()
            : 'Unknown Supplier';

        // Reset & Open Modal
        document.getElementById('verify-po-number').innerText   = _activePoNum;
        document.getElementById('verify-po-supplier').innerText = supplier;
        document.getElementById('verify-po-items-list').innerHTML = '';
        document.getElementById('verify-po-items-count').innerText = '0 Items';
        document.getElementById('verify-location-id').value = '';
        
        document.getElementById('modal-po-verify').classList.remove('hidden');
        document.getElementById('verify-loading').classList.remove('hidden');

        try {
            const res  = await fetch(`/Dashboard/GetPOItems/${_activePoId}`);
            const data = await res.json();
            
            document.getElementById('verify-loading').classList.add('hidden');
            document.getElementById('verify-po-items-count').innerText = `${data.length} line item${data.length !== 1 ? 's' : ''}`;

            const listBody = document.getElementById('verify-po-items-list');
            data.forEach(item => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="px-5 py-3 font-semibold text-slate-800 dark:text-slate-200">${item.name}</td>
                    <td class="px-5 py-3 font-mono text-[10px] text-slate-500">${item.sku}</td>
                    <td class="px-5 py-3 font-black text-slate-900 dark:text-white text-right">x${item.quantity}</td>
                `;
                listBody.appendChild(tr);
            });
        } catch(err) {
            console.error("Failed to fetch PO items:", err);
            document.getElementById('verify-loading').innerHTML = '<span class="text-red-500 font-bold p-4 block text-center">Failed to load order items.</span>';
        }
    }

    function closePoVerify() {
        document.getElementById('modal-po-verify').classList.add('hidden');
        _activePoId  = null;
        _activePoNum = null;
        // Reset manual dropdown
        document.getElementById('po-select').value = '';
    }

    async function confirmAndReceivePO() {
        const locationId = document.getElementById('verify-location-id').value;
        if (!locationId) {
            alert("Please select a destination location for these items.");
            return;
        }

        const btn = document.getElementById('btn-confirm-receive');
        const originalText = btn.innerText;
        btn.innerText = "Processing Receipt...";
        btn.disabled = true;

        const formData = new FormData();
        formData.append("poId", _activePoId);
        formData.append("locationId", locationId);
        formData.append("__RequestVerificationToken", document.querySelector('input[name="__RequestVerificationToken"]').value);

        try {
            const res = await fetch('/Dashboard/ReceivePOJson', {
                method: 'POST',
                body: formData
            });
            const result = await res.json();

            if (result.success) {
                // Success!
                closePoVerify();
                showBanner('success', result.message);
                
                // Refresh logs table or reload page
                setTimeout(() => window.location.reload(), 1500);
            } else {
                alert("Error: " + result.message);
                btn.innerText = originalText;
                btn.disabled = false;
            }
        } catch (err) {
            console.error("AJAX Error during receipt:", err);
            alert("Connection error. Inventory may not have been updated.");
            btn.innerText = originalText;
            btn.disabled = false;
        }
    }

    function onPoDropdownChange() {
        const poSelect = document.getElementById('po-select');
        const opt = poSelect.options[poSelect.selectedIndex];
        if (opt && opt.value) {
            openPoVerifyModal(opt);
        }
    }

    /* ══════════════════════════════════════════════════════════════
       BANNER HELPER
    ══════════════════════════════════════════════════════════════ */
    let _bannerTimer = null;
    function showBanner(type, message) {
        const banner     = document.getElementById('scan-po-banner');
        const bannerText = document.getElementById('scan-po-banner-text');
        if (!banner || !bannerText) return;

        const base   = 'flex items-start gap-2.5 px-4 py-3 rounded-xl border text-xs font-semibold mt-3';
        const themes = {
            success: 'bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/20 text-emerald-700 dark:text-emerald-400',
            warn:    'bg-amber-50 dark:bg-amber-500/10 border-amber-200 dark:border-amber-500/20 text-amber-700 dark:text-amber-400',
            error:   'bg-red-50 dark:bg-red-500/10 border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400',
        };

        banner.className     = `${base} ${themes[type] || themes.warn}`;
        bannerText.innerText = message;
        banner.classList.remove('hidden');

        if (_bannerTimer) clearTimeout(_bannerTimer);
        _bannerTimer = setTimeout(() => banner.classList.add('hidden'), 8000);
    }
</script>
<style>
@@keyframes scan {
    0%, 100% { transform: translateY(-100px); opacity: 0; }
    50% { transform: translateY(100px); opacity: 1; }
}
</style>






