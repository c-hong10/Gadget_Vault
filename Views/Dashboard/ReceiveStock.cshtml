@{
    ViewData["Title"] = "Receive Stock (Inbound)";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6 h-full">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">Receive Stock</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 transition-colors duration-300">Scan or manually enter inbound inventory drops.</p>
        </div>
    </div>

    <!-- TOUCH-FRIENDLY ACTION BAR (Warehouse Staff) -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm dark:shadow-none transition-colors duration-300">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-3">Quick Actions</p>
        <div class="flex flex-col sm:flex-row gap-3">
            <!-- Primary: Scan Incoming PO -->
            <button id="btn-scan-po"
                    class="flex-1 flex items-center justify-center gap-3 py-5 rounded-xl
                           bg-gv-brand text-white font-extrabold text-base
                           shadow-lg 
                           hover:bg-gv-brand active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h4v16H3V4zm6 0h2v16H9V4zm4 0h1v16h-1V4zm3 0h5v16h-5V4z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z" opacity="0"/>
                </svg>
                Scan Incoming PO
            </button>
            <!-- Secondary: Manual Entry -->
            <button id="btn-manual-entry"
                    class="flex-1 flex items-center justify-center gap-3 py-5 rounded-xl
                           bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-extrabold text-base
                           hover:bg-slate-200 dark:hover:bg-slate-700 active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Manual Entry
            </button>
            <!-- Tertiary: Print GRN -->
            <button id="btn-print-grn"
                    class="sm:w-auto flex items-center justify-center gap-2 px-6 py-5 rounded-xl
                           bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 font-bold text-sm
                           hover:bg-slate-200 dark:hover:bg-slate-700 active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
                Print GRN
            </button>
        </div>
    </div>

    <!-- Layout Grid -->

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ════════ LEFT COLUMN: RECEIVING FORM ════════ -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 p-6 flex flex-col gap-5 transition-colors duration-300">
                
                <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight border-b border-slate-200 dark:border-slate-800 pb-3 transition-colors duration-300">
                    Shipment Details
                </h2>

                <div class="flex flex-col gap-4">
                    <!-- SKU Input -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white transition-colors duration-300">SKU / Barcode</label>
                        <div class="relative">
                            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none transition-colors duration-300"
                                 width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h4v16H3V4zm6 0h2v16H9V4zm4 0h1v16h-1V4zm3 0h5v16h-5V4z"/>
                            </svg>
                            <input type="text" placeholder="Scan or type..."
                                   class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all duration-300" />
                        </div>
                    </div>

                    <!-- Quantity Input -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white transition-colors duration-300">Quantity</label>
                        <input type="number" min="1" placeholder="0"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all duration-300" />
                    </div>

                    <!-- Destination Zone -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white transition-colors duration-300">Destination Zone</label>
                        <select class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all duration-300 cursor-pointer">
                            <option value="">Select Zone</option>
                            <option value="ZA" selected>Zone A - High Value</option>
                            <option value="ZB">Zone B - Bulk Storage</option>
                            <option value="ZC">Zone C - Outbound Buffer</option>
                        </select>
                    </div>

                    <!-- Supplier -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white transition-colors duration-300">Supplier</label>
                        <select class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all duration-300 cursor-pointer">
                            <option value="">Select Supplier</option>
                            <option value="apple" selected>Apple Inc</option>
                            <option value="sony">Sony</option>
                            <option value="samsung">Samsung</option>
                        </select>
                    </div>

                    <!-- Submit Button -->
                    <button class="w-full py-3 mt-2 bg-gv-brand hover:bg-gv-brand text-white text-sm font-extrabold rounded-xl shadow-lg  active:scale-[0.98] transition-all">
                        Log Shipment
                    </button>
                </div>
            </div>
        </div>

        <!-- ════════ RIGHT COLUMN: INBOUND LOGS ════════ -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 flex flex-col h-full overflow-hidden transition-colors duration-300">
                
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                    <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Recent Inbound Logs
                    </h2>
                    <span class="px-2.5 py-1 rounded-full bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 text-xs font-bold text-gv-brand dark:text-gv-brand-light transition-colors duration-300">
                        Today: 154 Items
                    </span>
                </div>

                <div class="overflow-x-auto flex-1">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800 transition-colors duration-300">
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Timestamp</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">SKU</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Product Name</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Qty</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Zone</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Received By</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800 transition-colors duration-300">
                            
                            <!-- Log Row 1 -->
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                <td class="px-6 py-4 font-mono text-xs text-slate-500 dark:text-slate-400 transition-colors duration-300">10:45 AM</td>
                                <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-700 dark:text-slate-300 transition-colors duration-300">SKU-APL-IP15P</td>
                                <td class="px-6 py-4 font-semibold text-slate-900 dark:text-slate-200 transition-colors duration-300">iPhone 15 Pro</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center justify-end gap-1.5">
                                        <span class="font-black text-slate-900 dark:text-white transition-colors duration-300">50</span>
                                        <span class="flex items-center justify-center w-4 h-4 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-[10px] font-bold text-gv-brand-dark dark:text-gv-brand-light transition-colors duration-300">+</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-slate-600 dark:text-slate-400 text-xs font-bold transition-colors duration-300">Zone A</td>
                                <td class="px-6 py-4">
                                    <span class="inline-block px-2.5 py-1 text-xs font-semibold rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors duration-300">Alex Ray</span>
                                </td>
                            </tr>

                            <!-- Log Row 2 -->
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                <td class="px-6 py-4 font-mono text-xs text-slate-500 dark:text-slate-400 transition-colors duration-300">10:12 AM</td>
                                <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-700 dark:text-slate-300 transition-colors duration-300">SKU-SNY-WHXM5</td>
                                <td class="px-6 py-4 font-semibold text-slate-900 dark:text-slate-200 transition-colors duration-300">Sony WH-1000XM5</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center justify-end gap-1.5">
                                        <span class="font-black text-slate-900 dark:text-white transition-colors duration-300">24</span>
                                        <span class="flex items-center justify-center w-4 h-4 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-[10px] font-bold text-gv-brand-dark dark:text-gv-brand-light transition-colors duration-300">+</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-slate-600 dark:text-slate-400 text-xs font-bold transition-colors duration-300">Zone B</td>
                                <td class="px-6 py-4">
                                    <span class="inline-block px-2.5 py-1 text-xs font-semibold rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors duration-300">Mike K.</span>
                                </td>
                            </tr>

                            <!-- Log Row 3 -->
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                <td class="px-6 py-4 font-mono text-xs text-slate-500 dark:text-slate-400 transition-colors duration-300">09:05 AM</td>
                                <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-700 dark:text-slate-300 transition-colors duration-300">SKU-SAM-S24U</td>
                                <td class="px-6 py-4 font-semibold text-slate-900 dark:text-slate-200 transition-colors duration-300">Galaxy S24 Ultra</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center justify-end gap-1.5">
                                        <span class="font-black text-slate-900 dark:text-white transition-colors duration-300">80</span>
                                        <span class="flex items-center justify-center w-4 h-4 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-[10px] font-bold text-gv-brand-dark dark:text-gv-brand-light transition-colors duration-300">+</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-slate-600 dark:text-slate-400 text-xs font-bold transition-colors duration-300">Zone A</td>
                                <td class="px-6 py-4">
                                    <span class="inline-block px-2.5 py-1 text-xs font-semibold rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors duration-300">Alex Ray</span>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>






