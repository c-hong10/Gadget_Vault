@{
    ViewData["Title"] = "Receive Stock (Inbound)";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6 h-full">

    <!-- Toasts -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">Receive Stock</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 transition-colors duration-300">Scan or manually enter inbound inventory drops.</p>
        </div>
    </div>

    <!-- TOUCH-FRIENDLY ACTION BAR (Warehouse Staff) -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm dark:shadow-none transition-colors duration-300">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-3">Quick Actions</p>
        <div class="flex flex-col sm:flex-row gap-3">
            <!-- Primary: Scan Incoming PO -->
            <button id="btn-scan-po"
                    class="flex-1 flex items-center justify-center gap-3 py-5 rounded-xl
                           bg-gv-brand text-white font-extrabold text-base
                           shadow-lg 
                           hover:bg-gv-brand active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h4v16H3V4zm6 0h2v16H9V4zm4 0h1v16h-1V4zm3 0h5v16h-5V4z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z" opacity="0"/>
                </svg>
                Scan Incoming PO
            </button>
            <!-- Secondary: Manual Entry -->
            <button id="btn-manual-entry"
                    class="flex-1 flex items-center justify-center gap-3 py-5 rounded-xl
                           bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-extrabold text-base
                           hover:bg-slate-200 dark:hover:bg-slate-700 active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Manual Entry
            </button>
            <!-- Tertiary: Print GRN -->
            <button id="btn-print-grn"
                    class="sm:w-auto flex items-center justify-center gap-2 px-6 py-5 rounded-xl
                           bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 font-bold text-sm
                           hover:bg-slate-200 dark:hover:bg-slate-700 active:scale-[0.98]
                           transition-all duration-200 outline-none border-none">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
                Print GRN
            </button>
        </div>
    </div>

    <!-- Layout Grid -->

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ════════ LEFT COLUMN: RECEIVING FORM ════════ -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            
            <!-- MANUAL LOGGING FORM -->
            <div id="manual-form-container" class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 p-6 flex flex-col gap-5 transition-colors duration-300">
                <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight border-b border-slate-200 dark:border-slate-800 pb-3 transition-colors duration-300">
                    Log Manual Shipment
                </h2>

                <form asp-controller="Warehouse" asp-action="LogManualShipment" method="post" class="flex flex-col gap-4">
                    @Html.AntiForgeryToken()
                    
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Product (SKU)</label>
                        <select name="productId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Choose Product --</option>
                            @foreach (var p in (List<Product>)ViewBag.Products) {
                                <option value="@p.Id">@p.Name (@p.SKU)</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Quantity</label>
                        <input type="number" name="quantity" min="1" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Storage Zone</label>
                        <select name="locationId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Select Zone --</option>
                            @foreach (var loc in (List<WarehouseLocation>)ViewBag.Locations) {
                                <option value="@loc.Id">@loc.Zone - @loc.Aisle</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-900 dark:text-white">Supplier</label>
                        <select name="supplierId" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-sm text-slate-900 dark:text-white focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)]">
                            <option value="">-- Select Supplier --</option>
                            @foreach (var s in (List<BusinessPartner>)ViewBag.Suppliers) {
                                <option value="@s.Id">@s.CompanyName</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="w-full py-3 bg-gv-brand text-white text-sm font-extrabold rounded-xl shadow-lg active:scale-95 transition-all border-none">
                        Log Shipment
                    </button>
                </form>
            </div>

            <!-- PO RECEIVING SECTION (Minimized) -->
            <div class="bg-slate-50 dark:bg-slate-900/40 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
                <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Or Receive via PO</h3>
                <form asp-controller="Warehouse" asp-action="ConfirmReceipt" method="post" class="flex flex-col gap-3">
                    @Html.AntiForgeryToken()
                    <select name="poId" required class="w-full px-4 py-2 bg-white dark:bg-black/30 border border-slate-300 dark:border-slate-700 rounded-lg text-xs">
                        <option value="">-- Select Acknowledged PO --</option>
                        @foreach (var po in (List<PurchaseOrder>)ViewBag.AcknowledgedOrders) {
                            <option value="@po.Id">@po.PONumber (@po.Supplier?.CompanyName)</option>
                        }
                    </select>
                    <select name="locationId" required class="w-full px-4 py-2 bg-white dark:bg-black/30 border border-slate-300 dark:border-slate-700 rounded-lg text-xs">
                        <option value="">-- Select Destination Location --</option>
                        @foreach (var loc in (List<WarehouseLocation>)ViewBag.Locations) {
                            <option value="@loc.Id">@loc.Zone - @loc.Aisle</option>
                        }
                    </select>
                    <button type="submit" class="w-full py-2 bg-slate-800 text-white text-xs font-bold rounded-lg hover:bg-black">Receive PO</button>
                </form>
            </div>
        </div>

        <!-- ════════ RIGHT COLUMN: INBOUND LOGS ════════ -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 flex flex-col h-full overflow-hidden transition-colors duration-300">
                
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                    <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Recent Inbound Logs
                    </h2>
                    <span class="px-2.5 py-1 rounded-full bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 text-xs font-bold text-gv-brand dark:text-gv-brand-light transition-colors duration-300">
                        Today: 154 Items
                    </span>
                </div>

                <div class="overflow-x-auto flex-1">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800 transition-colors duration-300">
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Timestamp</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">SKU</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Product Name</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Qty</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Zone</th>
                                <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Received By</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800 transition-colors duration-300">
                            @foreach (var t in (List<InventoryTransaction>)ViewBag.RecentTransactions)
                            {
                                <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                    <td class="px-6 py-4 font-mono text-xs text-slate-500 dark:text-slate-400 transition-colors duration-300">@t.Timestamp.ToLocalTime().ToString("hh:mm tt")</td>
                                    <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-700 dark:text-slate-300 transition-colors duration-300">@t.Product?.SKU</td>
                                    <td class="px-6 py-4 font-semibold text-slate-900 dark:text-slate-200 transition-colors duration-300">@t.Product?.Name</td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="inline-flex items-center justify-end gap-1.5">
                                            <span class="font-black text-slate-900 dark:text-white transition-colors duration-300">@t.Quantity</span>
                                            <span class="flex items-center justify-center w-4 h-4 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-[10px] font-bold text-gv-brand-dark dark:text-gv-brand-light transition-colors duration-300">+</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600 dark:text-slate-400 text-xs font-bold transition-colors duration-300">@t.Location?.Zone</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-block px-2.5 py-1 text-xs font-semibold rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors duration-300">@t.ReferenceId</span>
                                    </td>
                                </tr>
                            }
                            @if (!((List<InventoryTransaction>)ViewBag.RecentTransactions).Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 italic">No inbound transactions logged today.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- SCANNER MODAL -->
<div id="scanner-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-md transition-all duration-300">
    <div class="relative w-full max-w-lg bg-[#111113] border border-slate-800 rounded-3xl shadow-2xl overflow-hidden flex flex-col mx-4">
        
        <!-- Header -->
        <div class="p-6 border-b border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-xl font-extrabold text-white tracking-tight">Barcode Scanner</h3>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mt-1">Ready for capture</p>
            </div>
            <button onclick="stopScanner()" class="p-2 rounded-xl bg-slate-800 text-slate-400 hover:text-white transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <!-- Scanner Viewport -->
        <div class="relative aspect-square bg-black overflow-hidden flex items-center justify-center">
            <div id="reader" class="w-full h-full"></div>
            
            <!-- Scanning Square Overlay -->
            <div id="scanner-overlay" class="absolute inset-0 pointer-events-none flex items-center justify-center">
                <div class="w-2/3 h-2/3 border-2 border-gv-brand/50 rounded-3xl relative">
                    <!-- Corners -->
                    <div class="absolute -top-1 -left-1 w-6 h-6 border-t-4 border-l-4 border-gv-brand rounded-tl-xl"></div>
                    <div class="absolute -top-1 -right-1 w-6 h-6 border-t-4 border-r-4 border-gv-brand rounded-tr-xl"></div>
                    <div class="absolute -bottom-1 -left-1 w-6 h-6 border-b-4 border-l-4 border-gv-brand rounded-bl-xl"></div>
                    <div class="absolute -bottom-1 -right-1 w-6 h-6 border-b-4 border-r-4 border-gv-brand rounded-br-xl"></div>
                    
                    <!-- Animated Laser Line -->
                    <div class="absolute inset-x-4 top-1/2 h-[2px] bg-gv-brand shadow-[0_0_15px_rgba(var(--brand-color-rgb),0.8)] animate-[scan_2s_infinite_ease-in-out]"></div>
                </div>
            </div>

            <!-- Success Flash Overlay -->
            <div id="success-flash" class="absolute inset-0 bg-emerald-500/0 pointer-events-none transition-all duration-300"></div>
        </div>

        <!-- Controls -->
        <div class="p-6 bg-[#0c0c0e] border-t border-slate-800 flex items-center justify-between">
            <button id="btn-torch" onclick="toggleTorch()" class="flex items-center gap-3 px-5 py-3 rounded-2xl bg-slate-800 text-slate-300 font-bold text-sm hover:bg-slate-700 transition-all">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Torch Off
            </button>
            <p class="text-[10px] text-slate-500 font-medium italic">Align barcode inside the frame</p>
        </div>
    </div>
</div>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
    let html5QrCode;
    let isTorchOn = false;

    document.addEventListener('DOMContentLoaded', function() {
        // Wire up main scanner button
        const btnScan = document.getElementById('btn-scan-po');
        if (btnScan) {
            btnScan.addEventListener('click', startScanner);
        }

        // Auto-focus the product selector for continuous logging
        const productSelect = document.querySelector('select[name="productId"]');
        if (productSelect) {
            productSelect.focus();
        }
    });

    async function startScanner() {
        const modal = document.getElementById('scanner-modal');
        modal.classList.remove('hidden');
        
        html5QrCode = new Html5Qrcode("reader");
        const config = { fps: 10, qrbox: { width: 250, height: 250 } };

        try {
            await html5QrCode.start(
                { facingMode: "environment" }, 
                config,
                onScanSuccess
            );
        } catch (err) {
            console.error("Unable to start scanner", err);
            alert("Camera access denied or not available.");
            stopScanner();
        }
    }

    function onScanSuccess(decodedText, decodedResult) {
        // Visual feedback: Green Flash
        const flash = document.getElementById('success-flash');
        flash.classList.replace('bg-emerald-500/0', 'bg-emerald-500/40');
        setTimeout(() => flash.classList.replace('bg-emerald-500/40', 'bg-emerald-500/0'), 300);

        // Success Sound (simulated with vibration)
        if (navigator.vibrate) navigator.vibrate(100);

        // Stop scanning after success
        stopScanner();

        // Logic: Find matching PO in the dropdown
        const poSelect = document.querySelector('select[name="poId"]');
        let found = false;

        for (let i = 0; i < poSelect.options.length; i++) {
            const option = poSelect.options[i];
            // Check if PO Number or Supplier Name contains the scanned text
            if (option.text.toUpperCase().includes(decodedText.toUpperCase())) {
                poSelect.selectedIndex = i;
                found = true;
                break;
            }
        }

        if (found) {
            alert(`Detected PO: ${decodedText}. Selected for receipt.`);
        } else {
            alert(`Scanned: ${decodedText}. No matching active Purchase Order found.`);
        }
    }

    async function stopScanner() {
        const modal = document.getElementById('scanner-modal');
        modal.classList.add('hidden');
        
        if (html5QrCode && html5QrCode.isScanning) {
            await html5QrCode.stop();
        }
        isTorchOn = false;
        document.getElementById('btn-torch').innerHTML = '<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg> Torch Off';
    }

    async function toggleTorch() {
        if (!html5QrCode || !html5QrCode.isScanning) return;
        
        try {
            isTorchOn = !isTorchOn;
            await html5QrCode.applyVideoConstraints({
                advanced: [{ torch: isTorchOn }]
            });
            
            const btn = document.getElementById('btn-torch');
            btn.innerHTML = isTorchOn 
                ? '<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg> Torch On'
                : '<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg> Torch Off';
            
            btn.classList.toggle('bg-gv-brand', isTorchOn);
            btn.classList.toggle('bg-slate-800', !isTorchOn);
        } catch (err) {
            console.error("Torch not supported on this device", err);
        }
    }
</script>

<style>
@@keyframes scan {
    0%, 100% { transform: translateY(-100px); opacity: 0; }
    50% { transform: translateY(100px); opacity: 1; }
}
</style>






