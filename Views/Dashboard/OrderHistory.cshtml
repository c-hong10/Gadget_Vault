@using GadgetVault.Models
@model IEnumerable<PurchaseOrder>
@{
    ViewData["Title"] = "Order History";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var orders = Model ?? Enumerable.Empty<PurchaseOrder>();
    var user = ViewBag.CurrentUser as User;
    string search = ViewBag.Search ?? "";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">
    <!-- HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Order History</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                Viewing fulfilled and received orders for <span class="font-bold text-slate-700 dark:text-slate-200">@(user?.Supplier?.CompanyName ?? "Your Company")</span>.
            </p>
        </div>
        <div class="flex items-center gap-1 bg-slate-100 dark:bg-slate-800/50 p-1 rounded-xl">
            <span class="px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-slate-400">Filter: Received Only</span>
        </div>
    </div>

    <!-- TOOLBAR: SEARCH -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors duration-300">
        <form method="get" class="relative w-full md:w-96">
            <input type="text" name="search" value="@search" placeholder="Search by PO Number..." 
                   class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl text-xs font-bold focus:ring-2 focus:ring-gv-brand/20 focus:border-gv-brand transition-all outline-none text-slate-700 dark:text-slate-300">
            <div class="absolute left-3 top-3 text-slate-400">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <button type="submit" class="hidden"></button>
        </form>
    </div>

    <!-- PO LIST SECTION -->
    <section class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm transition-all duration-300">
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 dark:bg-slate-900/20 border-b border-slate-100 dark:border-slate-800">
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Order Ref</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Date Completed</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Value</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-center">Final Status</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                    @foreach (var po in orders) {
                        <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                            <td class="px-6 py-4">
                                <div class="text-xs font-black text-slate-900 dark:text-white">@po.PONumber</div>
                                <div class="text-[10px] font-bold text-slate-400 font-mono">ID: @po.Id.ToString("D4")</div>
                            </td>
                            <td class="px-6 py-4 text-xs text-slate-500 font-medium">
                                @po.OrderDate.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-6 py-4 text-right font-mono text-sm font-black text-slate-800 dark:text-slate-200">
                                @po.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("en-PH"))
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-tight bg-emerald-100 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">
                                    <span class="w-1 h-1 rounded-full bg-emerald-400"></span>
                                    @po.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="PODetails" asp-route-id="@po.Id" class="text-[10px] font-black text-slate-400 hover:text-gv-brand uppercase tracking-widest transition-colors">
                                    View Full Details
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!orders.Any()) {
                        <tr>
                            <td colspan="5" class="px-6 py-24 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-16 h-16 bg-slate-50 dark:bg-slate-800/50 rounded-2xl flex items-center justify-center text-slate-300 dark:text-slate-600 mb-2">
                                        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                    </div>
                                    <h3 class="text-sm font-bold text-slate-900 dark:text-white">No History Records</h3>
                                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium italic">No historical orders found matching your search.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION (Matching Stock Adjustments style) -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30 flex items-center justify-between">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                Page @currentPage of @totalPages
            </p>
            <div class="flex items-center gap-2">
                <a href="?search=@search&page=@(currentPage - 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
                </a>
                
                <div class="flex items-center gap-1">
                    @for (int i = 1; i <= totalPages; i++) {
                        <a href="?search=@search&page=@i" 
                           class="w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all @(i == currentPage ? "bg-gv-brand text-white shadow-md shadow-gv-brand/20" : "text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                            @i
                        </a>
                    }
                </div>

                <a href="?search=@search&page=@(currentPage + 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </section>
</div>
