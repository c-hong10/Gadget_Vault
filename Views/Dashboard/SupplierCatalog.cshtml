@using GadgetVault.Models
@model IEnumerable<Product>
@{
    ViewData["Title"] = "Supplier Catalog";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var products = Model ?? Enumerable.Empty<Product>();
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">
    <!-- PAGE HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">My Catalog</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage your active product line and supply pricing.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-4 py-2 bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl shadow-sm text-xs font-bold text-slate-500">
                <span class="text-gv-brand">@totalCount</span> SKUs Active
            </div>
        </div>
    </div>

    <!-- MAIN SECTION -->
    <section class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl overflow-hidden shadow-sm transition-all duration-300">
        <!-- Toolbar -->
        <div class="p-6 border-b border-slate-200 dark:border-[#1e1e24] flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#111113]/20">
            <div class="relative w-full sm:w-96">
                <input type="text" id="prod-search" placeholder="Quick search catalog..." 
                       class="w-full pl-10 pr-4 py-2.5 bg-white dark:bg-[#111113]/50 border border-slate-200 dark:border-[#1e1e24] rounded-xl text-xs font-bold focus:ring-2 focus:ring-gv-brand/20 focus:border-gv-brand transition-all outline-none text-slate-700 dark:text-slate-300">
                <div class="absolute left-3 top-3 text-slate-400 pointer-events-none">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/30 dark:bg-[#111113]/10 border-b border-slate-100 dark:border-[#1e1e24]">
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Media</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Product Identity</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Classification</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Supply Cost</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#1e1e24]/60" id="prod-tbody">
                    @foreach (var p in products) {
                        <tr class="group hover:bg-slate-50 dark:hover:bg-[#1e1e24]/30 transition-colors prod-row">
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(p.ImageUrl)) {
                                    <img src="@p.ImageUrl" class="h-10 w-10 object-cover rounded-xl border border-slate-200 dark:border-[#1e1e24] shadow-sm transition-transform group-hover:scale-110" />
                                } else {
                                    <div class="h-10 w-10 rounded-xl bg-slate-50 dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] flex items-center justify-center text-slate-300">
                                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-xs font-black text-slate-900 dark:text-white">@p.Name</div>
                                <div class="text-[10px] font-bold text-slate-400 font-mono">@p.SKU</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded-md text-[10px] font-black uppercase tracking-tight bg-slate-100 dark:bg-[#1e1e24] text-slate-500 border border-slate-200 dark:border-[#1e1e24]">
                                    @(p.Category?.Name ?? "General")
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="text-sm font-black text-slate-900 dark:text-white font-mono">
                                    @p.CostPrice.ToString("C2", new System.Globalization.CultureInfo("en-PH"))
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!products.Any()) {
                        <tr>
                            <td colspan="4" class="px-6 py-24 text-center">
                                <p class="text-xs text-slate-400 font-medium italic">Your product catalog is empty.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION (Matching Stock Adjustments style) -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-[#1e1e24] bg-slate-50/50 dark:bg-[#111113]/30 flex items-center justify-between">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                Showing @((currentPage - 1) * 12 + 1)-@Math.Min(currentPage * 12, totalCount) of @totalCount products
            </p>
            <div class="flex items-center gap-2">
                <a asp-action="SupplierCatalog" asp-route-page="@(currentPage - 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
                </a>
                
                <div class="flex items-center gap-1">
                    @for (int i = 1; i <= totalPages; i++) {
                        <a asp-action="SupplierCatalog" asp-route-page="@i" 
                           class="w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all @(i == currentPage ? "bg-gv-brand text-white shadow-md shadow-gv-brand/20" : "text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                            @i
                        </a>
                    }
                </div>

                <a asp-action="SupplierCatalog" asp-route-page="@(currentPage + 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </section>
</div>

<script>
    document.getElementById('prod-search').addEventListener('input', function(e) {
        const q = e.target.value.toLowerCase();
        document.querySelectorAll('.prod-row').forEach(row => {
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(q) ? '' : 'none';
        });
    });
</script>
