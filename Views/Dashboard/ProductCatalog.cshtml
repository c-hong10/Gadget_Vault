                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">SKU <span class="text-red-500">*</span></label>
                        <input type="text" name="sku" id="edit-prod-sku" required
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-mono text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">@(User.IsInRole("Supplier") ? "My Cost Price ($)" : "Supplier Cost ($)") <span class="text-red-500">*</span></label>
                        <input type="number" name="costPrice" id="edit-prod-cost" required min="0" step="0.01"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                </div>

                @if (!User.IsInRole("Supplier"))
                {
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Retail Selling Price ($) <span class="text-red-500">*</span></label>
                        <input type="number" name="sellingPrice" id="edit-prod-sell" required min="0" step="0.01"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                }

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Category <span class="text-red-500">*</span></label>
                        <select name="categoryId" id="edit-prod-cat" required
                                class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all cursor-pointer">
                            <option value="" disabled>Select category...</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    @if (!User.IsInRole("Supplier"))
                    {
                        <div>
                            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Supplier <span class="text-red-500">*</span></label>
                            <select name="supplierId" id="edit-prod-sup" required
                                    class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all cursor-pointer">
                                <option value="" disabled>Select supplier...</option>
                                @foreach (var sup in suppliers)
                                {
                                    <option value="@sup.Id">@sup.CompanyName</option>
                                }
                            </select>
