                    }
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea name="description" id="edit-prod-desc" rows="2"
                              class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all resize-none"></textarea>
                </div>
                <!-- Row 5: Image -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Product Image <span class="text-slate-400 font-normal">(optional, will overwrite existing)</span></label>
                    <input type="file" name="imageFile" accept="image/*"
                           class="w-full px-4 py-2 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all cursor-pointer file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 dark:file:bg-slate-700 dark:file:text-slate-200 hover:file:bg-slate-300 dark:hover:file:bg-slate-600"/>
                </div>
                <!-- Actions -->
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="document.getElementById('modal-edit-product').classList.add('hidden')"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- BARCODE MODAL -->
<div id="modal-barcode" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/80 backdrop-blur-md transition-all duration-300">
    <div class="relative w-full max-w-sm bg-[#111113] border border-slate-800 rounded-3xl shadow-2xl overflow-hidden flex flex-col">
        <div class="p-6 border-b border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-lg font-extrabold text-white tracking-tight">Test Barcode</h3>
                <p id="barcode-sku" class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mt-1"></p>
            </div>
            <button onclick="document.getElementById('modal-barcode').classList.add('hidden')" class="p-2 rounded-xl bg-slate-800 text-slate-400 hover:text-white transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="p-8 bg-white flex flex-col items-center justify-center gap-4">
            <svg id="barcode-canvas"></svg>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Point scanner at screen to test</p>
        </div>
        <div class="p-4 bg-[#0c0c0e] text-center">
             <button onclick="document.getElementById('modal-barcode').classList.add('hidden')" class="w-full py-3 rounded-xl bg-slate-800 text-white text-sm font-bold hover:bg-slate-700 transition-all">Close Preview</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
<script>
    let isVaultOpen = false;

    function showBarcode(sku) {
        document.getElementById('barcode-sku').innerText = sku;
        JsBarcode("#barcode-canvas", sku, {
            format: "CODE128",
            lineColor: "#000",
            width: 2,
            height: 100,
            displayValue: true,
            fontSize: 16,
            font: "monospace",
            margin: 10
        });
        document.getElementById('modal-barcode').classList.remove('hidden');
    }

    function toggleVault() {
        isVaultOpen = !isVaultOpen;
        const activeTable = document.getElementById('active-table');
        const vaultPanel  = document.getElementById('vault-panel');
        const btnLabel    = document.getElementById('vault-btn-label');
        const toggleBtn   = document.getElementById('btn-vault-toggle');

        if (isVaultOpen) {
            activeTable.style.display = 'none';
            vaultPanel.style.display  = 'block';
            btnLabel.innerText        = 'Exit Archive';
            toggleBtn.style.background = 'white';
            toggleBtn.style.color      = 'var(--brand-color)';
            loadVault();
        } else {
            activeTable.style.display = 'block';
            vaultPanel.style.display  = 'none';
            btnLabel.innerText        = 'View Archives';
            toggleBtn.style.background = 'color-mix(in srgb,var(--brand-color) 8%,transparent)';
            toggleBtn.style.color      = 'var(--brand-color)';
            filterProducts(); // Re-apply search filter to active items
        }
    }

    async function loadVault() {
        const tbody = document.getElementById('vault-table-body');
        tbody.innerHTML = '<tr id="vault-loading"><td colspan="5" class="px-6 py-8 text-center text-slate-400 text-sm">Searching the vault...</td></tr>';

        try {
            const res = await fetch('/Dashboard/GetArchivedProducts');
            const products = await res.json();

            if (products.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 text-sm font-medium italic">The vault is empty. No archived products found.</td></tr>';
            } else {
                tbody.innerHTML = '';
                products.forEach(p => {
                    const row = document.createElement('tr');
                    row.className = "hover:bg-amber-500/5 transition-colors vault-row";
                    row.dataset.name = p.name.toLowerCase();
                    row.dataset.sku = p.sku.toLowerCase();
                    row.innerHTML = `
                        <td class="px-6 py-4 font-mono text-xs font-semibold text-amber-600/80">${p.sku}</td>
                        <td class="px-6 py-4 font-semibold text-slate-700 dark:text-slate-300">${p.name}</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-tight bg-amber-100 text-amber-700 border border-amber-200">
                                ${p.category ? p.category.name : 'General'}
                            </span>
                        </td>
                        <td class="px-6 py-4 font-bold text-slate-700 dark:text-slate-300 text-right">$${parseFloat(p.price).toFixed(2)}</td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="restoreProduct(${p.id}, '${p.name.replace("'","\\\'")}')" title="Restore Gadget"
                                    class="p-2 rounded-lg bg-amber-50 dark:bg-amber-500/10 text-amber-600 hover:bg-amber-100 dark:hover:bg-amber-500/20 transition-all border-none outline-none">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            </button>
                        </td>
                    `;
                    tbody.appendChild(row);
                });
                filterProducts(); // Apply search if already typing
            }
        } catch (e) {
            tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-red-400">Failed to load vault.</td></tr>';
        }
    }

    async function restoreProduct(id, name) {
        if (typeof showConfirm === 'function') {
            showConfirm("Restore Product", "Move \"" + name + "\" back to active catalog?", async function() {
                try {
                    const res = await fetch(`/Dashboard/RestoreProduct/${id}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert(data.message);
                    }
                } catch (e) {
                    console.error("Restore failed", e);
                }
            });
        }
    }

    function filterProducts() {
        // Now handled server-side for Active Table. 
        // Vault Table still uses client-side filtering as it's a smaller set.
        const q = document.getElementById('prod-search')?.value.toLowerCase() || "";
        
        if (isVaultOpen) {
            document.querySelectorAll('.vault-row').forEach(row => {
                const nameMatch = row.dataset.name.includes(q) || row.dataset.sku.includes(q);
                row.style.display = nameMatch ? '' : 'none';
            });
        }
    }

    function openEditModal(btn) {
        const row = btn.closest('tr');
        document.getElementById('edit-prod-id').value = row.dataset.id;
        document.getElementById('edit-prod-name').value = row.dataset.rawName;
        document.getElementById('edit-prod-sku').value = row.dataset.rawSku;
        
        // Pricing
        const costInput = document.getElementById('edit-prod-cost');
        if (costInput) costInput.value = row.dataset.costPrice;
        
        const sellInput = document.getElementById('edit-prod-sell');
        if (sellInput) sellInput.value = row.dataset.sellingPrice;

        document.getElementById('edit-prod-cat').value = row.dataset.catId;
        
        const supInput = document.getElementById('edit-prod-sup');
        if (supInput) supInput.value = row.dataset.supplierId;
        
        document.getElementById('edit-prod-desc').value = row.dataset.desc || '';
        
        const form = document.getElementById('editProductForm');
        form.action = `/Product/Edit/${row.dataset.id}`;
        
        document.getElementById('modal-edit-product').classList.remove('hidden');
    }

    function triggerArchive(id, itemName) {
        if (typeof showConfirm === 'function') {
            showConfirm("Archive Product", "Archive \"" + itemName + "\"? It will be hidden from active views but preserved for reporting.", function() {
                fetch(`/Product/Archive/${id}`, { method: 'POST' })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) window.location.reload();
                        else alert(res.message);
                    })
                    .catch(e => console.error("Archive failed", e));
            });
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        const toast = document.getElementById('toast-success');
        if (toast) setTimeout(() => toast.style.opacity = '0', 3500);
    });
</script>





