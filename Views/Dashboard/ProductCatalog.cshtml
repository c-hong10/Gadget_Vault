@using GadgetVault.Models
@{
    ViewData["Title"] = "Product Catalog";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var products   = (ViewBag.Products   as IEnumerable<Product>)  ?? Enumerable.Empty<Product>();
    var categories = (ViewBag.Categories as IEnumerable<Category>) ?? Enumerable.Empty<Category>();
}

<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6">

    <!-- PAGE HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Product Catalog</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage global product portfolio, SKUs, and pricing.</p>
        </div>
    </div>

    <!-- TOAST NOTIFICATION -->
    @if (TempData["Success"] != null)
    {
        <div id="toast-success"
             class="flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold shadow-sm transition-opacity duration-500"
             style="background-color: color-mix(in srgb, var(--brand-color) 10%, transparent); border: 1px solid color-mix(in srgb, var(--brand-color) 30%, transparent); color: var(--brand-color);">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 px-5 py-3.5 rounded-xl bg-red-50 dark:bg-red-500/10
                    border border-red-200 dark:border-red-500/30 text-red-700 dark:text-red-400
                    text-sm font-semibold shadow-sm">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            @TempData["Error"]
        </div>
    }

    <!-- MAIN CARD -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm flex flex-col">

        <!-- Toolbar -->
        <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
            <div class="flex flex-1 flex-col sm:flex-row gap-3">
                <!-- Search -->
                <div class="relative w-full sm:w-80">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                         width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
                    </svg>
                    <input type="text" id="prod-search" oninput="filterProducts()" placeholder="Search products..."
                           class="w-full pl-9 pr-4 py-2 bg-white dark:bg-[#09090b] border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <!-- Filter by Category -->
                <select id="cat-filter" onchange="filterProducts()"
                        class="w-full sm:w-48 bg-white dark:bg-[#09090b] border border-slate-200 dark:border-slate-700/60 rounded-xl px-3 py-2 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all cursor-pointer">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Name">@cat.Name</option>
                    }
                </select>
            </div>
            <!-- Add product button -->
            <button onclick="document.getElementById('modal-add-product').classList.remove('hidden')"
                    class="flex items-center justify-center gap-2 px-4 py-2 text-white text-sm font-bold rounded-xl shadow-lg transition-all shrink-0 border-none outline-none"
                    style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add New Gadget
            </button>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm whitespace-nowrap">
                <thead>
                    <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 w-16">Image</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">SKU</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Product Name</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Category</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Price</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="prod-table-body" class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var p in products)
                    {
                        <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group prod-row"
                            data-id="@p.Id"
                            data-name="@p.Name.ToLower()" data-sku="@p.SKU.ToLower()" data-cat="@(p.Category?.Name ?? "")"
                            data-raw-name="@p.Name" data-raw-sku="@p.SKU" data-cat-id="@p.CategoryId" data-price="@p.Price.ToString("0.00")" data-desc="@p.Description">
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" class="h-10 w-10 object-cover rounded-lg border border-slate-200 dark:border-slate-700 shadow-sm" />
                                }
                                else
                                {
                                    <div class="h-10 w-10 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400">
                                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4 font-mono text-xs font-semibold text-slate-500 dark:text-slate-400">@p.SKU</td>
                            <td class="px-6 py-4 font-semibold text-slate-800 dark:text-slate-200">@p.Name</td>
                            <td class="px-6 py-4 text-slate-500 dark:text-slate-400">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold
                                             bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
                                    @(p.Category?.Name ?? "Uncategorised")
                                </span>
                            </td>
                            <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-200 text-right">$@p.Price.ToString("N2")</td>
                            <td class="px-6 py-4 text-right">
                                <button onclick="openEditModal(this)" class="text-xs font-bold transition-colors mr-3 bg-transparent border-none outline-none hover-brand" style="color: var(--brand-color);">Edit</button>
                                <button onclick="triggerArchive(@p.Id, '@p.Name')" class="text-xs font-bold text-slate-400 hover:text-amber-500 transition-colors bg-transparent border-none outline-none">Archive</button>
                            </td>
                        </tr>
                    }
                    @if (!products.Any())
                    {
                        <tr id="empty-row">
                            <td colspan="6" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 text-sm font-medium">
                                No products yet. Click <strong>Add New Gadget</strong> to add your first product.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50 flex items-center justify-between">
            <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">@products.Count() products in catalog</span>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     ADD PRODUCT MODAL
     ══════════════════════════════════════ -->
<div id="modal-add-product"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#18181b] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl w-full max-w-lg p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-base font-extrabold text-slate-900 dark:text-white">Add New Product</h2>
            <button onclick="document.getElementById('modal-add-product').classList.add('hidden')"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 bg-transparent border-none outline-none transition-colors">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" action="/Product/Create" enctype="multipart/form-data" onsubmit="this.querySelector('button[type=submit]').innerHTML = 'Processing...'; this.querySelector('button[type=submit]').disabled = true;">
            @Html.AntiForgeryToken()
            <div class="flex flex-col gap-4">
                <!-- Row 1: Name -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Product Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" required placeholder="e.g. Cisco Catalyst 9300"
                           class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <!-- Row 2: SKU + Price -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">SKU <span class="text-red-500">*</span></label>
                        <input type="text" name="sku" required placeholder="e.g. CSC-CAT9300"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-mono text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Price (USD) <span class="text-red-500">*</span></label>
                        <input type="number" name="price" required min="0" step="0.01" placeholder="0.00"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                </div>
                <!-- Row 3: Category -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Category <span class="text-red-500">*</span></label>
                    <select name="categoryId" required
                            class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all cursor-pointer">
                        <option value="" disabled selected>Select a category...</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <!-- Row 4: Description (optional) -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea name="description" rows="2" placeholder="Short product description..."
                              class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all resize-none"></textarea>
                </div>
                <!-- Row 5: Image -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Product Image <span class="text-slate-400 font-normal">(optional)</span></label>
                    <input type="file" name="imageFile" accept="image/*"
                           class="w-full px-4 py-2 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all cursor-pointer file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 dark:file:bg-slate-700 dark:file:text-slate-200 hover:file:bg-slate-300 dark:hover:file:bg-slate-600"/>
                </div>
                <!-- Actions -->
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="document.getElementById('modal-add-product').classList.add('hidden')"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        Save Product
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════
     EDIT PRODUCT MODAL
     ══════════════════════════════════════ -->
<div id="modal-edit-product"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#18181b] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl w-full max-w-lg p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-base font-extrabold text-slate-900 dark:text-white">Edit Product</h2>
            <button type="button" onclick="document.getElementById('modal-edit-product').classList.add('hidden')"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 bg-transparent border-none outline-none transition-colors">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" id="editProductForm" enctype="multipart/form-data" onsubmit="this.querySelector('button[type=submit]').innerHTML = 'Processing...'; this.querySelector('button[type=submit]').disabled = true;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="edit-prod-id" />
            <div class="flex flex-col gap-4">
                <!-- Row 1: Name -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Product Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" id="edit-prod-name" required
                           class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <!-- Row 2: SKU + Price -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">SKU <span class="text-red-500">*</span></label>
                        <input type="text" name="sku" id="edit-prod-sku" required
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-mono text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Price (USD) <span class="text-red-500">*</span></label>
                        <input type="number" name="price" id="edit-prod-price" required min="0" step="0.01"
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                    </div>
                </div>
                <!-- Row 3: Category -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Category <span class="text-red-500">*</span></label>
                    <select name="categoryId" id="edit-prod-cat" required
                            class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all cursor-pointer">
                        <option value="" disabled>Select a category...</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea name="description" id="edit-prod-desc" rows="2"
                              class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all resize-none"></textarea>
                </div>
                <!-- Row 5: Image -->
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Product Image <span class="text-slate-400 font-normal">(optional, will overwrite existing)</span></label>
                    <input type="file" name="imageFile" accept="image/*"
                           class="w-full px-4 py-2 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all cursor-pointer file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 dark:file:bg-slate-700 dark:file:text-slate-200 hover:file:bg-slate-300 dark:hover:file:bg-slate-600"/>
                </div>
                <!-- Actions -->
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="document.getElementById('modal-edit-product').classList.add('hidden')"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    function filterProducts() {
        const q   = document.getElementById('prod-search').value.toLowerCase();
        const cat = document.getElementById('cat-filter').value.toLowerCase();
        document.querySelectorAll('.prod-row').forEach(row => {
            const nameMatch = row.dataset.name.includes(q) || row.dataset.sku.includes(q);
            const catMatch  = cat === '' || row.dataset.cat.toLowerCase() === cat;
            row.style.display = (nameMatch && catMatch) ? '' : 'none';
        });
    }

    function openEditModal(btn) {
        const row = btn.closest('tr');
        document.getElementById('edit-prod-id').value = row.dataset.id;
        document.getElementById('edit-prod-name').value = row.dataset.rawName;
        document.getElementById('edit-prod-sku').value = row.dataset.rawSku;
        document.getElementById('edit-prod-price').value = row.dataset.price;
        document.getElementById('edit-prod-cat').value = row.dataset.catId;
        document.getElementById('edit-prod-desc').value = row.dataset.desc || '';
        
        const form = document.getElementById('editProductForm');
        form.action = `/Product/Edit/${row.dataset.id}`;
        
        document.getElementById('modal-edit-product').classList.remove('hidden');
    }

    function triggerArchive(id, itemName) {
        if (typeof showConfirm === 'function') {
            showConfirm("Archive Product", "Archive \"" + itemName + "\"? It will be hidden from active views but preserved for reporting.", function() {
                fetch(`/Product/Archive/${id}`, { method: 'POST' })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) window.location.reload();
                        else alert(res.message);
                    })
                    .catch(e => console.error("Archive failed", e));
            });
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        const toast = document.getElementById('toast-success');
        if (toast) setTimeout(() => toast.style.opacity = '0', 3500);
    });
</script>





