@using GadgetVault.Models
@model IEnumerable<InventoryTransaction>
@{
    ViewData["Title"] = "Stock Adjustments";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var transactions = Model ?? Enumerable.Empty<InventoryTransaction>();
}

<script src="https://cdn.tailwindcss.com"></script>


<!-- ┌──────────────────────────────────────────────────────
     │  PAGE HEADER
     └────────────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">

    <!-- left: title block -->
    <div>
        <span class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-widest
                     bg-orange-500 text-white px-3 py-1.5 rounded-full mb-3 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse inline-block"></span>
            Inventory Audit
        </span>
        <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-tight">
            Stock Adjustments &amp;
            <span class="text-orange-500">Inventory Audit</span>
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1.5 font-medium max-w-xl leading-relaxed">
            Review discrepancies, approve adjustments, and track shrinkage across all warehouse zones.
        </p>
    </div>

    <!-- right: CTA button -->
    <div class="shrink-0 mt-1">
        <button id="btn-manual-adj" onclick="openAdjustmentModal()"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl
                       bg-gv-brand text-white text-sm font-bold
                       shadow-lg
                       hover:opacity-90 hover:-translate-y-0.5
                       transition-all duration-200
                       outline-none border-none">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            Manual Stock Adjustment
        </button>
    </div>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  KPI STATS CARDS — 3 columns
     └────────────────────────────────────────────────────── -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">

    <!-- Card 1: Pending Approvals (orange) -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none
                border border-slate-200 dark:border-slate-800
                relative overflow-hidden hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-orange-400 to-amber-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between mb-3">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 leading-tight">
                Pending Approvals
            </p>
            <div class="w-9 h-9 rounded-xl bg-orange-50 dark:bg-orange-500/10 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <circle cx="9" cy="9" r="7" stroke="#f97316" stroke-width="1.6"/>
                    <path d="M9 5.5v4l2.5 2.5" stroke="#f97316" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>
        <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none mb-1 text-right">@ViewBag.PendingCount</p>
        <p class="text-xs text-slate-400 dark:text-slate-500 font-medium text-right">Adjustments awaiting manager sign-off</p>
        <div class="mt-3 flex items-center justify-end gap-1.5">
            <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse inline-block"></span>
            <span class="text-xs font-semibold text-orange-500">Live Audit Sync</span>
        </div>
    </div>

    <!-- Card 2: Total Shrinkage MTD (red) -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none
                border border-slate-200 dark:border-slate-800
                relative overflow-hidden hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-400 to-rose-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between mb-3">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 leading-tight">
                Total Shrinkage (MTD)
            </p>
            <div class="w-9 h-9 rounded-xl bg-red-50 dark:bg-red-500/10 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M9 2l7.5 13H1.5L9 2z" stroke="#ef4444" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M9 8v3M9 13v.5" stroke="#ef4444" stroke-width="1.6" stroke-linecap="round"/>
                </svg>
            </div>
        </div>
        <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none mb-1 text-right">@ViewBag.TotalShrinkage.ToString("C0")</p>
        <p class="text-xs text-slate-400 dark:text-slate-500 font-medium text-right">From manual & system corrections</p>
        <div class="mt-3 flex items-center justify-end gap-1.5">
            <span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>
            <span class="text-xs font-semibold text-red-500">Updated @DateTime.Now.ToString("HH:mm")</span>
        </div>
    </div>

    <!-- Card 3: Audit Completion % (green) -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none
                border border-slate-200 dark:border-slate-800
                relative overflow-hidden hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--brand-color)] to-[color-mix(in_srgb,var(--brand-color)_80%,transparent)] rounded-t-2xl"></div>
        <div class="flex items-start justify-between mb-3">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 leading-tight">
                Audit Completion %
            </p>
            <div class="w-9 h-9 rounded-xl bg-gv-brand-light dark:bg-gv-brand/10 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <circle cx="9" cy="9" r="7" stroke="#23a476" stroke-width="1.6"/>
                    <path d="M5.5 9.2L8 11.5l4.5-5" stroke="#23a476" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>
        <p class="text-4xl font-black text-gv-brand tracking-tight leading-none mb-1 text-right">@ViewBag.AuditCompletion%</p>
        <p class="text-xs text-slate-400 dark:text-slate-500 font-medium text-right">Monthly cycle count progress</p>
        <div class="mt-3 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-[var(--brand-color)] to-[color-mix(in_srgb,var(--brand-color)_80%,transparent)] rounded-full" style="width:@ViewBag.AuditCompletion%"></div>
        </div>
    </div>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  ADJUSTMENT TABLE
     └────────────────────────────────────────────────────── -->
<section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none
                border border-slate-200 dark:border-slate-800 overflow-hidden"
         aria-labelledby="adj-table-heading">

    <!-- section header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800">
        <div class="flex items-center gap-3">
            <div class="w-1 h-7 rounded-full bg-orange-500 shrink-0"></div>
            <div>
                <h2 id="adj-table-heading"
                    class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight">
                    Adjustment Log
                </h2>
                <p class="text-xs text-slate-400 dark:text-slate-500 font-medium mt-0.5">All stock changes — pending &amp; approved</p>
            </div>
        </div>

        <!-- filter tabs -->
        <div class="flex items-center gap-1 bg-slate-100 dark:bg-slate-800/60 p-1 rounded-xl">
            <button class="text-xs font-bold px-3 py-1.5 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm transition-all duration-200">All</button>
            <button class="text-xs font-bold px-3 py-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all duration-200">Pending</button>
            <button class="text-xs font-bold px-3 py-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all duration-200">Approved</button>
        </div>
    </div>

    <!-- table -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm" aria-label="Stock adjustment log">
            <thead>
                <tr class="bg-slate-50 dark:bg-black/30 border-b border-slate-200 dark:border-slate-800">
                    <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Date</th>
                    <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Product</th>
                    <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">SKU</th>
                    <th class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Qty Change</th>
                    <th class="text-left text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Reason</th>
                    <th class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Status</th>
                    <th class="text-center text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 px-5 py-3">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                @foreach (var t in transactions)
                {
                    var qtyColor = t.Quantity > 0 ? "text-gv-brand" : "text-red-500";
                    var qtySign = t.Quantity > 0 ? "+" : "";
                    
                    var typeLabel = t.Type.ToString();
                    var typeClass = t.Type switch {
                        TransactionType.StockIn => "bg-gv-brand-light dark:bg-gv-brand/10 text-gv-brand-dark dark:text-gv-brand-light border-gv-brand-light dark:border-gv-brand/20",
                        TransactionType.StockOut => "bg-red-100 dark:bg-red-500/10 text-red-600 dark:text-red-400 border-red-200 dark:border-red-500/20",
                        _ => "bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-500/20"
                    };

                    <tr class="hover:bg-slate-50/70 dark:hover:bg-slate-800/20 transition-colors duration-150 group">
                        <td class="px-5 py-4 text-xs text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">
                            @t.Timestamp.ToString("MMM dd, yyyy HH:mm")
                        </td>
                        <td class="px-5 py-4">
                            <div class="font-semibold text-slate-900 dark:text-white text-xs">@(t.Product?.Name ?? "Unknown Product")</div>
                        </td>
                        <td class="px-5 py-4">
                            <span class="font-mono text-xs font-bold text-slate-700 dark:text-slate-300">@(t.Product?.SKU ?? "N/A")</span>
                        </td>
                        <td class="px-5 py-4 text-center">
                            <span class="font-extrabold text-base @qtyColor">@qtySign@t.Quantity</span>
                        </td>
                        <td class="px-5 py-4">
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold border @typeClass">
                                @typeLabel
                            </span>
                        </td>
                        <td class="px-5 py-4 text-center">
                            <span class="font-mono text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-tight">
                                @(t.ReferenceId ?? "SYSTEM")
                            </span>
                        </td>
                        <td class="px-5 py-4 text-center">
                            <button class="text-xs font-bold text-slate-400 dark:text-slate-500 hover:text-gv-brand transition-colors border-none bg-transparent">
                                View
                            </button>
                        </td>
                    </tr>
                }

                @if (!transactions.Any())
                {
                    <tr>
                        <td colspan="7" class="px-5 py-12 text-center text-slate-400 font-medium italic">
                            No inventory transactions recorded yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- table footer -->
    <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50
                flex items-center justify-between">
        <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">Showing @transactions.Count() entries in the audit ledger</span>
        <a href="#" class="text-xs font-bold text-gv-brand hover:text-gv-mid transition-colors">
            View full audit log →
        </a>
    </div>
</section>

<!-- MANUAL ADJUSTMENT MODAL -->
<div id="modal-adjustment" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm transition-all duration-300">
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all">
        <!-- Header -->
        <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50/50 dark:bg-white/5">
            <div>
                <h3 class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Manual Stock Adjustment</h3>
                <p class="text-xs text-slate-500 font-medium mt-0.5">Record shrinkage, damage, or found items.</p>
            </div>
            <button onclick="closeAdjustmentModal()" class="w-10 h-10 rounded-full flex items-center justify-center text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all border-none outline-none">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <form asp-action="SubmitStockAdjustment" method="post" class="p-8">
            @Html.AntiForgeryToken()
            <div class="space-y-5">
                <!-- Product -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Product</label>
                    <select name="productId" required class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-gv-brand outline-none transition-all dark:text-white">
                        <option value="">Select Product...</option>
                        @foreach (var p in (ViewBag.Products as List<Product>) ?? new List<Product>())
                        {
                            <option value="@p.Id">@p.Name (@p.SKU)</option>
                        }
                    </select>
                </div>

                <!-- Location -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Location</label>
                    <select name="locationId" required class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-gv-brand outline-none transition-all dark:text-white">
                        <option value="">Select Location...</option>
                        @foreach (var l in (ViewBag.Locations as List<WarehouseLocation>) ?? new List<WarehouseLocation>())
                        {
                            <option value="@l.Id">@l.Zone - @l.Aisle (@l.Rack)</option>
                        }
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-5">
                    <!-- Qty Change -->
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Qty Change</label>
                        <input type="number" name="quantityChange" required placeholder="e.g. -5 or 10" class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-gv-brand outline-none transition-all dark:text-white" />
                    </div>
                    <!-- Reason -->
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Reason</label>
                        <select name="reason" required class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-gv-brand outline-none transition-all dark:text-white">
                            <option value="Damaged">Damaged</option>
                            <option value="Lost">Lost</option>
                            <option value="Expired">Expired</option>
                            <option value="Found Discrepancy">Found Discrepancy</option>
                            <option value="Cycle Count">Cycle Count</option>
                        </select>
                    </div>
                </div>

                <!-- Notes -->
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Notes / Audit Details</label>
                    <textarea name="notes" rows="3" placeholder="Explain the reason for adjustment..." class="w-full bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-gv-brand outline-none transition-all dark:text-white resize-none"></textarea>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button type="submit" class="flex-1 bg-gv-brand text-white py-4 rounded-2xl font-black text-sm shadow-xl shadow-gv-brand/20 hover:opacity-90 hover:-translate-y-1 transition-all border-none outline-none">
                    Confirm & Update Stock
                </button>
                <button type="button" onclick="closeAdjustmentModal()" class="px-6 py-4 rounded-2xl bg-slate-100 dark:bg-slate-800 text-slate-500 font-bold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openAdjustmentModal() {
        document.getElementById('modal-adjustment').classList.remove('hidden');
    }
    function closeAdjustmentModal() {
        document.getElementById('modal-adjustment').classList.add('hidden');
    }
</script>






