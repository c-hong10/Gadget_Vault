@{
    ViewData["Title"] = "System Overview";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN — consistent with other dashboard views -->
<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

<!-- ┌──────────────────────────────────────────────────────
     │  PAGE HEADER
     └────────────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">

    <!-- left: title block -->
    <div>
        <span class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-widest
                     bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white px-3 py-1.5 rounded-full mb-3 shadow-sm transition-colors duration-300">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M5 0.5L1 2.3v2.8c0 1.9 1.6 3.7 4 4.4 2.4-.7 4-2.5 4-4.4V2.3L5 0.5z" fill="currentColor" opacity="0.9"/>
            </svg>
            System Administration
        </span>

        <h1 class="text-3xl font-black tracking-tight leading-tight">
            <span class="text-gv-brand">System</span>
            <span class="text-slate-900 dark:text-white transition-colors duration-300"> Overview</span>
        </h1>

        <p class="text-sm text-slate-500 dark:text-slate-400 mt-2 font-medium max-w-xl leading-relaxed transition-colors duration-300">
            Monitor system health, active sessions, and recent security events.
        </p>
    </div>

    <!-- right: live badge -->
    <div class="shrink-0 mt-1 flex items-center gap-2 px-4 py-2 bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm dark:shadow-none transition-colors duration-300">
        <span class="w-2 h-2 rounded-full bg-gv-brand animate-pulse inline-block"></span>
        <span class="text-xs font-semibold text-slate-500 dark:text-slate-400">Live — Updated now</span>
    </div>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  KPI CARDS — 4 columns
     └────────────────────────────────────────────────────── -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">

    <!-- Card 1: Total Revenue -->
    <a href="/SalesOrder" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                hover:scale-105 hover:shadow-xl hover:border-gv-brand/30 transition-all duration-300 group">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-gv-brand to-emerald-400 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div class="w-10 h-10 rounded-xl bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/10 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#23a476" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="14" fill="#23a476">₱</text>
                </svg>
            </div>
            <div class="flex-1 text-right">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-1">Total Gross Revenue</p>
                <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@(((decimal)ViewBag.TotalRevenue).ToString("C0", new System.Globalization.CultureInfo("en-PH")))</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">View Sales Orders →</p>
            </div>
        </div>
        <div class="mt-4 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
            <span class="w-1.5 h-1.5 rounded-full bg-gv-brand inline-block"></span>
            <span class="text-[10px] font-bold text-gv-brand uppercase tracking-widest">Live P&L Sync</span>
        </div>
    </a>

    <!-- Card 2: Active Orders -->
    <a href="/Warehouse/Fulfillment" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                hover:scale-105 hover:shadow-xl hover:border-blue-400/30 transition-all duration-300 group">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-500/10 border border-blue-100 dark:border-blue-500/10 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            </div>
            <div class="flex-1 text-right">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-1">Active Fulfillment</p>
                <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@ViewBag.ActiveOrdersCount</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">Open PPS Queue →</p>
            </div>
        </div>
        <div class="mt-4 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
            <span class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Real-time Logistics</span>
        </div>
    </a>

    <!-- Card 3: Global Value -->
    <a href="/Dashboard/WarehouseStaff" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                hover:scale-105 hover:shadow-xl hover:border-amber-400/30 transition-all duration-300 group">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-amber-400 to-orange-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div class="w-10 h-10 rounded-xl bg-amber-50 dark:bg-amber-500/10 border border-amber-100 dark:border-amber-500/10 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <div class="flex-1 text-right">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-1">Inventory Assets</p>
                <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@(((decimal)ViewBag.InventoryValue).ToString("C0", new System.Globalization.CultureInfo("en-PH")))</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">View Inventory →</p>
            </div>
        </div>
        <div class="mt-4 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
            <span class="text-[10px] font-bold text-amber-600 uppercase tracking-widest">Stock Valuation</span>
        </div>
    </a>

    <!-- Card 4: Low Stock Alerts -->
    <a href="/Dashboard/PurchaseOrders" class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden flex flex-col justify-between min-h-[140px]
                hover:scale-105 hover:shadow-xl hover:border-red-400/30 transition-all duration-300 group">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-red-400 to-rose-600 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div class="w-10 h-10 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-100 dark:border-red-100/10 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <div class="flex-1 text-right">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-1">Critical Alerts</p>
                <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tight leading-none">@ViewBag.LowStockCount</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-2 font-bold uppercase tracking-tighter">Fix Discrepancies →</p>
            </div>
        </div>
        <div class="mt-4 flex items-center justify-end gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
            <span class="w-1.5 h-1.5 rounded-full bg-red-400 @(ViewBag.LowStockCount > 0 ? "animate-pulse" : "") inline-block"></span>
            <span class="text-[10px] font-bold text-red-500 uppercase tracking-widest">Attention Needed</span>
        </div>
    </a>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  SPLIT LAYOUT — 60 / 40
     └────────────────────────────────────────────────────── -->
<div class="flex flex-col lg:flex-row gap-6">

    <!-- ╔══════════════════════════════════════════════════
         ║  LEFT 60%  — RECENT SALES ORDERS
         ╚══════════════════════════════════════════════════ -->
    <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col lg:flex-[6] transition-colors duration-300"
             aria-labelledby="sales-heading">

        <!-- card header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
            <div class="flex items-center gap-3">
                <div class="w-1 h-7 rounded-full bg-gv-brand shrink-0"></div>
                <div>
                    <h2 id="sales-heading" class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Recent Sales Orders
                    </h2>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5 transition-colors duration-300">Latest business performance</p>
                </div>
            </div>
            <a href="/SalesOrder/Index" class="text-xs font-bold text-slate-400 hover:text-gv-brand transition-colors">View All Orders</a>
        </div>

        <!-- sales ledger -->
        <div class="flex-1 overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 dark:bg-slate-900/20 border-b border-slate-100 dark:border-slate-800">
                        <th class="px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">Order #</th>
                        <th class="px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">Customer</th>
                        <th class="px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">Date</th>
                        <th class="px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">Status</th>
                        <th class="px-6 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                    @foreach (var order in (List<SalesOrder>)ViewBag.RecentSalesOrders)
                    {
                        var statusClass = order.Status switch {
                            SOStatus.Draft => "bg-slate-100 text-slate-600",
                            SOStatus.Pending => "bg-amber-100 text-amber-600",
                            SOStatus.Picking => "bg-blue-100 text-blue-600",
                            SOStatus.Packed => "bg-purple-100 text-purple-600",
                            SOStatus.Shipped => "bg-emerald-100 text-emerald-600",
                            _ => "bg-slate-100 text-slate-600"
                        };

                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                            <td class="px-6 py-4">
                                <span class="text-xs font-black text-slate-900 dark:text-white">@order.SONumber</span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-xs font-bold text-slate-700 dark:text-slate-300">@order.Customer?.CompanyName</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs text-slate-500">@order.OrderDate.ToString("MMM dd")</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-black uppercase tracking-tight @statusClass">
                                    @order.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="text-xs font-black text-slate-900 dark:text-white">@order.TotalAmount.ToString("C0")</span>
                            </td>
                        </tr>
                    }
                    @if (!((List<SalesOrder>)ViewBag.RecentSalesOrders).Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-400 italic">No sales orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- footer -->
        <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30 transition-colors duration-300">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                Aggregated from live transaction database
            </p>
        </div>
    </section>

    <!-- ╔══════════════════════════════════════════════════
         ║  RIGHT 40%  — CRITICAL ALERTS
         ╚══════════════════════════════════════════════════ -->
    <div class="flex flex-col gap-5 lg:flex-[4]">

        <!-- Critical Alerts card -->
        <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col transition-colors duration-300"
                 aria-labelledby="sessions-heading">

            <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                <div class="flex items-center gap-3">
                    <div class="w-1 h-7 rounded-full bg-red-500 shrink-0"></div>
                    <div>
                        <h2 id="sessions-heading" class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                            Critical Low Stock
                        </h2>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5 transition-colors duration-300">Requires immediate reorder</p>
                    </div>
                </div>
                <span class="flex items-center gap-1.5 text-xs font-bold text-red-500
                             bg-red-50 dark:bg-red-500/10 border border-red-100 dark:border-red-500/20 px-2.5 py-1 rounded-full transition-colors duration-300">
                    @ViewBag.LowStockCount Alerts
                </span>
            </div>

            <div class="flex-1 divide-y divide-slate-100 dark:divide-slate-800/60 transition-colors duration-300 overflow-y-auto max-h-[350px]">
                @foreach (var item in ViewBag.LowStockItems)
                {
                    <div class="flex items-center gap-4 px-5 py-4 hover:bg-red-50 dark:hover:bg-red-500/5 transition-colors duration-150">
                        <div class="relative shrink-0">
                            <div class="w-10 h-10 rounded-xl bg-red-100 dark:bg-red-500/15 flex items-center justify-center">
                                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-slate-900 dark:text-slate-200 truncate">@item.Name</p>
                            <p class="text-xs text-red-500 font-bold">Only @item.Qty units left</p>
                        </div>
                        <div class="text-right shrink-0">
                            <a href="/Dashboard/PurchaseOrders" class="inline-flex items-center gap-1.5 text-xs font-extrabold text-white bg-slate-900 dark:bg-slate-700 px-3 py-1.5 rounded-lg">RESTOCK</a>
                        </div>
                    </div>
                }
                @if (ViewBag.LowStockCount == 0) {
                    <div class="py-12 text-center text-slate-400 italic font-medium px-5">All stock levels healthy.</div>
                }
            </div>

            <div class="px-5 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30 transition-colors duration-300">
                <a href="#" class="text-xs font-bold text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">
                    Manage thresholds →
                </a>
            </div>
        </section>

        <!-- System Health mini-card -->
        <div class="bg-gv-brand-light dark:bg-[#0a1a12] rounded-2xl p-5 text-slate-900 dark:text-white relative overflow-hidden border border-gv-brand-light dark:border-gv-brand/10 transition-colors duration-300">
            <div class="absolute inset-0 opacity-10 dark:opacity-5"
                 style="background-image: linear-gradient(rgba(35,164,118,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(35,164,118,0.2) 1px, transparent 1px); background-size: 24px 24px;"></div>
            <div class="relative z-10">
                <p class="text-xs font-bold uppercase tracking-widest text-gv-brand dark:text-gv-brand-light dark:opacity-70 mb-3">Live Fleet Summary</p>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">@ViewBag.TotalProducts</p>
                        <p class="text-xs text-gv-brand dark:text-gv-brand-light dark:opacity-70 font-medium mt-1">Catalog SKUs</p>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">@ViewBag.LowStockCount</p>
                        <p class="text-xs text-gv-brand dark:text-gv-brand-light dark:opacity-70 font-medium mt-1">Alerts</p>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-gv-brand">100%</p>
                        <p class="text-xs text-gv-brand dark:text-gv-brand-light dark:opacity-70 font-medium mt-1">SLA Uptime</p>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">@ViewBag.TotalUsers</p>
                        <p class="text-xs text-gv-brand dark:text-gv-brand-light dark:opacity-70 font-medium mt-1">Active Users</p>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /right column -->

</div><!-- /split layout -->






