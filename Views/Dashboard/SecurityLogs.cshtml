@{
    ViewData["Title"] = "Security Logs";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Security Logs</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Audit trail for authentication events and role modifications.</p>
        </div>
        <button class="px-4 py-2 bg-slate-200 dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-sm font-bold rounded-xl transition-all">
            Export CSV
        </button>
    </div>

    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm flex flex-col">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm whitespace-nowrap">
                <thead>
                    <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Timestamp</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Event Type</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">User / IP</th>
                        <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Description</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-slate-500">2026-04-10 14:22:15</td>
                        <td class="px-6 py-4"><span class="px-2 py-1 bg-red-100 dark:bg-red-500/15 text-red-600 dark:text-red-400 text-xs font-bold rounded">Failed Login</span></td>
                        <td class="px-6 py-4 text-slate-700 dark:text-slate-300">unknown<br><span class="text-xs text-slate-400">192.168.1.45</span></td>
                        <td class="px-6 py-4 text-slate-500 dark:text-slate-400">Invalid password attempt for admin@gadgetvault.com</td>
                    </tr>
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-slate-500">2026-04-10 13:45:01</td>
                        <td class="px-6 py-4"><span class="px-2 py-1 bg-gv-brand-light dark:bg-gv-brand/15 text-gv-brand dark:text-gv-brand-light text-xs font-bold rounded">Login Success</span></td>
                        <td class="px-6 py-4 text-slate-700 dark:text-slate-300">alex.ray@gadgetvault.com<br><span class="text-xs text-slate-400">10.0.0.5</span></td>
                        <td class="px-6 py-4 text-slate-500 dark:text-slate-400">Successful authentication via 2FA.</td>
                    </tr>
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-4 font-mono text-xs text-slate-500">2026-04-09 09:12:33</td>
                        <td class="px-6 py-4"><span class="px-2 py-1 bg-amber-100 dark:bg-amber-500/15 text-amber-600 dark:text-amber-400 text-xs font-bold rounded">Role Modified</span></td>
                        <td class="px-6 py-4 text-slate-700 dark:text-slate-300">System<br><span class="text-xs text-slate-400">localhost</span></td>
                        <td class="px-6 py-4 text-slate-500 dark:text-slate-400">User ID 45 role updated from Staff to Manager.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>






