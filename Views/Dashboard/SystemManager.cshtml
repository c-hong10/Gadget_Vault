@{
    ViewData["Title"] = "System Overview";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CSS CDN (Play CDN — UI prototype) -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    'gv-dark':   '#061f17',
                    'gv-deep':   '#0a3124',
                    'gv-mid':    '#115740',
                    'gv-accent': '#23a476',
                    'gv-light':  '#f2f7f5',
                    'gv-sage':   '#d1e8df',
                },
                fontFamily: {
                    sans: ['Inter', 'Segoe UI', 'Roboto', 'sans-serif'],
                },
            },
        },
    }
</script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

<!-- ═══════════════════════════════════════════════════════
     OUTER SHELL
     ═══════════════════════════════════════════════════════ -->
<div class="flex min-h-screen bg-gv-light font-sans">

    <!-- ────────────────────────────────────────
         SIDEBAR
         ──────────────────────────────────────── -->
    <aside class="w-72 bg-gv-dark text-white flex flex-col shrink-0" style="padding: 30px;">

        <!-- brand -->
        <div class="flex items-center gap-3 mb-8">
            <div class="w-9 h-9 rounded-lg bg-gv-accent flex items-center justify-center shadow-lg shrink-0">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="2"  y="2"  width="7" height="7" rx="1.5" fill="white" opacity="0.95"/>
                    <rect x="11" y="2"  width="7" height="7" rx="1.5" fill="white" opacity="0.6"/>
                    <rect x="2"  y="11" width="7" height="7" rx="1.5" fill="white" opacity="0.6"/>
                    <rect x="11" y="11" width="7" height="7" rx="1.5" fill="white" opacity="0.85"/>
                </svg>
            </div>
            <div>
                <div class="font-extrabold text-base leading-tight">
                    Gadget<span class="text-gv-accent">Vault</span>
                </div>
                <div class="text-xs text-gv-sage opacity-70 font-medium leading-tight">System Manager</div>
            </div>
        </div>

        <!-- nav label -->
        <div class="text-xs font-bold uppercase tracking-widest text-gv-sage opacity-50 mb-3 px-1">
            Administration
        </div>

        <!-- nav links -->
        <nav class="flex flex-col gap-1" aria-label="System Manager navigation">

            <!-- Overview (Active) -->
            <a href="#" aria-current="page"
               class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gv-accent text-white font-semibold text-sm transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="1" y="1" width="6" height="6" rx="1.2" fill="currentColor" opacity="0.9"/>
                    <rect x="9" y="1" width="6" height="6" rx="1.2" fill="currentColor" opacity="0.5"/>
                    <rect x="1" y="9" width="6" height="6" rx="1.2" fill="currentColor" opacity="0.5"/>
                    <rect x="9" y="9" width="6" height="6" rx="1.2" fill="currentColor" opacity="0.8"/>
                </svg>
                Overview
            </a>

            <!-- User Management -->
            <a asp-controller="Dashboard" asp-action="UserManagement"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="6" cy="5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M1 14c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="12" cy="5" r="2" stroke="currentColor" stroke-width="1.4" opacity="0.6"/>
                    <path d="M11 10.5c1.5.3 3 1.5 3 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.6"/>
                </svg>
                User Management
            </a>

            <!-- Roles Access Control -->
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 1L3 3.5v4c0 3 2.5 5.5 5 6.5 2.5-1 5-3.5 5-6.5v-4L8 1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    <path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Roles Access Control
            </a>

            <!-- Connected Apps -->
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M6.5 9.5a3.5 3.5 0 005 0l2-2a3.5 3.5 0 00-5-5L7.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M9.5 6.5a3.5 3.5 0 00-5 0l-2 2a3.5 3.5 0 005 5L8.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Connected Apps
            </a>

            <!-- Security Logs -->
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 3C4 3 1.5 8 1.5 8S4 13 8 13s6.5-5 6.5-5S12 3 8 3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4"/>
                </svg>
                Security Logs
            </a>

            <!-- System Logs -->
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M5 6l2 2-2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 10h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                System Logs
            </a>

            <!-- Company Settings -->
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="7" width="12" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="8" cy="10.5" r="1.2" fill="currentColor" opacity="0.7"/>
                </svg>
                Company Settings
            </a>
        </nav>

        <!-- bottom profile + logout -->
        <div class="mt-auto">
            <hr class="border-white/10 my-5" />
            <a href="#"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-gv-sage font-medium text-sm hover:bg-gv-mid hover:text-white transition-all duration-200">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M2 14c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                My Profile
            </a>
            <a asp-controller="Home" asp-action="Index"
               class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-400 font-semibold text-sm hover:bg-red-500/10 transition-all duration-200 mt-1">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M6 14H3a1 1 0 01-1-1V3a1 1 0 011-1h3M10 11l3-3-3-3M13 8H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Log Out
            </a>
        </div>
    </aside>

    <!-- ────────────────────────────────────────
         MAIN CONTENT
         ──────────────────────────────────────── -->
    <main class="flex-1 p-8 overflow-auto" id="main-content">

        <!-- ┌──────────────────────────────────────────────────────
             │  PAGE HEADER
             └────────────────────────────────────────────────────── -->
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">

            <!-- left: title block -->
            <div>
                <!-- SYSTEM ADMINISTRATION pill -->
                <span class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-widest
                             bg-slate-800 text-white px-3 py-1.5 rounded-full mb-3 shadow-sm">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                        <path d="M5 0.5L1 2.3v2.8c0 1.9 1.6 3.7 4 4.4 2.4-.7 4-2.5 4-4.4V2.3L5 0.5z" fill="currentColor" opacity="0.9"/>
                    </svg>
                    System Administration
                </span>

                <!-- main title -->
                <h1 class="text-3xl font-black tracking-tight leading-tight">
                    <span class="text-gv-accent">System</span>
                    <span class="text-gv-deep"> Overview</span>
                </h1>

                <!-- subtitle -->
                <p class="text-sm text-slate-500 mt-2 font-medium max-w-xl leading-relaxed">
                    Monitor system health, active sessions, and recent security events.
                </p>
            </div>

            <!-- right: timestamp badge -->
            <div class="shrink-0 mt-1 flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl shadow-sm">
                <span class="w-2 h-2 rounded-full bg-gv-accent animate-pulse"></span>
                <span class="text-xs font-semibold text-slate-500">Live — Updated now</span>
            </div>
        </div>

        <!-- ┌──────────────────────────────────────────────────────
             │  KPI CARDS — 4 columns
             └────────────────────────────────────────────────────── -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">

            <!-- Card 1: Total Active Users (green border) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden
                        hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gv-accent to-emerald-400 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Total Active Users</p>
                        <p class="text-5xl font-black text-gv-deep tracking-tight leading-none">42</p>
                        <p class="text-xs text-slate-400 mt-2 font-medium">3 pending invites</p>
                    </div>
                    <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                            <circle cx="8"  cy="7"  r="3.5" stroke="#23a476" stroke-width="1.8"/>
                            <path d="M2 19c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="#23a476" stroke-width="1.8" stroke-linecap="round"/>
                            <circle cx="16" cy="7"  r="2.5" stroke="#23a476" stroke-width="1.5" opacity="0.55"/>
                            <path d="M15 13.5c2 .4 4 1.9 4 5.5" stroke="#23a476" stroke-width="1.5" stroke-linecap="round" opacity="0.55"/>
                        </svg>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-gv-accent inline-block"></span>
                    <span class="text-xs font-semibold text-gv-accent">All systems operational</span>
                </div>
            </div>

            <!-- Card 2: Failed Logins 24h (red border) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden
                        hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-400 to-rose-500 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Failed Logins (24H)</p>
                        <p class="text-5xl font-black text-gv-deep tracking-tight leading-none">7</p>
                        <p class="text-xs text-slate-400 mt-2 font-medium">Across 2 accounts</p>
                    </div>
                    <div class="w-11 h-11 rounded-xl bg-red-50 flex items-center justify-center shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                            <path d="M11 2L4 5.5v5c0 4.14 2.97 8.01 7 9.5 4.03-1.49 7-5.36 7-9.5v-5L11 2z" stroke="#ef4444" stroke-width="1.8" stroke-linejoin="round"/>
                            <path d="M11 9v3M11 14.5v.5" stroke="#ef4444" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>
                    <span class="text-xs font-semibold text-red-500">Review security logs</span>
                </div>
            </div>

            <!-- Card 3: Active Integrations (blue border) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden
                        hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Active Integrations</p>
                        <p class="text-5xl font-black text-gv-deep tracking-tight leading-none">3</p>
                        <p class="text-xs text-slate-400 mt-2 font-medium">Shopify · QuickBooks · FedEx</p>
                    </div>
                    <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                            <path d="M9 13a5 5 0 007 0l3-3a5 5 0 00-7-7L10.5 4.5" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                            <path d="M13 9a5 5 0 00-7 0L3 12a5 5 0 007 7L11.5 17.5" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>
                    <span class="text-xs font-semibold text-blue-500">All connections healthy</span>
                </div>
            </div>

            <!-- Card 4: System Uptime (purple border) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 relative overflow-hidden
                        hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-400 to-violet-500 rounded-t-2xl"></div>
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">System Uptime</p>
                        <p class="text-5xl font-black text-gv-deep tracking-tight leading-none">99.9%</p>
                        <p class="text-xs text-slate-400 mt-2 font-medium">Last updated 2 mins ago</p>
                    </div>
                    <div class="w-11 h-11 rounded-xl bg-purple-50 flex items-center justify-center shrink-0">
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                            <circle cx="11" cy="11" r="8.5" stroke="#a855f7" stroke-width="1.8"/>
                            <path d="M11 5v6l3.5 3.5" stroke="#a855f7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
                    <span class="text-xs font-semibold text-purple-500">SLA target: 99.5%</span>
                </div>
            </div>
        </div>

        <!-- ┌──────────────────────────────────────────────────────
             │  SPLIT LAYOUT — 60 / 40
             └────────────────────────────────────────────────────── -->
        <div class="flex flex-col xl:flex-row gap-6">

            <!-- ╔══════════════════════════════════════════════════
                 ║  LEFT 60%  — RECENT SECURITY ALERTS
                 ╚══════════════════════════════════════════════════ -->
            <section class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col xl:flex-[6]"
                     aria-labelledby="alerts-heading">

                <!-- card header -->
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                    <div class="flex items-center gap-3">
                        <div class="w-1 h-7 rounded-full bg-red-400 shrink-0"></div>
                        <div>
                            <h2 id="alerts-heading" class="text-sm font-extrabold text-gv-deep tracking-tight">
                                Recent Security Alerts
                            </h2>
                            <p class="text-xs text-slate-400 font-medium mt-0.5">Human-triggered security events</p>
                        </div>
                    </div>
                    <span class="flex items-center gap-1.5 text-xs font-bold text-red-500
                                 bg-red-50 border border-red-200 px-2.5 py-1 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse inline-block"></span>
                        Live
                    </span>
                </div>

                <!-- alerts feed -->
                <div class="flex-1 px-6 py-4 space-y-3">

                    <!-- Alert 1 — Failed Login (red) -->
                    <div class="flex items-start gap-4 p-4 rounded-xl bg-red-50 border border-red-100
                                hover:border-red-200 transition-colors duration-200">
                        <div class="w-9 h-9 rounded-xl bg-red-100 flex items-center justify-center shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <path d="M8 2L2 4.5v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5v-4L8 2z" stroke="#ef4444" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M8 6.5v3M8 11v.5" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-slate-800">Failed Login Attempt</p>
                            <p class="text-xs text-slate-500 mt-0.5 font-medium">
                                <span class="font-semibold text-red-600">admin@techflow.com</span>
                                &nbsp;·&nbsp; IP: 192.168.1.4
                            </p>
                            <span class="inline-flex items-center gap-1 mt-2 text-xs font-bold text-red-600 bg-red-100 border border-red-200 px-2 py-0.5 rounded-full">
                                5 consecutive failures — Auto-locked
                            </span>
                        </div>
                        <span class="text-xs text-slate-400 font-medium whitespace-nowrap">3 min ago</span>
                    </div>

                    <!-- Alert 2 — Role Change (yellow) -->
                    <div class="flex items-start gap-4 p-4 rounded-xl bg-amber-50 border border-amber-100
                                hover:border-amber-200 transition-colors duration-200">
                        <div class="w-9 h-9 rounded-xl bg-amber-100 flex items-center justify-center shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <path d="M8 1L3 3.5v4c0 3 2.5 5.5 5 6.5 2.5-1 5-3.5 5-6.5v-4L8 1z" stroke="#f59e0b" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M5.5 8l2 2 3-3" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-slate-800">Role Changed</p>
                            <p class="text-xs text-slate-500 mt-0.5 font-medium">
                                <span class="font-semibold text-amber-700">Jane Mendoza</span>
                                &nbsp;→ moved to <span class="font-bold text-gv-deep">Warehouse Manager</span>
                            </p>
                            <p class="text-xs text-slate-400 mt-1">Modified by: Admin John Dela Cruz</p>
                        </div>
                        <span class="text-xs text-slate-400 font-medium whitespace-nowrap">1 hr ago</span>
                    </div>

                    <!-- Alert 3 — New Device Login (green) -->
                    <div class="flex items-start gap-4 p-4 rounded-xl bg-emerald-50 border border-emerald-100
                                hover:border-emerald-200 transition-colors duration-200">
                        <div class="w-9 h-9 rounded-xl bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="#23a476" stroke-width="1.5"/>
                                <path d="M6 12v2M10 12v2M4 14h8" stroke="#23a476" stroke-width="1.4" stroke-linecap="round"/>
                                <path d="M5.5 8.5l2 2 3-3" stroke="#23a476" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-slate-800">New Device Login</p>
                            <p class="text-xs text-slate-500 mt-0.5 font-medium">
                                <span class="font-semibold text-gv-deep">John Doe</span>
                                &nbsp;· MacBook Pro (Chrome 123)
                            </p>
                            <p class="text-xs text-slate-400 mt-1">Location: Manila, PH &nbsp;·&nbsp; IP: 203.11.82.9</p>
                        </div>
                        <span class="text-xs text-slate-400 font-medium whitespace-nowrap">2 hrs ago</span>
                    </div>

                    <!-- Alert 4 — Settings change (slate) -->
                    <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100
                                hover:border-slate-200 transition-colors duration-200">
                        <div class="w-9 h-9 rounded-xl bg-slate-100 flex items-center justify-center shrink-0 mt-0.5">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <circle cx="8" cy="8" r="2" stroke="#64748b" stroke-width="1.4"/>
