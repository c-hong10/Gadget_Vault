@{
    ViewData["Title"] = "System Overview";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN — consistent with other dashboard views -->
<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

<!-- ┌──────────────────────────────────────────────────────
     │  PAGE HEADER
     └────────────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">

    <!-- left: title block -->
    <div>
        <span class="inline-flex items-center gap-1.5 text-xs font-extrabold uppercase tracking-widest
                     bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white px-3 py-1.5 rounded-full mb-3 shadow-sm transition-colors duration-300">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M5 0.5L1 2.3v2.8c0 1.9 1.6 3.7 4 4.4 2.4-.7 4-2.5 4-4.4V2.3L5 0.5z" fill="currentColor" opacity="0.9"/>
            </svg>
            System Administration
        </span>

        <h1 class="text-3xl font-black tracking-tight leading-tight">
            <span class="text-gv-brand">System</span>
            <span class="text-slate-900 dark:text-white transition-colors duration-300"> Overview</span>
        </h1>

        <p class="text-sm text-slate-500 dark:text-slate-400 mt-2 font-medium max-w-xl leading-relaxed transition-colors duration-300">
            Monitor system health, active sessions, and recent security events.
        </p>
    </div>

    <!-- right: live badge -->
    <div class="shrink-0 mt-1 flex items-center gap-2 px-4 py-2 bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm dark:shadow-none transition-colors duration-300">
        <span class="w-2 h-2 rounded-full bg-gv-brand animate-pulse inline-block"></span>
        <span class="text-xs font-semibold text-slate-500 dark:text-slate-400">Live — Updated now</span>
    </div>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  KPI CARDS — 4 columns
     └────────────────────────────────────────────────────── -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">

    <!-- Card 1: Total Active Users -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden
                hover:-translate-y-1 hover:shadow-md hover: transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[var(--brand-color)] to-[color-mix(in_srgb,var(--brand-color)_80%,transparent)] rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 transition-colors duration-300">Total Active Users</p>
                <p class="text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-none transition-colors duration-300">42</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 font-medium transition-colors duration-300">3 pending invites</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/10 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <circle cx="8"  cy="7"  r="3.5" stroke="#23a476" stroke-width="1.8"/>
                    <path d="M2 19c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="#23a476" stroke-width="1.8" stroke-linecap="round"/>
                    <circle cx="16" cy="7"  r="2.5" stroke="#23a476" stroke-width="1.5" opacity="0.55"/>
                    <path d="M15 13.5c2 .4 4 1.9 4 5.5" stroke="#23a476" stroke-width="1.5" stroke-linecap="round" opacity="0.55"/>
                </svg>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-gv-brand inline-block"></span>
            <span class="text-xs font-semibold text-gv-brand transition-colors duration-300">All systems operational</span>
        </div>
    </div>

    <!-- Card 2: Failed Logins 24h -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden
                hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-red-400 to-rose-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 transition-colors duration-300">Failed Logins (24H)</p>
                <p class="text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-none transition-colors duration-300">7</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 font-medium transition-colors duration-300">Across 2 accounts</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-100 dark:border-red-500/10 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M11 2L4 5.5v5c0 4.14 2.97 8.01 7 9.5 4.03-1.49 7-5.36 7-9.5v-5L11 2z" stroke="#ef4444" stroke-width="1.8" stroke-linejoin="round"/>
                    <path d="M11 9v3M11 14.5v.5" stroke="#ef4444" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>
            <span class="text-xs font-semibold text-red-500 transition-colors duration-300">Review security logs</span>
        </div>
    </div>

    <!-- Card 3: Active Integrations -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden
                hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 transition-colors duration-300">Active Integrations</p>
                <p class="text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-none transition-colors duration-300">3</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 font-medium transition-colors duration-300">Shopify · QuickBooks · FedEx</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-blue-50 dark:bg-blue-500/10 border border-blue-100 dark:border-blue-500/10 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M9 13a5 5 0 007 0l3-3a5 5 0 00-7-7L10.5 4.5" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M13 9a5 5 0 00-7 0L3 12a5 5 0 007 7L11.5 17.5" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>
            <span class="text-xs font-semibold text-blue-500 transition-colors duration-300">All connections healthy</span>
        </div>
    </div>

    <!-- Card 4: System Uptime -->
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-6 shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 relative overflow-hidden
                hover:-translate-y-1 hover:shadow-md transition-all duration-300">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-purple-400 to-violet-500 rounded-t-2xl"></div>
        <div class="flex items-start justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 transition-colors duration-300">System Uptime</p>
                <p class="text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-none transition-colors duration-300">99.9%</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 font-medium transition-colors duration-300">Last updated 2 mins ago</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-purple-50 dark:bg-purple-500/10 border border-purple-100 dark:border-purple-500/10 flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="8.5" stroke="#a855f7" stroke-width="1.8"/>
                    <path d="M11 5v6l3.5 3.5" stroke="#a855f7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
            <span class="text-xs font-semibold text-purple-500 transition-colors duration-300">SLA target: 99.5%</span>
        </div>
    </div>
</div>

<!-- ┌──────────────────────────────────────────────────────
     │  SPLIT LAYOUT — 60 / 40
     └────────────────────────────────────────────────────── -->
<div class="flex flex-col xl:flex-row gap-6">

    <!-- ╔══════════════════════════════════════════════════
         ║  LEFT 60%  — RECENT SECURITY ALERTS
         ╚══════════════════════════════════════════════════ -->
    <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col xl:flex-[6] transition-colors duration-300"
             aria-labelledby="alerts-heading">

        <!-- card header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
            <div class="flex items-center gap-3">
                <div class="w-1 h-7 rounded-full bg-red-400 shrink-0"></div>
                <div>
                    <h2 id="alerts-heading" class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Recent Security Alerts
                    </h2>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5 transition-colors duration-300">Human-triggered security events</p>
                </div>
            </div>
            <span class="flex items-center gap-1.5 text-xs font-bold text-red-500
                         bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-2.5 py-1 rounded-full transition-colors duration-300">
                <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse inline-block"></span>
                Live
            </span>
        </div>

        <!-- alerts feed -->
        <div class="flex-1 px-6 py-4 space-y-3">

            <!-- Alert 1 — Failed Login -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-red-50 dark:bg-red-500/5 border border-red-100 dark:border-red-500/10 hover:border-red-200 dark:hover:border-red-500/20 transition-colors duration-200">
                <div class="w-9 h-9 rounded-xl bg-red-100 dark:bg-red-500/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M8 2L2 4.5v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5v-4L8 2z" stroke="#ef4444" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M8 6.5v3M8 11v.5" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Failed Login Attempt</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 font-medium">
                        <span class="font-semibold text-red-500 dark:text-red-400">admin@techflow.com</span>
                        &nbsp;·&nbsp; IP: 192.168.1.4
                    </p>
                    <span class="inline-flex items-center gap-1 mt-2 text-xs font-bold text-red-500 dark:text-red-400 bg-red-100 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-2 py-0.5 rounded-full">
                        5 consecutive failures — Auto-locked
                    </span>
                </div>
                <span class="text-xs text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">3 min ago</span>
            </div>

            <!-- Alert 2 — Role Change -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-amber-50 dark:bg-amber-500/5 border border-amber-100 dark:border-amber-500/10 hover:border-amber-200 dark:hover:border-amber-500/20 transition-colors duration-200">
                <div class="w-9 h-9 rounded-xl bg-amber-100 dark:bg-amber-500/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M8 1L3 3.5v4c0 3 2.5 5.5 5 6.5 2.5-1 5-3.5 5-6.5v-4L8 1z" stroke="#f59e0b" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M5.5 8l2 2 3-3" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Role Changed</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 font-medium">
                        <span class="font-semibold text-amber-500 dark:text-amber-400">Jane Mendoza</span>
                        &nbsp;→ moved to <span class="font-bold text-slate-900 dark:text-white">Warehouse Manager</span>
                    </p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Modified by: Admin John Dela Cruz</p>
                </div>
                <span class="text-xs text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">1 hr ago</span>
            </div>

            <!-- Alert 3 — New Device Login -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-gv-brand-light dark:bg-gv-brand/5 border border-gv-brand-light dark:border-gv-brand/10 hover:border-gv-brand-light dark:hover:border-gv-brand/20 transition-colors duration-200">
                <div class="w-9 h-9 rounded-xl bg-gv-brand-light dark:bg-gv-brand/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="#23a476" stroke-width="1.5"/>
                        <path d="M6 12v2M10 12v2M4 14h8" stroke="#23a476" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M5.5 8.5l2 2 3-3" stroke="#23a476" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-slate-900 dark:text-slate-200">New Device Login</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 font-medium">
                        <span class="font-semibold text-slate-800 dark:text-slate-300">John Doe</span>
                        &nbsp;· MacBook Pro (Chrome 123)
                    </p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Location: Manila, PH &nbsp;·&nbsp; IP: 203.11.82.9</p>
                </div>
                <span class="text-xs text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">2 hrs ago</span>
            </div>

            <!-- Alert 4 — Settings change -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/30 border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 transition-colors duration-200">
                <div class="w-9 h-9 rounded-xl bg-slate-200 dark:bg-slate-800 flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <circle cx="8" cy="8" r="2" stroke="#64748b" stroke-width="1.4"/>
                        <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41" stroke="#64748b" stroke-width="1.3" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Password Policy Updated</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 font-medium">Minimum length changed from 8 → <span class="font-bold text-slate-800 dark:text-slate-300">12 characters</span></p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Modified by: Admin John Dela Cruz</p>
                </div>
                <span class="text-xs text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">Yesterday</span>
            </div>
        </div>

        <!-- footer -->
        <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30 transition-colors duration-300">
            <a href="#" class="text-xs font-bold text-gv-brand hover:text-gv-brand dark:hover:text-emerald-300 transition-colors">
                View all security logs →
            </a>
        </div>
    </section>

    <!-- ╔══════════════════════════════════════════════════
         ║  RIGHT 40%  — ACTIVE SESSIONS + SUMMARY
         ╚══════════════════════════════════════════════════ -->
    <div class="flex flex-col gap-5 xl:flex-[4]">

        <!-- Active Sessions card -->
        <section class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col transition-colors duration-300"
                 aria-labelledby="sessions-heading">

            <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                <div class="flex items-center gap-3">
                    <div class="w-1 h-7 rounded-full bg-gv-brand shrink-0"></div>
                    <div>
                        <h2 id="sessions-heading" class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                            Current Active Sessions
                        </h2>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5 transition-colors duration-300">Users online right now</p>
                    </div>
                </div>
                <span class="flex items-center gap-1.5 text-xs font-bold text-gv-brand
                             bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 px-2.5 py-1 rounded-full transition-colors duration-300">
                    <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span>
                    3 Online
                </span>
            </div>

            <div class="flex-1 divide-y divide-slate-100 dark:divide-slate-800/60 transition-colors duration-300">
                <!-- Session 1 -->
                <div class="flex items-center gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors duration-150">
                    <div class="relative shrink-0">
                        <div class="w-10 h-10 rounded-xl bg-purple-100 dark:bg-purple-500/15 flex items-center justify-center">
                            <span class="text-xs font-extrabold text-purple-600 dark:text-purple-400">DC</span>
                        </div>
                        <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-400 border-2 border-white dark:border-[#111113] transition-colors duration-300"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Dave</p>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium">System Admin</p>
                    </div>
                    <div class="text-right shrink-0">
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold text-gv-brand dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 px-2 py-0.5 rounded-full">Online</span>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium mt-1">Active 2m ago</p>
                    </div>
                </div>

                <!-- Session 2 -->
                <div class="flex items-center gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors duration-150">
                    <div class="relative shrink-0">
                        <div class="w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-500/15 flex items-center justify-center">
                            <span class="text-xs font-extrabold text-amber-600 dark:text-amber-400">SA</span>
                        </div>
                        <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-400 border-2 border-white dark:border-[#111113] transition-colors duration-300"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Sarah</p>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium">Sales Officer</p>
                    </div>
                    <div class="text-right shrink-0">
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold text-gv-brand dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 px-2 py-0.5 rounded-full">Online</span>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium mt-1">Active 8m ago</p>
                    </div>
                </div>

                <!-- Session 3 -->
                <div class="flex items-center gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/20 transition-colors duration-150">
                    <div class="relative shrink-0">
                        <div class="w-10 h-10 rounded-xl bg-teal-100 dark:bg-teal-500/15 flex items-center justify-center">
                            <span class="text-xs font-extrabold text-teal-600 dark:text-teal-400">MK</span>
                        </div>
                        <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-400 border-2 border-white dark:border-[#111113] transition-colors duration-300"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-900 dark:text-slate-200">Mike</p>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium">Warehouse Staff</p>
                    </div>
                    <div class="text-right shrink-0">
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold text-gv-brand dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 px-2 py-0.5 rounded-full">Online</span>
                        <p class="text-xs text-slate-500 dark:text-slate-500 font-medium mt-1">Active 15m ago</p>
                    </div>
                </div>
            </div>

