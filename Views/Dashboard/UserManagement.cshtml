@model IEnumerable<GadgetVault.Models.User>

@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN — consistent with other dashboard views -->
<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

<!-- ═══════════════════════════════════════
     PAGE HEADER
     ═══════════════════════════════════════ -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-7">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">User Management</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage system access, roles, and user permissions.</p>
    </div>
    <!-- Live badge -->
    <div class="flex items-center gap-2 px-3 py-1.5 bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm shrink-0">
        <span class="w-2 h-2 rounded-full bg-gv-brand animate-pulse"></span>
        <span class="text-xs font-semibold text-slate-500 dark:text-slate-400">@(Model?.Count() ?? 6) Users Total</span>
    </div>
</div>

<!-- ═══════════════════════════════════════
     TOOLBAR
     ═══════════════════════════════════════ -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-5">

    <!-- Search -->
    <form method="get" asp-action="UserManagement" class="relative w-full sm:w-80">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none"
             width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" /><path stroke-linecap="round" d="M21 21l-4.35-4.35" />
        </svg>
        <input type="text" name="searchString" value="@ViewBag.CurrentSearch"
               id="user-search-input"
               placeholder="Search users by name or email..."
               class="w-full pl-9 pr-4 py-2.5 bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-600 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all" />
    </form>

    <!-- Right side controls -->
    <div class="flex items-center gap-2 shrink-0">
        <!-- Add New User -->
        <button onclick="openInviteModal()" id="btn-add-user"
            class="flex items-center gap-2 px-4 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg transition-all">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add New User
        </button>
    </div>
</div>

<!-- ═══════════════════════════════════════
     TABLE CARD
     ═══════════════════════════════════════ -->
<div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm">

    <!-- Tab strip -->
    <div class="flex items-center gap-0 border-b border-slate-200 dark:border-slate-800 px-6">
        <button onclick="filterByStatus('all')" id="tab-all" class="tab-btn py-4 text-sm font-bold text-gv-brand dark:text-gv-brand-light border-b-2 border-gv-brand -mb-px pr-4 transition-colors">All Users</button>
        <button onclick="filterByStatus('active')" id="tab-active" class="tab-btn py-4 text-sm font-medium text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 border-b-2 border-transparent -mb-px px-4 transition-colors">Active</button>
        <button onclick="filterByStatus('inactive')" id="tab-inactive" class="tab-btn py-4 text-sm font-medium text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 border-b-2 border-transparent -mb-px px-4 transition-colors">Inactive</button>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm" id="users-table">
            <thead>
                <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">

                    <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">User</th>
                    <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Role</th>
                    <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Status</th>
                    <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Last Login</th>
                    <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/70" id="users-tbody">

                @* ─── Real data rows (when DB is populated) ─── *@
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        var initials = string.Join("", (user.FullName ?? user.Username ?? "?").Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                        var roleName = user.Role?.Name ?? "Unassigned";
                        var (roleClass, roleDot) = roleName switch {
                            "SystemManager"        => ("text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border-gv-brand-light dark:border-gv-brand/20", "bg-gv-brand"),
                            "WarehouseManager"     => ("text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-500/15 border-blue-200 dark:border-blue-500/20", "bg-blue-500"),
                            "WarehouseStaff"       => ("text-orange-700 dark:text-orange-400 bg-orange-100 dark:bg-orange-500/15 border-orange-200 dark:border-orange-500/20", "bg-orange-500"),
                            "SalesAndProcurement"  => ("text-purple-700 dark:text-purple-400 bg-purple-100 dark:bg-purple-500/15 border-purple-200 dark:border-purple-500/20", "bg-purple-500"),
                            _                      => ("text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700", "bg-slate-400"),
                        };
                        var roleLabel = roleName switch {
                            "SystemManager"       => "System Manager",
                            "WarehouseManager"    => "Warehouse Mgr",
                            "WarehouseStaff"      => "Warehouse Staff",
                            "SalesAndProcurement" => "Sales & Procure",
                            _                     => roleName,
                        };
                        <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="@(user.IsActive ? "active" : "inactive")">

                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center font-bold text-xs text-slate-600 dark:text-slate-300 shrink-0">
                                        @initials
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-semibold text-slate-800 dark:text-slate-200 truncate">@(user.FullName ?? user.Username)</p>
                                        <p class="text-xs text-slate-400 truncate mt-0.5">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold border @roleClass">
                                    <span class="w-1.5 h-1.5 rounded-full @roleDot inline-block"></span>
                                    @roleLabel
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400 inline-block"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm text-slate-500 dark:text-slate-400">@user.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick="openEditModal('@user.Id', '@user.Email', '@user.RoleId')"
                                            title="Edit User"
                                            class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all border-none outline-none">
                                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                    </button>
                                    <button onclick="confirmDeactivate(@user.Id, '@(user.FullName ?? user.Email)')"
                                            title="@(user.IsActive ? "Deactivate User" : "Activate User")"
                                            class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-@(user.IsActive ? "red-600" : "emerald-600") hover:bg-@(user.IsActive ? "red-50" : "emerald-50") dark:hover:bg-@(user.IsActive ? "red-500/10" : "emerald-500/10") transition-all border-none outline-none">
                                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                            @if (user.IsActive) {
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                                            } else {
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                            }
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @* ─── Mock data rows (design/demo mode) ─── *@

                    <!-- Row 1 — Alex Ray / System Manager / Active -->
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="active">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-gv-brand-light dark:bg-gv-brand-light flex items-center justify-center font-bold text-xs text-gv-brand-dark dark:text-gv-brand-light shrink-0">AR</div>
                                <div>
                                    <p class="font-semibold text-slate-800 dark:text-slate-200">Alex Ray</p>
                                    <p class="text-xs text-slate-400 mt-0.5">alex.ray@gadgetvault.com</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-gv-brand inline-block"></span> System Manager
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span> Active
                            </span>
                        </td>
                        <td class="px-6 py-4"><span class="text-sm text-slate-500 dark:text-slate-400">Today, 9:14 AM</span></td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button title="Edit User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                </button>
                                <button title="Deactivate User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 2 — Maria Santos / Warehouse Manager / Active -->
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="active">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center font-bold text-xs text-blue-700 dark:text-blue-400 shrink-0">MS</div>
                                <div>
                                    <p class="font-semibold text-slate-800 dark:text-slate-200">Maria Santos</p>
                                    <p class="text-xs text-slate-400 mt-0.5">m.santos@gadgetvault.com</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-500/15 border border-blue-200 dark:border-blue-500/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block"></span> Warehouse Mgr
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span> Active
                            </span>
                        </td>
                        <td class="px-6 py-4"><span class="text-sm text-slate-500 dark:text-slate-400">Today, 8:02 AM</span></td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button title="Edit User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                </button>
                                <button title="Deactivate User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 3 — Jake Reyes / Warehouse Staff / Active -->
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="active">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-orange-100 dark:bg-orange-900/40 flex items-center justify-center font-bold text-xs text-orange-700 dark:text-orange-400 shrink-0">JR</div>
                                <div>
                                    <p class="font-semibold text-slate-800 dark:text-slate-200">Jake Reyes</p>
                                    <p class="text-xs text-slate-400 mt-0.5">j.reyes@gadgetvault.com</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-orange-700 dark:text-orange-400 bg-orange-100 dark:bg-orange-500/15 border border-orange-200 dark:border-orange-500/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-orange-500 inline-block"></span> Warehouse Staff
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span> Active
                            </span>
                        </td>
                        <td class="px-6 py-4"><span class="text-sm text-slate-500 dark:text-slate-400">Yesterday, 4:55 PM</span></td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button title="Edit User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                </button>
                                <button title="Deactivate User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 4 — Laura Cruz / Sales & Procurement / Active -->
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="active">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center font-bold text-xs text-purple-700 dark:text-purple-400 shrink-0">LC</div>
                                <div>
                                    <p class="font-semibold text-slate-800 dark:text-slate-200">Laura Cruz</p>
                                    <p class="text-xs text-slate-400 mt-0.5">l.cruz@gadgetvault.com</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-purple-700 dark:text-purple-400 bg-purple-100 dark:bg-purple-500/15 border border-purple-200 dark:border-purple-500/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-purple-500 inline-block"></span> Sales & Procure
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 border border-gv-brand-light dark:border-gv-brand/20">
                                <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse inline-block"></span> Active
                            </span>
                        </td>
                        <td class="px-6 py-4"><span class="text-sm text-slate-500 dark:text-slate-400">Apr 9, 2026</span></td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button title="Edit User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                </button>
                                <button title="Deactivate User" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 5 — Ben Alvarez / Warehouse Staff / Inactive -->
                    <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group user-row" data-status="inactive">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center font-bold text-xs text-slate-500 dark:text-slate-400 shrink-0">BA</div>
                                <div>
                                    <p class="font-semibold text-slate-500 dark:text-slate-500">Ben Alvarez</p>
