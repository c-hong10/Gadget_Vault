@using GadgetVault.Models
@{
    ViewData["Title"] = "Master Data Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var categories = (ViewBag.Categories as IEnumerable<Category>) ?? Enumerable.Empty<Category>();
    var locations = (ViewBag.Locations as IEnumerable<WarehouseLocation>) ?? Enumerable.Empty<WarehouseLocation>();
}

<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6">

    <!-- PAGE HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Master Data Management</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Configure structural data used across the system.</p>
        </div>
    </div>

    <!-- TOAST NOTIFICATION -->
    @if (TempData["Success"] != null)
    {
        <div id="toast-success"
             class="flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold shadow-sm transition-opacity duration-500"
             style="background-color: color-mix(in srgb, var(--brand-color) 10%, transparent); border: 1px solid color-mix(in srgb, var(--brand-color) 30%, transparent); color: var(--brand-color);">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 px-5 py-3.5 rounded-xl bg-red-50 dark:bg-red-500/10
                    border border-red-200 dark:border-red-500/30 text-red-700 dark:text-red-400
                    text-sm font-semibold shadow-sm">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            @TempData["Error"]
        </div>
    }

    <!-- MAIN CARD -->
    <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm flex flex-col">

        <!-- TABS -->
        <div class="flex items-center gap-6 px-6 border-b border-slate-200 dark:border-slate-800">
            <button id="tab-btn-categories" onclick="switchTab('categories')"
                class="py-4 text-sm font-bold border-b-2 -mb-px transition-colors"
                style="color: var(--brand-color); border-color: var(--brand-color);">
                Product Categories
            </button>
            <button id="tab-btn-zones" onclick="switchTab('zones')"
                class="py-4 text-sm font-medium text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 border-b-2 border-transparent -mb-px transition-colors">
                Warehouse Zones
            </button>
        </div>

        <!-- TAB: CATEGORIES -->
        <div id="tab-content-categories" class="flex flex-col">
            <!-- Toolbar -->
            <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
                <div class="relative w-full sm:w-80">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                         width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
                    </svg>
                    <input type="text" id="cat-search" oninput="filterCategories()" placeholder="Search categories..."
                           class="w-full pl-9 pr-4 py-2 bg-white dark:bg-[#09090b] border border-slate-200 dark:border-slate-700/60 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <button onclick="toggleVault('cat')" id="cat-vault-btn"
                            class="flex items-center gap-2 px-4 py-2 text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        <span id="cat-vault-label">View Archive Vault</span>
                    </button>
                    <button onclick="document.getElementById('modal-add-category').classList.remove('hidden')"
                            class="flex items-center justify-center gap-2 px-4 py-2 text-white text-sm font-bold rounded-xl shadow-lg transition-all shrink-0 border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                        New Category
                    </button>
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead>
                        <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Category Name</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Description</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Total SKUs</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="cat-table-body" class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var cat in categories)
                        {
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group cat-row"
                                data-id="@cat.Id" data-name="@cat.Name" data-desc="@cat.Description">
                                <td class="px-6 py-4 font-semibold text-slate-800 dark:text-slate-200 cat-name">@cat.Name</td>
                                <td class="px-6 py-4 text-slate-500 dark:text-slate-400 truncate max-w-[280px]">@(cat.Description ?? "—")</td>
                                <td class="px-6 py-4 text-slate-500 dark:text-slate-400">@cat.Products.Count</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button onclick="openEditCategoryModal(this)"
                                                title="Edit Category"
                                                class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all border-none outline-none">
                                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                        </button>
                                        <button onclick="triggerArchive('@cat.Id', '@cat.Name')"
                                                title="Archive Category"
                                                class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all border-none outline-none">
                                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!categories.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 text-sm font-medium">
                                    No categories found. Click <strong>New Category</strong> to add one.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Category Archive Vault Panel -->
            <div id="cat-vault-panel" class="hidden flex-col bg-amber-50/30 dark:bg-amber-500/5 border-t border-amber-100/50 dark:border-amber-500/10">
                <div class="px-6 py-4 flex items-center gap-3">
                    <div class="p-2 rounded-lg bg-amber-100 dark:bg-amber-500/20 text-amber-600">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-amber-900 dark:text-amber-400">Category Archive Vault</h3>
                        <p class="text-[10px] text-amber-600/70 dark:text-amber-500/50 uppercase tracking-widest font-bold">Historical Structures</p>
                    </div>
                </div>
                <div class="overflow-x-auto border-t border-amber-100/50 dark:border-amber-500/10">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead>
                            <tr class="bg-amber-50/50 dark:bg-amber-500/5 border-b border-amber-100/30 dark:border-amber-500/10">
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60">Category</th>
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60">Description</th>
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60">SKUs</th>
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody id="cat-vault-body" class="divide-y divide-amber-100/30 dark:divide-amber-500/10">
                            <!-- JS loaded -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer -->
            <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
                <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">@categories.Count() active categories</span>
            </div>
        </div>

        <!-- TAB: WAREHOUSE ZONES -->
        <div id="tab-content-zones" class="hidden flex-col">
            <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 flex-1">Manage logical areas within the physical warehouse.</p>
                <div class="flex items-center gap-2 shrink-0">
                    <button onclick="toggleVault('zone')" id="zone-vault-btn"
                            class="flex items-center gap-2 px-4 py-2 text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        <span id="zone-vault-label">View Archive Vault</span>
                    </button>
                    <button onclick="document.getElementById('modal-add-zone').classList.remove('hidden')"
                            class="flex items-center justify-center gap-2 px-4 py-2 text-white text-sm font-bold rounded-xl shadow-lg transition-all shrink-0 border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                        Add Zone
                    </button>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead>
                        <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Zone Code</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Zone Name</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Aisle Count</th>
                            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var row in locations)
                        {
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group"
                                data-id="@row.Id" data-zone="@row.Zone" data-aisle="@row.Aisle" data-rack="@row.Rack">
                                <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-200">@row.Zone</td>
                                <td class="px-6 py-4 text-slate-500 dark:text-slate-400">@row.Aisle</td>
                                <td class="px-6 py-4 text-slate-500 dark:text-slate-400">@row.Rack</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button onclick="openEditZoneModal(this)"
                                                title="Edit Zone"
                                                class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all border-none outline-none">
                                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                                        </button>
                                        <button onclick="triggerArchiveZone('@row.Id', '@row.Zone')"
                                                title="Archive Zone"
                                                class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all border-none outline-none">
                                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!locations.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 text-sm font-medium">
                                    No zones found. Click <strong>Add Zone</strong> to create one.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Zone Archive Vault Panel -->
            <div id="zone-vault-panel" class="hidden flex-col bg-amber-50/30 dark:bg-amber-500/5 border-t border-amber-100/50 dark:border-amber-500/10">
                <div class="px-6 py-4 flex items-center gap-3">
                    <div class="p-2 rounded-lg bg-amber-100 dark:bg-amber-500/20 text-amber-600">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-amber-900 dark:text-amber-400">Zone Archive Vault</h3>
                        <p class="text-[10px] text-amber-600/70 dark:text-amber-500/50 uppercase tracking-widest font-bold">Historical Locations</p>
                    </div>
                </div>
                <div class="overflow-x-auto border-t border-amber-100/50 dark:border-amber-500/10">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead>
                            <tr class="bg-amber-50/50 dark:bg-amber-500/5 border-b border-amber-100/30 dark:border-amber-500/10">
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60">Zone Code</th>
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60">Zone Name</th>
                                <th class="px-6 py-2.5 text-[10px] font-bold uppercase tracking-wider text-amber-600/60 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody id="zone-vault-body" class="divide-y divide-amber-100/30 dark:divide-amber-500/10">
                            <!-- JS loaded -->
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Footer -->
            <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
                <span class="text-xs text-slate-400 dark:text-slate-500 font-medium">@locations.Count() active zones</span>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     ADD CATEGORY MODAL
     ══════════════════════════════════════ -->
<div id="modal-add-category"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#18181b] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-base font-extrabold text-slate-900 dark:text-white">New Product Category</h2>
            <button onclick="document.getElementById('modal-add-category').classList.add('hidden')"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 bg-transparent border-none outline-none transition-colors">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" action="/Category/Create">
            @Html.AntiForgeryToken()
            <div class="flex flex-col gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Category Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" required placeholder="e.g. Enterprise Networking"
                           class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea name="description" rows="3" placeholder="Brief description of this category..."
                              class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all resize-none"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="document.getElementById('modal-add-category').classList.add('hidden')"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        Save Category
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════
     EDIT CATEGORY MODAL
     ══════════════════════════════════════ -->
<div id="modal-edit-category"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#18181b] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-base font-extrabold text-slate-900 dark:text-white">Edit Product Category</h2>
            <button onclick="document.getElementById('modal-edit-category').classList.add('hidden')"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 bg-transparent border-none outline-none transition-colors">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" id="editCategoryForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="edit-cat-id" />
            <div class="flex flex-col gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Category Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" id="edit-cat-name" required placeholder="e.g. Enterprise Networking"
                           class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all"/>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Description <span class="text-slate-400 font-normal">(optional)</span></label>
                    <textarea name="description" id="edit-cat-desc" rows="3" placeholder="Brief description of this category..."
                              class="w-full px-4 py-2.5 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-[var(--brand-color)] transition-all resize-none"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="document.getElementById('modal-edit-category').classList.add('hidden')"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none"
                            style="background-color: var(--brand-color) !important; box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-color) 30%, transparent) !important;">
                        Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

