@using Microsoft.AspNetCore.Html
@model GadgetVault.Models.Role
@{
    ViewData["Title"] = "Edit Role";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var perms = Model.Permissions?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? new string[0];
    
    bool HasPerm(string key) => perms.Contains(key);
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="max-w-3xl mx-auto">
    <div class="mb-8 flex items-center gap-4">
        <a asp-action="RolesPermissions" class="p-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-slate-900 dark:hover:text-white transition-all">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Edit Role: @Model.Name</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Configure granular system access and metadata.</p>
        </div>
    </div>

    <form method="post" asp-action="UpdateRole" class="space-y-6">
        <input type="hidden" name="id" value="@Model.Id" />
        
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm space-y-5">
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Role Name</label>
                <input type="text" name="name" value="@Model.Name" required
                    class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium" />
            </div>
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Description</label>
                <textarea name="description" rows="2" required
                    class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium">@Model.Description</textarea>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-6">Granular Permissions</h2>
            
            <div class="space-y-8">
                <!-- OVERVIEW -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center text-indigo-500">
                            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100">Overview</h3>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-11">
                        @PermissionToggle("Overview_SystemDashboard", "System Dashboard", "Primary KPI overview for internal staff", HasPerm("Overview_SystemDashboard"))
                        @PermissionToggle("Overview_ManagerDashboard", "Manager Dashboard", "Warehouse and operational oversight", HasPerm("Overview_ManagerDashboard"))
                        @PermissionToggle("Overview_SupplierDashboard", "Supplier Dashboard", "Partner-specific order and catalog overview", HasPerm("Overview_SupplierDashboard"))
                    </div>
                </div>

                <!-- ADMINISTRATION -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-blue-500">
                            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100">Administration</h3>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-11">
                        @PermissionToggle("Admin_SystemOverview", "System Overview", "Dashboard KPI metrics and health status", HasPerm("Admin_SystemOverview"))
                        @PermissionToggle("Admin_UserManagement", "User Management", "Create, edit, and deactivate accounts", HasPerm("Admin_UserManagement"))
                        @PermissionToggle("Admin_RolesPermissions", "Roles & Permissions", "Configure access levels and granular keys", HasPerm("Admin_RolesPermissions"))
                        @PermissionToggle("Admin_MasterData", "Master Data", "System-wide tables and entity management", HasPerm("Admin_MasterData"))
                        @PermissionToggle("Admin_SecurityLogs", "Security Logs", "Audit trail of logins and security events", HasPerm("Admin_SecurityLogs"))
                        @PermissionToggle("Admin_SystemLogs", "System Logs", "Technical telemetry and system output", HasPerm("Admin_SystemLogs"))
                        @PermissionToggle("Admin_CompanySettings", "Company Settings", "Branding, white-labeling, and localization", HasPerm("Admin_CompanySettings"))
                    </div>
                </div>

                <!-- WAREHOUSE -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center text-emerald-500">
                            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100">Warehouse</h3>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-11">
                        @PermissionToggle("Wh_ProductCatalog", "Product Catalog", "Manage item master and global SKU list", HasPerm("Wh_ProductCatalog"))
                        @PermissionToggle("Wh_LiveInventory", "Live Inventory", "Real-time stock levels across locations", HasPerm("Wh_LiveInventory"))
                        @PermissionToggle("Wh_ReceiveStock", "Receive Stock", "Process incoming shipments and GRN", HasPerm("Wh_ReceiveStock"))
                        @PermissionToggle("Wh_PickPackShip", "Pick-Pack-Ship", "Handle fulfillment and picking lists", HasPerm("Wh_PickPackShip"))
                        @PermissionToggle("Wh_StockAdjustments", "Stock Adjustments", "Manual quantity corrections and overrides", HasPerm("Wh_StockAdjustments"))
                    </div>
                </div>

                <!-- COMMERCIAL -->
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center text-amber-500">
                            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-800 dark:text-slate-100">Commercial</h3>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-11">
                        @PermissionToggle("Comm_BusinessDirectory", "Business Directory", "Manage suppliers, vendors, and partners", HasPerm("Comm_BusinessDirectory"))
                        @PermissionToggle("Comm_PurchaseOrders", "Purchase Orders", "Create and track procurement orders", HasPerm("Comm_PurchaseOrders"))
                        @PermissionToggle("Comm_SalesOrders", "Sales Orders", "Manage customer sales and transactions", HasPerm("Comm_SalesOrders"))
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-end gap-3">
            <a asp-action="RolesPermissions" class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors">Cancel</a>
            <button type="submit" class="px-8 py-2.5 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                Save Role Configuration
            </button>
        </div>
    </form>
</div>

@functions {
    IHtmlContent PermissionToggle(string key, string label, string desc, bool isChecked)
    {
        var html = $@"
        <label class=""flex items-start gap-3 p-3 rounded-xl border border-slate-100 dark:border-slate-800/60 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-all cursor-pointer group"">
            <div class=""mt-0.5"">
                <input type=""checkbox"" name=""selectedPermissions"" value=""{key}"" {(isChecked ? "checked" : "")} 
                    class=""w-4 h-4 rounded border-slate-300 text-gv-brand focus:ring-gv-brand accent-gv-brand"" />
            </div>
            <div class=""min-w-0"">
                <p class=""text-xs font-bold text-slate-700 dark:text-slate-200 group-hover:text-gv-brand transition-colors"">{label}</p>
                <p class=""text-[0.65rem] text-slate-400 dark:text-slate-500 leading-relaxed truncate"">{desc}</p>
            </div>
        </label>";
        return new HtmlString(html);
    }
}
