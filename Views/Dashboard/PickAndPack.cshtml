@{
    ViewData["Title"] = "Fulfillment: Pick, Pack & Ship";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Tailwind CDN for UI prototype -->
<script src="https://cdn.tailwindcss.com"></script>


<div class="flex flex-col gap-6 h-full">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">Pick, Pack & Ship</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 transition-colors duration-300">Outgoing order fulfillment workspace.</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-xs font-bold text-red-600 dark:text-red-400 transition-colors duration-300">
                <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span> 1 Express Pending
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gv-brand-light dark:bg-gv-brand/10 border border-gv-brand-light dark:border-gv-brand/20 text-xs font-bold text-gv-brand dark:text-gv-brand-light transition-colors duration-300">
                3 Standard Pending
            </span>
        </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ════════ LEFT COLUMN: PENDING TASKS ════════ -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 flex flex-col h-full overflow-hidden transition-colors duration-300">
                
                <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                    <h2 class="text-sm font-extrabold text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                        Pending Task List
                    </h2>
                </div>

                <div class="flex flex-col divide-y divide-slate-100 dark:divide-slate-800/60 overflow-y-auto max-h-[600px] transition-colors duration-300">
                    
                    <!-- Task 1 (Active/Selected) -->
                    <div class="flex flex-col gap-2 p-5 bg-gv-brand-light/50 dark:bg-gv-brand/5 relative hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-150 cursor-pointer">
                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gv-brand"></div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900 dark:text-white transition-colors duration-300">SO-9921</span>
                            <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider font-extrabold bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-400 transition-colors duration-300">Express</span>
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium transition-colors duration-300">5 Items · Ship via FedEx Overnight</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 transition-colors duration-300">Assigned to: YOU</p>
                    </div>

                    <!-- Task 2 -->
                    <div class="flex flex-col gap-2 p-5 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-150 cursor-pointer">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900 dark:text-slate-200 transition-colors duration-300">SO-9922</span>
                            <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider font-extrabold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 transition-colors duration-300">Standard</span>
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium transition-colors duration-300">1 Item · Ship via UPS Ground</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 transition-colors duration-300">Unassigned</p>
                    </div>

                    <!-- Task 3 -->
                    <div class="flex flex-col gap-2 p-5 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-150 cursor-pointer">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900 dark:text-slate-200 transition-colors duration-300">SO-9923</span>
                            <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider font-extrabold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 transition-colors duration-300">Standard</span>
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium transition-colors duration-300">2 Items · Ship via USPS Priority</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 transition-colors duration-300">Unassigned</p>
                    </div>

                    <!-- Task 4 -->
                    <div class="flex flex-col gap-2 p-5 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors duration-150 cursor-pointer">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900 dark:text-slate-200 transition-colors duration-300">SO-9924</span>
                            <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider font-extrabold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 transition-colors duration-300">Standard</span>
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium transition-colors duration-300">4 Items · Ship via UPS Ground</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 transition-colors duration-300">Unassigned</p>
                    </div>

                </div>
            </div>
        </div>

        <!-- ════════ RIGHT COLUMN: ACTIVE WORKSPACE ════════ -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-[#111113] rounded-2xl shadow-sm dark:shadow-none border border-slate-200 dark:border-slate-800 flex flex-col overflow-hidden transition-colors duration-300">
                
                <!-- Workspace Header -->
                <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between bg-slate-50/50 dark:bg-[#0c0c0e]/50 transition-colors duration-300">
                    <div class="flex flex-col">
                        <h2 class="text-lg font-black text-slate-900 dark:text-white tracking-tight transition-colors duration-300">
                            Active Order: SO-9921
                        </h2>
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5 transition-colors duration-300">Customer: Omni Tech Solutions · Dest: New York, NY</p>
                    </div>
                    <button class="px-3 py-1.5 bg-white dark:bg-[#111113] border border-slate-300 dark:border-slate-700 rounded-lg text-xs font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors duration-300 shadow-sm">
                        Print Pick Slip
                    </button>
                </div>

                <div class="p-6 flex flex-col gap-8">
                    
                    <!-- Step 1: The Pick List -->
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-2 mb-1">
                            <div class="w-6 h-6 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-gv-brand-dark dark:text-gv-brand-light flex items-center justify-center text-xs font-black transition-colors duration-300">1</div>
                            <h3 class="text-sm font-bold text-slate-900 dark:text-white transition-colors duration-300">The Pick List</h3>
                        </div>
                        <div class="border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm dark:shadow-none transition-colors duration-300">
                            <table class="w-full text-left text-sm whitespace-nowrap">
                                <thead>
                                    <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
                                        <th class="px-4 py-3 w-10 text-center"><input type="checkbox" class="w-4 h-4 cursor-pointer accent-gv-accent opacity-50" disabled style="accent-color: var(--brand-color);" />></th>
                                        <th class="px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 transition-colors duration-300">Item</th>
                                        <th class="px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 transition-colors duration-300">Qty</th>
                                        <th class="px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 transition-colors duration-300">Location</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60 transition-colors duration-300">
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                        <td class="px-4 py-3 text-center"><input type="checkbox" class="w-4 h-4 cursor-pointer accent-gv-accent" style="accent-color: var(--brand-color);" />></td>
                                        <td class="px-4 py-3 font-semibold text-slate-800 dark:text-slate-200 transition-colors duration-300">AirPods Pro</td>
                                        <td class="px-4 py-3 font-bold text-slate-900 dark:text-white transition-colors duration-300">2 <span class="text-xs text-slate-400 dark:text-slate-500 font-normal">/ 2</span></td>
                                        <td class="px-4 py-3 font-mono text-xs text-slate-600 dark:text-slate-400 transition-colors duration-300">Zone B · Rack 2 · Bin 4</td>
                                    </tr>
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors duration-150">
                                        <td class="px-4 py-3 text-center"><input type="checkbox" class="w-4 h-4 cursor-pointer accent-gv-accent" style="accent-color: var(--brand-color);" />></td>
                                        <td class="px-4 py-3 font-semibold text-slate-800 dark:text-slate-200 transition-colors duration-300">iPhone 15 Case - Leather</td>
                                        <td class="px-4 py-3 font-bold text-slate-900 dark:text-white transition-colors duration-300">3 <span class="text-xs text-slate-400 dark:text-slate-500 font-normal">/ 3</span></td>
                                        <td class="px-4 py-3 font-mono text-xs text-slate-600 dark:text-slate-400 transition-colors duration-300">Zone A · Rack 5 · Bin 12</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Step 2: The Packing Scanner -->
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-2 mb-1">
                            <div class="w-6 h-6 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-gv-brand-dark dark:text-gv-brand-light flex items-center justify-center text-xs font-black transition-colors duration-300">2</div>
                            <h3 class="text-sm font-bold text-slate-900 dark:text-white transition-colors duration-300">Packing Scanner</h3>
                        </div>
                        <div class="flex gap-3">
                            <div class="relative flex-1">
                                <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none transition-colors duration-300"
                                     width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h4v16H3V4zm6 0h2v16H9V4zm4 0h1v16h-1V4zm3 0h5v16h-5V4z"/>
                                </svg>
                                <input type="text" placeholder="Scan Item Barcode to Pack..."
                                       class="w-full pl-12 pr-4 py-4 bg-slate-50 dark:bg-black/50 border border-slate-300 dark:border-slate-700 rounded-xl text-base font-mono text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all duration-300 shadow-inner dark:shadow-none" />
                            </div>
                            <button class="px-8 py-4 bg-slate-800 hover:bg-slate-900 dark:bg-slate-800 dark:hover:bg-slate-700 text-white font-bold rounded-xl shadow-lg transition-all duration-300">
                                Verify
                            </button>
                        </div>
                        <div class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 px-1 mt-1 transition-colors duration-300">
                            <span class="w-2 h-2 rounded-full bg-gv-brand shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span> Scanner Online & Ready
                        </div>
                    </div>

                    <!-- Step 3: Shipping -->
                    <div class="flex flex-col gap-3 pt-4 border-t border-slate-200 dark:border-slate-800 transition-colors duration-300">
                        <div class="flex items-center gap-2 mb-1">
                            <div class="w-6 h-6 rounded-full bg-gv-brand-light dark:bg-gv-brand/20 text-gv-brand-dark dark:text-gv-brand-light flex items-center justify-center text-xs font-black transition-colors duration-300">3</div>
                            <h3 class="text-sm font-bold text-slate-900 dark:text-white transition-colors duration-300">Shipping</h3>
                        </div>
                        
                        <div class="p-6 rounded-xl border-2 border-dashed border-slate-300 dark:border-slate-700 bg-slate-50/50 dark:bg-black/20 flex flex-col items-center justify-center gap-4 transition-colors duration-300">
                            
                            <!-- Mock FedEx Box / Label -->
                            <div class="w-48 h-32 bg-white dark:bg-[#111113] border border-slate-300 dark:border-slate-600 rounded shadow-md flex flex-col relative overflow-hidden transition-colors duration-300">
                                <div class="h-6 bg-[#4d148c] w-full flex items-center px-2">
                                    <span class="text-white text-[10px] font-black italic tracking-tighter">FedEx</span>
                                </div>
                                <div class="flex-1 p-2 flex flex-col gap-1.5 opacity-60">
                                    <div class="h-1.5 w-3/4 bg-slate-300 dark:bg-slate-700 rounded-full"></div>
                                    <div class="h-1 w-1/2 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
                                    <div class="mt-auto h-8 w-full bg-[url('data:image/svg+xml;base64,')] bg-repeat-x bg-contain opacity-50 dark:invert"></div>
                                </div>
                            </div>
                            
                            <p class="text-xs text-slate-500 dark:text-slate-400 font-medium text-center transition-colors duration-300">
                                All items must be packed before generating the shipping label.
                            </p>

                            <button class="mt-2 px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-extrabold rounded-xl shadow-lg shadow-blue-500/20 active:scale-[0.98] transition-all duration-300 w-full sm:w-auto">
                                Generate Shipping Label & Complete
                            </button>

                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>






