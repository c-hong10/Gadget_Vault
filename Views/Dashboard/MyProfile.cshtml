@model GadgetVault.Models.User
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var initials = string.Join("", (Model?.FullName ?? "New User").Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(s => s[0]));
    var activeTab = ViewBag.ActiveTab as string ?? "profile";
}

<!-- Cropper.js -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script src="https://cdn.tailwindcss.com"></script>

<div class="max-w-3xl mx-auto">

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">My Profile</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage your personal information, security settings, and preferences.</p>
    </div>

    <!-- Global Success Feedback (Always Top) -->
    @if (TempData["Success"] != null) {
        <div class="mb-6 flex items-center gap-3 px-5 py-3.5 rounded-xl bg-gv-brand/10 border border-gv-brand/30 text-gv-brand dark:text-gv-brand-light text-sm font-semibold shadow-sm animate-in fade-in slide-in-from-top-4 duration-500">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            @TempData["Success"]
        </div>
    }

    <!-- Tab Nav -->
    <div class="flex items-center gap-1 border-b border-slate-200 dark:border-[#1e1e24] mb-8">
        <button onclick="switchTab('profile')" id="tab-profile"
            class="profile-tab px-4 py-2.5 text-sm font-semibold transition-colors border-b-2 -mb-px">
            Profile
        </button>
        <button onclick="switchTab('security')" id="tab-security"
            class="profile-tab px-4 py-2.5 text-sm font-semibold transition-colors border-b-2 -mb-px">
            Security
        </button>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SECTION 1: PROFILE INFORMATION
         ═══════════════════════════════════════════════════════ -->
    <div id="section-profile" class="profile-section space-y-6 hidden">
        @if (activeTab == "profile" && TempData["Error"] != null) {
            <div class="flex items-center gap-3 px-5 py-3.5 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 text-red-700 dark:text-red-400 text-sm font-semibold shadow-sm mb-6">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                @TempData["Error"]
            </div>
        }

        <!-- Avatar block -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Profile Photo</h2>
            <div class="flex items-center gap-5">
                <div class="relative shrink-0">
                    @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl)) {
                        <img src="@Model.ProfilePictureUrl" alt="Profile" id="preview-avatar" class="w-24 h-24 rounded-full object-cover border-2 border-gv-brand/20" />
                    } else {
                        <div id="preview-avatar-placeholder" class="w-24 h-24 rounded-full bg-gv-brand-light dark:bg-emerald-900/30 border-2 border-emerald-400/40 flex items-center justify-center">
                            <span class="text-3xl font-extrabold text-gv-brand-dark dark:text-gv-brand-light">@initials</span>
                        </div>
                        <img src="" id="preview-avatar" class="hidden w-24 h-24 rounded-full object-cover border-2 border-gv-brand/20" />
                    }
                    <label for="profilePicture" class="absolute -bottom-1 -right-1 w-8 h-8 bg-slate-900 dark:bg-[#1e1e24] border-2 border-white dark:border-[#0c0c0e] rounded-full flex items-center justify-center hover:bg-slate-700 dark:hover:bg-[#1e1e24] transition-colors shadow-md cursor-pointer">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </label>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800 dark:text-slate-100">@Model?.FullName</p>
                    <p class="text-xs text-slate-400 mt-0.5">Upload a square photo (PNG, JPG — max 2MB)</p>
                    <label for="profilePicture" class="mt-2.5 inline-block text-xs font-semibold text-gv-brand dark:text-gv-brand-light border border-gv-brand/40 px-3 py-1 rounded-lg hover:bg-gv-brand/10 transition-colors cursor-pointer">
                        Change Photo
                    </label>
                </div>
            </div>
        </div>

        <!-- Profile fields -->
        <form id="profile-form" method="post" asp-action="UpdateProfile" enctype="multipart/form-data" class="space-y-6">
            <input type="file" id="profilePicture" class="hidden" accept="image/*" />
            
            <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-6">
                <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Personal Information</h2>
                <div class="space-y-5">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Full Name</label>
                            <input type="text" name="fullName" value="@Model?.FullName" required class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all font-medium" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Username</label>
                            <input type="text" name="username" value="@Model?.Username" required class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all font-medium" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Phone Number</label>
                            <input type="text" name="phoneNumber" value="@Model?.PhoneNumber" maxlength="11" placeholder="11 digits only" 
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                                   class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all font-medium" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Job Role</label>
                            <div class="relative">
                                <input type="text" value="@Model?.Role?.Name" readonly
                                    class="w-full bg-slate-100 dark:bg-[#111113]/50 border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-500 dark:text-slate-500 cursor-not-allowed font-medium" />
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] font-bold text-slate-400 bg-slate-200 dark:bg-[#1e1e24] px-2 py-0.5 rounded-full">System Managed</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Email Address</label>
                        <div class="relative">
                            <input type="email" value="@Model?.Email" readonly
                                class="w-full bg-slate-100 dark:bg-[#111113]/50 border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-500 dark:text-slate-500 cursor-not-allowed font-medium" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400 bg-slate-200 dark:bg-[#1e1e24] px-2 py-0.5 rounded-full">Read-only</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Home/Office Address</label>
                        <textarea name="address" rows="2" class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all resize-none font-medium">@Model?.Address</textarea>
                    </div>
                </div>
            </div>

            <!-- Save -->
            <div class="flex justify-end">
                <button type="submit" class="px-6 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg hover:opacity-90 transition-all">
                    Save Changes
                </button>
            </div>
        </form>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SECTION 2: SECURITY
         ═══════════════════════════════════════════════════════ -->
    <div id="section-security" class="profile-section space-y-6 hidden">
        @if (activeTab == "security" && TempData["Error"] != null) {
            <div class="flex items-center gap-3 px-5 py-3.5 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 text-red-700 dark:text-red-400 text-sm font-semibold shadow-sm mb-6">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                @TempData["Error"]
            </div>
        }

        <!-- Change Password -->
        <form method="post" asp-action="UpdatePassword" class="space-y-6">
            <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-6">
                <div class="flex items-center justify-between mb-5">
                    <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Change Password</h2>
                    <span class="text-[10px] font-bold text-gv-brand bg-gv-brand/10 px-2 py-0.5 rounded-full uppercase tracking-tighter">Strict Policy Enabled</span>
                </div>
                
                <div class="space-y-5">
                    <!-- Requirements Checklist -->
                    <div class="p-4 bg-slate-50 dark:bg-black/40 border border-slate-200 dark:border-[#1e1e24] rounded-xl mb-6">
                        <p class="text-[0.65rem] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-3">Hardening Requirements:</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
                            <div id="req-length" class="flex items-center gap-2 text-[0.75rem] text-slate-400 transition-colors duration-200">
                                <div class="req-dot w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-[#1e1e24] transition-colors"></div>
                                <span>12+ Characters</span>
                            </div>
                            <div id="req-upper" class="flex items-center gap-2 text-[0.75rem] text-slate-400 transition-colors duration-200">
                                <div class="req-dot w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-[#1e1e24] transition-colors"></div>
                                <span>Uppercase Letter</span>
                            </div>
                            <div id="req-lower" class="flex items-center gap-2 text-[0.75rem] text-slate-400 transition-colors duration-200">
                                <div class="req-dot w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-[#1e1e24] transition-colors"></div>
                                <span>Lowercase Letter</span>
                            </div>
                            <div id="req-symbol" class="flex items-center gap-2 text-[0.75rem] text-slate-400 transition-colors duration-200">
                                <div class="req-dot w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-[#1e1e24] transition-colors"></div>
                                <span>Number & Symbol</span>
                            </div>
                        </div>
                    </div>

                    <!-- Current Password -->
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Current Password</label>
                        <div class="relative">
                            <input id="pwd-current" name="currentPassword" type="password" required placeholder="••••••••••••"
                                class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 pr-12 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all" />
                            <button type="button" onclick="togglePwd('pwd-current', this)"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors p-1">
                                <svg class="eye-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                            </button>
                        </div>
                    </div>

                    <!-- New Password Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">New Password</label>
                            <div class="relative">
                                <input id="pwd-new" name="newPassword" type="password" required placeholder="••••••••••••" oninput="validatePassword(this.value)"
                                    class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 pr-12 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all" />
                                <button type="button" onclick="togglePwd('pwd-new', this)"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors p-1">
                                    <svg class="eye-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Confirm New Password</label>
                            <div class="relative">
                                <input id="pwd-confirm" name="confirmPassword" type="password" required placeholder="••••••••••••"
                                    class="w-full bg-slate-50 dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl px-4 py-2.5 pr-12 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand transition-all" />
                                <button type="button" onclick="togglePwd('pwd-confirm', this)"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors p-1">
                                    <svg class="eye-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Save -->
            <div class="flex justify-end">
                <button type="submit" class="px-6 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                    Update Password
                </button>
            </div>
        </form>

        <!-- Current Session Info -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Current Session Information</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-gv-brand-light dark:bg-gv-brand/10 flex items-center justify-center shrink-0">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-gv-brand"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Last Login Timestamp</p>
                        <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 mt-0.5">@(Model?.LastLoginAt?.ToString("MMM dd, yyyy HH:mm") ?? "First Login Session")</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-500/10 flex items-center justify-center shrink-0">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-blue-500"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Source Network IP</p>
                        <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 mt-0.5">@(Model?.LastLoginIp ?? "0.0.0.0")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ═══════════════════════════════════════════════════════
     CROP MODAL
     ═══════════════════════════════════════════════════════ -->
<div id="crop-modal" class="fixed inset-0 z-[100] hidden bg-[#0c0c0e]/80 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-[#111113] rounded-2xl w-full max-w-xl overflow-hidden shadow-2xl border border-slate-200 dark:border-[#1e1e24] animate-in zoom-in-95 duration-200">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-900 dark:text-white">Crop Profile Photo</h3>
            <button onclick="closeCropModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="p-6">
            <div class="aspect-square w-full bg-slate-100 dark:bg-[#111113] rounded-xl overflow-hidden mb-6">
                <img id="crop-image" class="max-w-full block" />
            </div>
            <div class="flex justify-end gap-3">
                <button onclick="closeCropModal()" class="px-5 py-2 text-sm font-bold text-slate-500 hover:text-slate-700 transition-colors">Cancel</button>
                <button onclick="applyCrop()" class="px-6 py-2 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                    Crop & Save
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let cropper = null;
    let croppedBlob = null;

    // ----- Tab switching -----
    function switchTab(tab) {
        document.querySelectorAll('.profile-section').forEach(s => s.classList.add('hidden'));
        document.querySelectorAll('.profile-tab').forEach(t => {
            t.classList.remove('text-gv-brand', 'dark:text-gv-brand-light', 'border-gv-brand', 'active-tab');
            t.classList.add('text-slate-500', 'dark:text-slate-400', 'border-transparent');
        });

        const section = document.getElementById('section-' + tab);
        if (section) section.classList.remove('hidden');
        
        const activeTab = document.getElementById('tab-' + tab);
        if (activeTab) {
            activeTab.classList.add('text-gv-brand', 'dark:text-gv-brand-light', 'border-gv-brand', 'active-tab');
            activeTab.classList.remove('text-slate-500', 'dark:text-slate-400', 'border-transparent');
        }
    }

    // Initialize Active Tab
    document.addEventListener('DOMContentLoaded', () => {
        const initialTab = "@activeTab";
        switchTab(initialTab);
    });

    // ----- Password Visibility Toggle -----
    const eyeOpen = `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`;
    const eyeSlash = `<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;

    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        const svg = btn.querySelector('svg');
        svg.innerHTML = isHidden ? eyeSlash : eyeOpen;
        btn.classList.toggle('text-gv-brand', isHidden);
    }

    // ----- Real-time Password Validation -----
    function validatePassword(val) {
        const checks = {
            length: val.length >= 12,
            upper: /[A-Z]/.test(val),
            lower: /[a-z]/.test(val),
            symbol: /[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)
        };

        Object.keys(checks).forEach(key => {
            const el = document.getElementById('req-' + key);
            const dot = el.querySelector('.req-dot');
            if (checks[key]) {
                el.classList.replace('text-slate-400', 'text-emerald-500');
                dot.classList.replace('bg-slate-300', 'bg-emerald-500');
                dot.classList.replace('dark:bg-[#1e1e24]', 'bg-emerald-500');
            } else {
                el.classList.contains('text-emerald-500') && el.classList.replace('text-emerald-500', 'text-slate-400');
                dot.classList.contains('bg-emerald-500') && dot.classList.replace('bg-emerald-500', 'bg-slate-300');
            }
        });
    }

    // ----- Image Selection & Cropping -----
    const fileInput = document.getElementById('profilePicture');
    const cropModal = document.getElementById('crop-modal');
    const cropImage = document.getElementById('crop-image');

    fileInput.addEventListener('change', function(e) {
        if (e.target.files && e.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function(event) {
                cropImage.src = event.target.result;
                cropModal.classList.remove('hidden');
                
                if (cropper) cropper.destroy();
                cropper = new Cropper(cropImage, {
                    aspectRatio: 1,
                    viewMode: 2,
                    dragMode: 'move',
                    background: false,
                    autoCropArea: 1,
                    cropBoxMovable: false,
                    cropBoxResizable: false
                });
            }
            reader.readAsDataURL(e.target.files[0]);
        }
    });

    function closeCropModal() {
        cropModal.classList.add('hidden');
        fileInput.value = '';
    }

    function applyCrop() {
        const canvas = cropper.getCroppedCanvas({ width: 250, height: 250 });
        canvas.toBlob((blob) => {
            croppedBlob = blob;
            const preview = document.getElementById('preview-avatar');
            const placeholder = document.getElementById('preview-avatar-placeholder');
            
            preview.src = URL.createObjectURL(blob);
            preview.classList.remove('hidden');
            if (placeholder) placeholder.classList.add('hidden');
            
            closeCropModal();
        }, 'image/jpeg', 0.9);
    }

    // ----- Form Submission Override -----
    document.getElementById('profile-form').addEventListener('submit', function(e) {
        if (croppedBlob) {
            e.preventDefault();
            const formData = new FormData(this);
            formData.set('profilePicture', croppedBlob, 'profile.jpg');
            
            fetch(this.action, {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    window.location.reload();
                }
            });
        }
    });
</script>
