@model GadgetVault.Models.User
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var initials = string.Join("", (Model?.FullName ?? "New User").Split(' ').Select(s => s[0]));
}

<script src="https://cdn.tailwindcss.com"></script>


<div class="max-w-3xl mx-auto">

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">My Profile</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage your personal information, security settings, and preferences.</p>
    </div>

    <!-- Tab Nav -->
    <div class="flex items-center gap-1 border-b border-slate-200 dark:border-slate-800 mb-8">
        <button onclick="switchTab('profile')" id="tab-profile"
            class="profile-tab active-tab px-4 py-2.5 text-sm font-semibold text-gv-brand dark:text-gv-brand-light border-b-2 border-gv-brand -mb-px transition-colors">
            Profile
        </button>
        <button onclick="switchTab('security')" id="tab-security"
            class="profile-tab px-4 py-2.5 text-sm font-semibold text-slate-500 dark:text-slate-400 border-b-2 border-transparent -mb-px hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
            Security
        </button>
        <button onclick="switchTab('regional')" id="tab-regional"
            class="profile-tab px-4 py-2.5 text-sm font-semibold text-slate-500 dark:text-slate-400 border-b-2 border-transparent -mb-px hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
            Regional
        </button>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SECTION 1: PROFILE INFORMATION
         ═══════════════════════════════════════════════════════ -->
    <div id="section-profile" class="profile-section space-y-6">

        <!-- Avatar block -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Profile Photo</h2>
            <div class="flex items-center gap-5">
                <div class="relative shrink-0">
                    <div class="w-20 h-20 rounded-full bg-gv-brand-light dark:bg-emerald-900/30 border-2 border-emerald-400/40 flex items-center justify-center">
                        <span class="text-2xl font-extrabold text-gv-brand-dark dark:text-gv-brand-light">@initials</span>
                    </div>
                    <button class="absolute -bottom-1 -right-1 w-7 h-7 bg-slate-900 dark:bg-slate-700 border-2 border-white dark:border-slate-900 rounded-full flex items-center justify-center hover:bg-slate-700 transition-colors shadow-md">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800 dark:text-slate-100">@Model?.FullName</p>
                    <p class="text-xs text-slate-400 mt-0.5">Upload a new photo (PNG, JPG — max 2MB)</p>
                    <button class="mt-2.5 text-xs font-semibold text-gv-brand dark:text-gv-brand-light border border-gv-brand/40 px-3 py-1 rounded-lg hover:bg-gv-brand/10 transition-colors">
                        Upload Photo
                    </button>
                </div>
            </div>
        </div>

        <!-- Profile fields -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Personal Information</h2>
            <div class="space-y-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Full Name</label>
                        <input type="text" value="@Model?.FullName" class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Username</label>
                        <input type="text" value="@Model?.Username" class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium" />
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Email Address</label>
                    <div class="relative">
                        <input type="email" value="@Model?.Email" readonly
                            class="w-full bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700/40 rounded-xl px-4 py-2.5 text-sm text-slate-500 dark:text-slate-500 cursor-not-allowed font-medium" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400 bg-slate-200 dark:bg-slate-700 px-2 py-0.5 rounded-full">Read-only</span>
                    </div>
                    <p class="mt-1.5 text-xs text-slate-400">Primary email used for system notifications and security alerts. Email modifications require strict IT compliance approval.</p>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Job Role</label>
                    <input type="text" value="@Model?.Role?.Name" readonly
                        class="w-full bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700/40 rounded-xl px-4 py-2.5 text-sm text-slate-500 dark:text-slate-500 cursor-not-allowed font-medium" />
                </div>
            </div>
        </div>

        <!-- Save -->
        <div class="flex justify-end">
            <button class="px-6 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg  hover: transition-all">
                Save Changes
            </button>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SECTION 2: SECURITY
         ═══════════════════════════════════════════════════════ -->
    <div id="section-security" class="profile-section hidden space-y-6">

        <!-- Change Password -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Change Password</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Current Password</label>
                    <div class="relative">
                        <input id="pwd-current" type="password" placeholder="••••••••••"
                            class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 pr-11 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all" />
                        <button type="button" onclick="togglePwd('pwd-current', this)"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" aria-label="Toggle visibility">
                            <svg class="eye-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">New Password</label>
                        <div class="relative">
                            <input id="pwd-new" type="password" placeholder="Min 8 characters"
                                class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 pr-11 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all" />
                            <button type="button" onclick="togglePwd('pwd-new', this)"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" aria-label="Toggle visibility">
                                <svg class="eye-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Confirm Password</label>
                        <div class="relative">
                            <input id="pwd-confirm" type="password" placeholder="Repeat new password"
                                class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 pr-11 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all" />
                            <button type="button" onclick="togglePwd('pwd-confirm', this)"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" aria-label="Toggle visibility">
                                <svg class="eye-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- 2FA Toggle -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Two-Factor Authentication</h2>
            <div class="flex items-start gap-5">
                <div class="flex-1">
                    <p class="text-sm font-bold text-slate-800 dark:text-slate-100">Authenticator App (2FA)</p>
                    <p class="text-xs text-slate-400 mt-1 leading-relaxed max-w-md">Add an extra layer of security. When enabled, you'll be asked for a verification code from your authenticator app each time you sign in.</p>
                    <span id="tfa-status-label" class="inline-flex items-center gap-1.5 mt-3 text-xs font-bold text-slate-400 bg-slate-100 dark:bg-slate-800 px-2.5 py-1 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                        Disabled
                    </span>
                </div>
                <!-- Premium toggle switch -->
                <div class="shrink-0 mt-1">
                    <button id="tfa-toggle" role="switch" aria-checked="false"
                        onclick="toggle2FA()"
                        class="relative inline-flex h-6 w-11 items-center rounded-full bg-slate-200 dark:bg-slate-700 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[var(--brand-color)] focus:ring-offset-2 dark:focus:ring-offset-slate-900">
                        <span id="tfa-thumb" class="translate-x-0.5 inline-block h-5 w-5 transform rounded-full bg-white shadow-md transition-transform duration-300"></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Active Sessions (read-only info) -->
        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Active Sessions</h2>
                <button class="text-xs font-bold text-red-500 hover:text-red-400 transition-colors">Revoke All</button>
            </div>
            <div class="space-y-3">
                <div class="flex items-center gap-4 p-3 rounded-xl bg-gv-brand-light dark:bg-gv-brand/5 border border-gv-brand-light dark:border-gv-brand/10">
                    <div class="w-9 h-9 rounded-xl bg-gv-brand-light dark:bg-emerald-900/30 flex items-center justify-center shrink-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#23a476" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" /><path stroke-linecap="round" d="M8 21h8M12 17v4" /></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-800 dark:text-slate-200">Chrome — Windows 11</p>
                        <p class="text-xs text-slate-400">Manila, PH · This device</p>
                    </div>
                    <span class="inline-flex items-center gap-1.5 text-xs font-bold text-gv-brand-dark dark:text-gv-brand-light bg-gv-brand-light dark:bg-gv-brand/15 px-2.5 py-1 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-gv-brand animate-pulse"></span>Current
                    </span>
                </div>
                <div class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 dark:bg-slate-800/30 border border-slate-100 dark:border-slate-700/40">
                    <div class="w-9 h-9 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#94a3b8" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" /><path stroke-linecap="round" d="M12 18h.01" /></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-800 dark:text-slate-200">Safari — iPhone 15</p>
                        <p class="text-xs text-slate-400">Last seen 3 hours ago</p>
                    </div>
                    <button class="text-xs font-bold text-red-500 hover:text-red-400 transition-colors">Revoke</button>
                </div>
            </div>
        </div>

        <!-- Save -->
        <div class="flex justify-end">
            <button class="px-6 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg  transition-all">
                Update Security
            </button>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         SECTION 3: REGIONAL SETTINGS
         ═══════════════════════════════════════════════════════ -->
    <div id="section-regional" class="profile-section hidden space-y-6">

        <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
            <h2 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-5">Localization</h2>
            <div class="space-y-5">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Timezone</label>
                    <select class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium appearance-none">
                        <option selected>(GMT+08:00) Asia/Manila</option>
                        <option>(GMT+00:00) UTC</option>
                        <option>(GMT-05:00) America/New_York</option>
                        <option>(GMT-08:00) America/Los_Angeles</option>
                        <option>(GMT+09:00) Asia/Tokyo</option>
                        <option>(GMT+01:00) Europe/London</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Language</label>
                    <select class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium appearance-none">
                        <option selected>English (US)</option>
                        <option>Filipino (Tagalog)</option>
                        <option>Japanese</option>
                        <option>Spanish</option>
                        <option>French</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Date Format</label>
                    <select class="w-full bg-slate-50 dark:bg-[#0e0e10] border border-slate-200 dark:border-slate-700/60 rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-slate-200 focus:outline-none focus:border-gv-brand focus:ring-2 focus:ring-[var(--brand-color)] transition-all font-medium appearance-none">
                        <option selected>MM/DD/YYYY</option>
                        <option>DD/MM/YYYY</option>
                        <option>YYYY-MM-DD</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Save -->
        <div class="flex justify-end">
            <button class="px-6 py-2.5 bg-gv-brand hover:bg-gv-mid text-white text-sm font-bold rounded-xl shadow-lg  transition-all">
                Save Preferences
            </button>
        </div>
    </div>

</div>

<script>
    // ----- Tab switching -----
    function switchTab(tab) {
        document.querySelectorAll('.profile-section').forEach(s => s.classList.add('hidden'));
        document.querySelectorAll('.profile-tab').forEach(t => {
            t.classList.remove('text-gv-brand', 'dark:text-gv-brand-light', 'border-gv-brand');
            t.classList.add('text-slate-500', 'dark:text-slate-400', 'border-transparent');
        });

        document.getElementById('section-' + tab).classList.remove('hidden');
        const activeTab = document.getElementById('tab-' + tab);
        activeTab.classList.add('text-gv-brand', 'border-gv-brand');
        activeTab.classList.remove('text-slate-500', 'border-transparent');
    }

    // ----- Password Visibility Toggle -----
    // SVG paths for eye-open vs eye-slash
    const eyeOpen = `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`;
    const eyeSlash = `<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;

    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        const svg = btn.querySelector('svg');
        svg.innerHTML = isHidden ? eyeSlash : eyeOpen;
        btn.classList.toggle('text-gv-brand', isHidden);
        btn.classList.toggle('text-slate-400', !isHidden);
    }

    // ----- 2FA Toggle -----
    let tfa = false;
    function toggle2FA() {
        tfa = !tfa;
        const btn = document.getElementById('tfa-toggle');
        const thumb = document.getElementById('tfa-thumb');
        const lbl = document.getElementById('tfa-status-label');

        if (tfa) {
            btn.classList.replace('bg-slate-200', 'bg-gv-brand');
            btn.classList.replace('dark:bg-slate-700', 'dark:bg-gv-brand');
            thumb.classList.replace('translate-x-0.5', 'translate-x-5');
            btn.setAttribute('aria-checked', 'true');
            lbl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span> Enabled';
            lbl.classList.replace('text-slate-400', 'text-gv-brand');
            lbl.classList.replace('bg-slate-100', 'bg-gv-brand-light');
        } else {
            btn.classList.replace('bg-gv-brand', 'bg-slate-200');
            btn.classList.replace('dark:bg-gv-brand', 'dark:bg-slate-700');
            thumb.classList.replace('translate-x-5', 'translate-x-0.5');
            btn.setAttribute('aria-checked', 'false');
            lbl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-slate-400 inline-block"></span> Disabled';
            lbl.classList.replace('text-gv-brand', 'text-slate-400');
            lbl.classList.replace('bg-gv-brand-light', 'bg-slate-100');
        }
    }
</script>






