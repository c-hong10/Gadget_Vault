@using GadgetVault.Models
@{
    ViewData["Title"] = "Business Partners";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var partners = (Model as IEnumerable<BusinessPartner>) ?? Enumerable.Empty<BusinessPartner>();
}
<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">

  <!-- PAGE HEADER -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Business Partners</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Manage your suppliers and customers for active orders.</p>
    </div>
  </div>

  <!-- SERVER MESSAGES -->
  @if (TempData["Success"] != null) {
  <div id="toast-success" class="flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold shadow-sm transition-opacity duration-500"
       style="background-color:color-mix(in srgb,var(--brand-color) 10%,transparent);border:1px solid color-mix(in srgb,var(--brand-color) 30%,transparent);color:var(--brand-color);">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    @TempData["Success"]
  </div>
  }
  @if (TempData["Error"] != null) {
  <div class="flex items-center gap-3 px-5 py-3.5 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 text-red-700 dark:text-red-400 text-sm font-semibold shadow-sm">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    @TempData["Error"]
  </div>
  }

  <!-- MAIN CARD -->
  <div class="bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-2xl overflow-hidden shadow-sm flex flex-col">

    <!-- TOOLBAR -->
    <div class="p-6 border-b border-slate-200 dark:border-[#1e1e24] flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-slate-50/50 dark:bg-[#0c0c0e]/50">
      <div class="relative w-full sm:w-80">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="partner-search" oninput="filterPartners()" placeholder="Search directory..."
               class="w-full pl-9 pr-4 py-2 bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none transition-all"/>
      </div>
      <div class="flex items-center gap-3">
        <button id="btn-vault-toggle" onclick="toggleVault()"
                class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold border transition-all"
                style="color:var(--brand-color);border-color:color-mix(in srgb,var(--brand-color) 35%,transparent);background:color-mix(in srgb,var(--brand-color) 8%,transparent);">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          <span id="vault-btn-label">View Archives</span>
        </button>
        <button onclick="openModal(0,'','','','','','Supplier')"
                class="flex items-center gap-2 px-4 py-2 text-white text-sm font-bold rounded-xl shadow-lg transition-all border-none outline-none"
                style="background-color:var(--brand-color)!important;">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Add New Partner
        </button>
      </div>
    </div>

    <!-- ACTIVE PARTNERS TABLE -->
    <div id="active-table" class="overflow-x-auto">
      <table class="w-full text-left text-sm whitespace-nowrap">
        <thead>
          <tr class="bg-slate-50/80 dark:bg-[#0c0c0e]/50 border-b border-slate-100 dark:border-[#1e1e24]">
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Company Name</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Contact</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Email</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Type</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="partner-table-body" class="divide-y divide-slate-100 dark:divide-[#1e1e24]">
          @foreach (var p in partners) {
          <tr class="hover:bg-slate-50/60 dark:hover:bg-[#1e1e24]/30 transition-colors group partner-row" 
              data-id="@p.Id"
              data-name="@p.CompanyName.ToLower()" 
              data-raw-company="@p.CompanyName"
              data-raw-contact="@p.ContactPerson"
              data-raw-email="@p.Email"
              data-raw-phone="@p.Phone"
              data-raw-address="@p.Address"
              data-type="@p.PartnerType">
            <td class="px-6 py-4 font-semibold text-slate-800 dark:text-slate-200">@p.CompanyName</td>
            <td class="px-6 py-4 text-slate-600 dark:text-slate-400">@p.ContactPerson</td>
            <td class="px-6 py-4 text-slate-600 dark:text-slate-400">@p.Email</td>
            <td class="px-6 py-4">
              @if (p.PartnerType == PartnerType.Supplier) {
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-500/30">Supplier</span>
              } else {
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/30">Customer</span>
              }
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <button onclick="openModal(@p.Id)"
                        title="Edit Partner"
                        class="p-2 rounded-lg bg-slate-100 dark:bg-[#1e1e24] text-slate-600 dark:text-slate-400 hover:text-gv-brand hover:bg-gv-brand-light transition-all">
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                </button>
                <button onclick="openArchiveConfirm(@p.Id)"
                        title="Archive Partner"
                        class="p-2 rounded-lg bg-slate-100 dark:bg-[#1e1e24] text-slate-400 hover:text-amber-600 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 transition-all">
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </button>
              </div>
            </td>
          </tr>
          }
          @if (!partners.Any()) {
          <tr><td colspan="5" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 text-sm font-medium">No active partners. Click <strong>Add New Partner</strong> to get started.</td></tr>
          }
        </tbody>
      </table>
    </div>
    <!-- Table Footer / Pagination -->
    <div class="px-6 py-4 border-t border-slate-200 dark:border-[#1e1e24] bg-slate-50/50 dark:bg-[#0c0c0e]/30 flex items-center justify-between">
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest" id="pagination-info">
            Showing 1-10 of @partners.Count() partners
        </p>
        <div class="flex items-center gap-2">
            <button onclick="changePage(-1)" id="btn-prev" class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white disabled:opacity-50 transition-all shadow-sm">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
            </button>
            <div id="page-numbers" class="flex items-center gap-1">
                <!-- Page numbers injected here -->
            </div>
            <button onclick="changePage(1)" id="btn-next" class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white disabled:opacity-50 transition-all shadow-sm">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
            </button>
        </div>
    </div>

    <!-- ARCHIVE VAULT PANEL (hidden by default) -->
    <div id="vault-panel" style="display:none;">
      <div class="px-6 py-4 border-t border-slate-200 dark:border-[#1e1e24] bg-amber-50/50 dark:bg-amber-500/5 flex items-center gap-3">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#f59e0b" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        <span class="text-sm font-bold text-amber-700 dark:text-amber-400">Archive Vault</span>
        <span class="text-xs text-amber-600 dark:text-amber-500 ml-1">Partners here are hidden from active orders. Restore them to bring them back.</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm whitespace-nowrap">
          <thead>
            <tr class="bg-amber-50/80 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/30">
              <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-amber-500/80">Company Name</th>
              <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-amber-500/80">Contact</th>
              <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-amber-500/80">Email</th>
              <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-amber-500/80">Type</th>
              <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-amber-500/80 text-right">Actions</th>
            </tr>
          </thead>
          <tbody id="vault-table-body" class="divide-y divide-amber-100/50 dark:divide-amber-900/20">
            <tr id="vault-loading"><td colspan="5" class="px-6 py-8 text-center text-slate-400 text-sm">Loading archived partners...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div><!-- end main card -->
</div>

<!-- ARCHIVE CONFIRMATION MODAL -->
<div id="modal-archive" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0c0c0e]/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl w-full max-w-md p-6">
    <div class="flex items-start gap-4 mb-5">
      <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(245,158,11,0.15);">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#f59e0b" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
      </div>
      <div>
        <h2 class="text-base font-extrabold text-slate-900 dark:text-white mb-1">Archive Partner?</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
          <strong id="archive-partner-name" class="text-slate-700 dark:text-slate-300"></strong> will be moved to the archives and hidden from active orders. You can recover them later from the <strong>Archive Vault</strong>.
        </p>
      </div>
    </div>
    <form id="archive-form" method="post" action="/Dashboard/ArchivePartner">
      @Html.AntiForgeryToken()
      <input type="hidden" name="id" id="archive-partner-id" value="0" />
      <div class="flex gap-3">
        <button type="button" onclick="closeArchiveModal()"
                class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-[#1e1e24] hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">Cancel</button>
        <button type="submit"
                class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white border-none outline-none transition-all"
                style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 14px rgba(245,158,11,0.35);">
          Confirm Archive
        </button>
      </div>
    </form>
  </div>
</div>

<!-- RESTORE CONFIRMATION MODAL -->
<div id="modal-restore" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0c0c0e]/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl w-full max-w-md p-6">
    <div class="flex items-start gap-4 mb-5">
      <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:color-mix(in srgb,var(--brand-color) 15%,transparent);">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="2.5" style="color:var(--brand-color);stroke:var(--brand-color);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
      </div>
      <div>
        <h2 class="text-base font-extrabold text-slate-900 dark:text-white mb-1">Restore Partner?</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
          <strong id="restore-partner-name" class="text-slate-700 dark:text-slate-300"></strong> will be reactivated, allowing them to be selected for new Purchase and Sales Orders.
        </p>
      </div>
    </div>
    <div class="flex gap-3">
      <button type="button" onclick="closeRestoreModal()"
              class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-[#1e1e24] hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">Cancel</button>
      <button type="button" onclick="confirmRestore()"
              class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white border-none outline-none transition-all"
              style="background-color:var(--brand-color)!important;box-shadow:0 4px 14px color-mix(in srgb,var(--brand-color) 35%,transparent)!important;">
        Confirm Restore
      </button>
    </div>
  </div>
</div>

<!-- HARD DELETE CONFIRMATION MODAL -->
<div id="modal-hard-delete" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0c0c0e]/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl w-full max-w-md p-6">
    <div class="flex items-start gap-4 mb-5">
      <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 bg-red-100 dark:bg-red-500/15">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <div>
        <h2 class="text-base font-extrabold text-slate-900 dark:text-white mb-1">Permanently Delete?</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
          This will permanently remove <strong id="hard-delete-partner-name" class="text-slate-700 dark:text-slate-300"></strong>. This action cannot be undone. All history linked to this partner will be orphaned.
        </p>
      </div>
    </div>
    <form method="post" action="/Dashboard/HardDeletePartner">
      @Html.AntiForgeryToken()
      <input type="hidden" name="id" id="hard-delete-partner-id" value="0" />
      <div class="flex gap-3">
        <button type="button" onclick="closeHardDeleteModal()"
                class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-[#1e1e24] hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">Cancel</button>
        <button type="submit"
                class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white bg-red-600 hover:bg-red-700 shadow-lg shadow-red-500/20 transition-all border-none outline-none">
          Yes, Delete Forever
        </button>
      </div>
    </form>
  </div>
</div>

<!-- EDIT/ADD PARTNER MODAL -->
<div id="modal-partner" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0c0c0e]/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-2xl shadow-2xl w-full max-w-lg p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 id="modal-title" class="text-base font-extrabold text-slate-900 dark:text-white">Add New Partner</h2>
      <button type="button" onclick="closeModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 bg-transparent border-none outline-none transition-colors">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="post" action="/Dashboard/AddOrEditBusinessPartner" onsubmit="this.querySelector('button[type=submit]').innerHTML='Processing...';this.querySelector('button[type=submit]').disabled=true;">
      @Html.AntiForgeryToken()
      <input type="hidden" name="Id" id="partner-id" value="0"/>
      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Company Name <span class="text-red-500">*</span></label>
          <input type="text" name="CompanyName" id="partner-company" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all"/>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Contact Person <span class="text-red-500">*</span></label>
            <input type="text" name="ContactPerson" id="partner-contact" required class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all"/>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Partner Type <span class="text-red-500">*</span></label>
            <select name="PartnerType" id="partner-type" onchange="toggleRequirements()" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all cursor-pointer">
              <option value="Supplier">Supplier</option>
              <option value="Customer">Customer</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Email <span id="req-email" class="text-red-500">*</span></label>
            <input type="email" name="Email" id="partner-email" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all"/>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Phone <span class="text-red-500">*</span></label>
            <input type="text" name="Phone" id="partner-phone" required maxlength="11" placeholder="e.g. 09123456789"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                   class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all"/>
          </div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1.5">Address <span id="req-address" class="text-red-500">*</span></label>
          <textarea name="Address" id="partner-address" rows="2" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#0c0c0e] border border-slate-200 dark:border-[#1e1e24] rounded-xl text-sm text-slate-800 dark:text-slate-200 focus:outline-none transition-all resize-none"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeModal()" class="flex-1 py-2.5 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-[#1e1e24] hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border-none outline-none">Cancel</button>
          <button type="submit" class="flex-1 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg transition-all border-none outline-none" style="background-color:var(--brand-color)!important;">Save Partner</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
// ── Dynamic Requirements & Formatting ───────────────────────────────
function toggleRequirements() {
  const type = document.getElementById('partner-type').value;
  const emailInput = document.getElementById('partner-email');
  const addressInput = document.getElementById('partner-address');
  const emailReq = document.getElementById('req-email');
  const addressReq = document.getElementById('req-address');

  if (type === 'Supplier') {
    emailInput.required = true;
    addressInput.required = true;
    emailReq.classList.remove('hidden');
    addressReq.classList.remove('hidden');
  } else {
    emailInput.required = false;
    addressInput.required = false;
    emailReq.classList.add('hidden');
    addressReq.classList.add('hidden');
  }
}

// ── Search ────────────────────────────────────────────────────────────
function filterPartners() {
  currentPage = 1;
  renderTable();
}

// ── Pagination Logic (Gold Standard) ──────────────────────────────────
let currentPage = 1;
const pageSize = 10;

function renderTable() {
    const rows = Array.from(document.querySelectorAll('.partner-row'));
    const q = document.getElementById('partner-search').value.toLowerCase();
    
    const filteredRows = rows.filter(r => r.dataset.name.includes(q));

    // Hide all rows first
    rows.forEach(row => row.classList.add('hidden'));

    // Paginate
    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;
    const pageRows = filteredRows.slice(start, end);

    pageRows.forEach(row => row.classList.remove('hidden'));

    // Update Info
    const total = filteredRows.length;
    document.getElementById('pagination-info').innerText = `Showing ${Math.min(start + 1, total)}-${Math.min(end, total)} of ${total} partners`;

    // Update Buttons
    document.getElementById('btn-prev').disabled = currentPage === 1;
    document.getElementById('btn-next').disabled = end >= total;

    // Render Page Numbers
    const totalPages = Math.ceil(total / pageSize);
    const pageContainer = document.getElementById('page-numbers');
    pageContainer.innerHTML = '';
    for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.innerText = i;
        btn.className = `w-8 h-8 rounded-lg text-xs font-bold transition-all ${i === currentPage ? 'bg-gv-brand text-white shadow-md shadow-gv-brand/20' : 'text-slate-400 hover:bg-slate-100 dark:hover:bg-[#1e1e24]'}`;
        btn.onclick = () => { currentPage = i; renderTable(); };
        pageContainer.appendChild(btn);
    }
}

function changePage(dir) {
    currentPage += dir;
    renderTable();
}

// ── Edit/Add Modal ────────────────────────────────────────────────────
function openModal(id) {
  if (id === 0) {
    document.getElementById('partner-id').value = 0;
    document.getElementById('partner-company').value = '';
    document.getElementById('partner-contact').value = '';
    document.getElementById('partner-email').value = '';
    document.getElementById('partner-phone').value = '';
    document.getElementById('partner-address').value = '';
    document.getElementById('partner-type').value = 'Supplier';
    document.getElementById('modal-title').innerText = 'Add New Partner';
  } else {
    const row = document.querySelector(`.partner-row[data-id="${id}"]`);
    if (row) {
      document.getElementById('partner-id').value = id;
      document.getElementById('partner-company').value = row.dataset.rawCompany;
      document.getElementById('partner-contact').value = row.dataset.rawContact;
      document.getElementById('partner-email').value = row.dataset.rawEmail;
      document.getElementById('partner-phone').value = row.dataset.rawPhone;
      document.getElementById('partner-address').value = row.dataset.rawAddress;
      document.getElementById('partner-type').value = row.dataset.type;
      document.getElementById('modal-title').innerText = 'Edit Partner';
    }
  }
  
  toggleRequirements();
  document.getElementById('modal-partner').classList.remove('hidden');
}
function closeModal() { document.getElementById('modal-partner').classList.add('hidden'); }

// ── Archive Confirm Modal ─────────────────────────────────────────────
function openArchiveConfirm(id) {
  const row = document.querySelector(`.partner-row[data-id="${id}"]`);
  const name = row ? row.dataset.rawCompany : "this partner";
  document.getElementById('archive-partner-id').value = id;
  document.getElementById('archive-partner-name').innerText = name;
  document.getElementById('modal-archive').classList.remove('hidden');
}
function closeArchiveModal() { document.getElementById('modal-archive').classList.add('hidden'); }

// ── Restore Confirm Modal ─────────────────────────────────────────────
var pendingRestoreId = 0;
function openRestoreConfirm(id, name) {
  pendingRestoreId = id;
  document.getElementById('restore-partner-name').innerText = name;
  document.getElementById('modal-restore').classList.remove('hidden');
}
function closeRestoreModal() { document.getElementById('modal-restore').classList.add('hidden'); }
function confirmRestore() {
  closeRestoreModal();
  recoverPartner(pendingRestoreId);
}

// ── Hard Delete Confirm Modal ──────────────────────────────────────────
function openHardDeleteConfirm(id, name) {
  document.getElementById('hard-delete-partner-id').value = id;
  document.getElementById('hard-delete-partner-name').innerText = name;
  document.getElementById('modal-hard-delete').classList.remove('hidden');
}
function closeHardDeleteModal() { document.getElementById('modal-hard-delete').classList.add('hidden'); }

// ── Archive Vault Toggle ───────────────────────────────────────────────
var vaultOpen = false;
function toggleVault() {
  vaultOpen = !vaultOpen;
  const vaultPanel = document.getElementById('vault-panel');
  const btnLabel = document.getElementById('vault-btn-label');
  if (vaultOpen) {
    vaultPanel.style.display = '';
    btnLabel.innerText = 'Hide Archives';
    loadVault();
  } else {
    vaultPanel.style.display = 'none';
    btnLabel.innerText = 'View Archives';
  }
}

function loadVault() {
  fetch('/Dashboard/GetArchivedPartners')
    .then(r => r.json())
    .then(data => {
      const tbody = document.getElementById('vault-table-body');
      if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-slate-400 text-sm">No archived partners found.</td></tr>';
        return;
      }
      tbody.innerHTML = data.map(p => `
        <tr class="hover:bg-amber-50/40 dark:hover:bg-amber-500/5 transition-colors">
          <td class="px-6 py-4 font-semibold text-slate-500 dark:text-slate-400">${p.companyName}</td>
          <td class="px-6 py-4 text-slate-400 dark:text-slate-500">${p.contactPerson || '—'}</td>
          <td class="px-6 py-4 text-slate-400 dark:text-slate-500">${p.email || '—'}</td>
          <td class="px-6 py-4">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-slate-100 dark:bg-[#1e1e24] text-slate-400 dark:text-slate-500">
              ${p.partnerType === 0 ? 'Supplier' : 'Customer'}
            </span>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button onclick="openRestoreConfirm(${p.id}, '${(p.companyName||'').replace(/'/g,"\\'")}')"
                      title="Restore Partner"
                      class="p-2 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-all border-none outline-none">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </button>
              <button onclick="openHardDeleteConfirm(${p.id}, '${(p.companyName||'').replace(/'/g,"\\'")}')"
                      title="Permanently Delete"
                      class="p-2 rounded-lg bg-red-50 dark:bg-red-500/10 text-red-500 hover:bg-red-100 dark:hover:bg-red-500/20 transition-all border-none outline-none">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>`).join('');
    });
}

function recoverPartner(id) {
  const token = document.querySelector('#archive-form input[name="__RequestVerificationToken"]').value;
  fetch('/Dashboard/RecoverPartner', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `id=${id}&__RequestVerificationToken=${encodeURIComponent(token)}`
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      window.location.reload();
    }
  });
}

window.addEventListener('DOMContentLoaded', () => {
  renderTable();
  const toast = document.getElementById('toast-success');
  if (toast) setTimeout(() => toast.style.opacity = '0', 3500);
});
</script>
