@using GadgetVault.Models
@{
    ViewData["Title"] = "Supplier Portal";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var orders = Model as IEnumerable<PurchaseOrder> ?? Enumerable.Empty<PurchaseOrder>();
    var user = ViewBag.CurrentUser as User;
}
<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">
  <!-- HEADER -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Supplier Portal</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
        Welcome, <span class="font-bold text-slate-700 dark:text-slate-200">@user?.FullName</span>. 
        Viewing orders for <span class="text-blue-600 font-bold">@(user?.Supplier?.CompanyName ?? "All Suppliers (Admin)")</span>.
      </p>
    </div>
  </div>

  <!-- TOAST -->
  @if (TempData["Success"] != null) {
  <div class="flex items-center gap-3 px-5 py-3 rounded-xl text-sm font-semibold bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    @TempData["Success"]
  </div>
  }

  <!-- PO LIST -->
  <div class="bg-white dark:bg-[#111113] border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm whitespace-nowrap">
        <thead>
          <tr class="bg-slate-50/80 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">PO #</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">Date</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Amount</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-center">Status</th>
            <th class="px-6 py-3.5 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
          @foreach (var po in orders) {
          <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-800/30 transition-colors group">
            <td class="px-6 py-4 font-mono text-xs font-bold text-slate-700 dark:text-slate-300">@po.PONumber</td>
            <td class="px-6 py-4 text-slate-500 dark:text-slate-400 text-xs">@po.OrderDate.ToString("MMM dd, yyyy")</td>
            <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-200 text-right font-mono">$@po.TotalAmount.ToString("N2")</td>
            <td class="px-6 py-4 text-center">
              @{
                var (bg, text, border) = po.Status switch {
                  POStatus.Ordered => ("bg-blue-50 dark:bg-blue-500/10", "text-blue-600 dark:text-blue-400", "border-blue-100 dark:border-blue-500/20"),
                  POStatus.Acknowledged => ("bg-amber-50 dark:bg-amber-500/10", "text-amber-600 dark:text-amber-400", "border-amber-100 dark:border-amber-500/20"),
                  POStatus.Received => ("bg-emerald-50 dark:bg-emerald-500/10", "text-emerald-600 dark:text-emerald-400", "border-emerald-100 dark:border-emerald-500/20"),
                  _ => ("bg-slate-50 dark:bg-slate-500/10", "text-slate-600 dark:text-slate-400", "border-slate-100 dark:border-slate-500/20")
                };
              }
              <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-bold border @bg @text @border">@po.Status</span>
            </td>
            <td class="px-6 py-4 text-right">
              @if (po.Status == POStatus.Ordered) {
              <form asp-action="AcknowledgePO" method="post" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@po.Id" />
                <button type="submit" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-bold rounded-lg transition-all shadow-sm active:scale-95">
                  Acknowledge
                </button>
              </form>
              } else {
                <span class="text-[10px] text-slate-400 font-medium italic">Confirmed</span>
              }
            </td>
          </tr>
          }
          @if (!orders.Any()) {
          <tr><td colspan="5" class="px-6 py-16 text-center text-slate-400 italic">No purchase orders assigned to your account.</td></tr>
          }
        </tbody>
      </table>
    </div>
    <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#0c0c0e]/50 flex items-center justify-between">
      <span class="text-[10px] text-slate-400 dark:text-slate-500 font-medium">Showing @orders.Count() orders</span>
      <span class="text-[10px] text-slate-400 dark:text-slate-500">Security: Data Isolation Active</span>
    </div>
  </div>
</div>
