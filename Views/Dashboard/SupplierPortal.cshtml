@using GadgetVault.Models
@model IEnumerable<PurchaseOrder>
@{
    ViewData["Title"] = "Supplier Portal";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var orders = Model ?? Enumerable.Empty<PurchaseOrder>();
    var user = ViewBag.CurrentUser as User;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-col gap-6">
    <!-- HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Active Orders</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                Welcome back, <span class="font-bold text-slate-700 dark:text-slate-200">@user?.FullName</span>. 
                Managing <span class="text-blue-600 font-bold">@user?.Supplier?.CompanyName</span> operations.
            </p>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-4 py-2 bg-white dark:bg-[#111113] border border-slate-200 dark:border-[#1e1e24] rounded-xl shadow-sm text-xs font-bold text-slate-500">
                <span class="text-gv-brand">@totalCount</span> Active Orders
            </div>
        </div>
    </div>

    <!-- TOAST -->
    @if (TempData["Success"] != null) {
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl text-sm font-semibold bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            @TempData["Success"]
        </div>
    }

    <!-- PO LIST SECTION -->
    <section class="bg-white dark:bg-[#111113] rounded-2xl border border-slate-200 dark:border-[#1e1e24] overflow-hidden shadow-sm transition-all duration-300">
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 dark:bg-[#111113]/30 border-b border-slate-100 dark:border-[#1e1e24]">
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Order Ref</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400">Date Ordered</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Total Value</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-center">Status</th>
                        <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#1e1e24]/60">
                    @foreach (var po in orders) {
                        <tr class="group hover:bg-slate-50 dark:hover:bg-[#1e1e24]/30 transition-colors">
                            <td class="px-6 py-4">
                                <div class="text-xs font-black text-slate-900 dark:text-white">@po.PONumber</div>
                                <div class="text-[10px] font-bold text-slate-400">@po.Items.Count items</div>
                            </td>
                            <td class="px-6 py-4 text-xs text-slate-500 font-medium">
                                @po.OrderDate.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-6 py-4 text-right font-mono text-sm font-black text-slate-800 dark:text-slate-200">
                                @po.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("en-PH"))
                            </td>
                            <td class="px-6 py-4 text-center">
                                @{
                                    var (bg, text, dot) = po.Status switch {
                                        POStatus.Ordered => ("bg-blue-100 text-blue-600 dark:bg-blue-500/10 dark:text-blue-400", "Pending", "bg-blue-400"),
                                        POStatus.Acknowledged => ("bg-amber-100 text-amber-600 dark:bg-amber-500/10 dark:text-amber-400", "Acknowledged", "bg-amber-400"),
                                        POStatus.Shipped => ("bg-indigo-100 text-indigo-600 dark:bg-indigo-500/10 dark:text-indigo-400", "In Transit", "bg-indigo-400"),
                                        _ => ("bg-slate-100 text-slate-600 dark:bg-[#1e1e24]/30 dark:text-slate-400", po.Status.ToString(), "bg-slate-400")
                                    };
                                }
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-tight @bg">
                                    <span class="w-1 h-1 rounded-full @dot animate-pulse"></span>
                                    @text
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a asp-action="PODetails" asp-route-id="@po.Id" class="text-[10px] font-black text-slate-400 hover:text-gv-brand uppercase tracking-widest transition-colors">
                                        Details
                                    </a>
                                    @if (po.Status == POStatus.Ordered || po.Status == POStatus.Draft) {
                                        <form asp-action="AcknowledgePO" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@po.Id" />
                                            <button type="submit" class="px-4 py-2 bg-gv-brand text-white text-[10px] font-black rounded-xl hover:scale-105 transition-all shadow-md shadow-gv-brand/10 uppercase tracking-widest">
                                                Acknowledge
                                            </button>
                                        </form>
                                    } else if (po.Status == POStatus.Acknowledged) {
                                        <form asp-action="ShipPO" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@po.Id" />
                                            <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-[10px] font-black rounded-xl hover:scale-105 transition-all shadow-md shadow-indigo-500/10 uppercase tracking-widest">
                                                Mark Shipped
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!orders.Any()) {
                        <tr>
                            <td colspan="5" class="px-6 py-24 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-16 h-16 bg-slate-50 dark:bg-[#1e1e24]/50 rounded-2xl flex items-center justify-center text-slate-300 dark:text-slate-600 mb-2">
                                        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                    </div>
                                    <h3 class="text-sm font-bold text-slate-900 dark:text-white">No Active Orders</h3>
                                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium italic">You have no pending fulfillments at this time.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION (Matching Stock Adjustments style) -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-[#1e1e24] bg-slate-50/50 dark:bg-[#111113]/30 flex items-center justify-between shrink-0">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                Showing @((currentPage - 1) * 10 + 1)-@Math.Min(currentPage * 10, totalCount) of @totalCount orders
            </p>
            <div class="flex items-center gap-2">
                <a asp-action="SupplierPortal" asp-route-page="@(currentPage - 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7"/></svg>
                </a>
                
                <div class="flex items-center gap-1">
                    @for (int i = 1; i <= totalPages; i++) {
                        <a asp-action="SupplierPortal" asp-route-page="@i" 
                           class="w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center transition-all @(i == currentPage ? "bg-gv-brand text-white shadow-md shadow-gv-brand/20" : "text-slate-400 hover:bg-slate-100 dark:hover:bg-[#1e1e24]")">
                            @i
                        </a>
                    }
                </div>

                <a asp-action="SupplierPortal" asp-route-page="@(currentPage + 1)" 
                   class="p-2 rounded-lg bg-white dark:bg-[#1e1e24] border border-slate-200 dark:border-[#1e1e24] text-slate-400 hover:text-slate-900 dark:hover:text-white transition-all @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </section>
</div>
