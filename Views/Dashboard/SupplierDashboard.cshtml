@{
    ViewData["Title"] = "Supplier Dashboard";
    Layout = "_DashboardLayout";
}

<div class="space-y-6">
    <div class="bg-white dark:bg-[#111113] rounded-2xl p-8 border border-slate-200 dark:border-[#1e1e24] shadow-sm transition-all duration-300">
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-2">Welcome to GadgetVault Partner Portal</h1>
        <p class="text-slate-500 dark:text-slate-400 max-w-2xl">
            You are currently logged in as a certified supplier. From here, you can manage your purchase orders, update your company profile, and track your performance metrics.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Quick Actions -->
        <a asp-action="SupplierPortal" class="group bg-white dark:bg-[#111113] p-6 rounded-2xl border border-slate-200 dark:border-[#1e1e24] hover:border-gv-brand dark:hover:border-gv-brand transition-all duration-300 no-underline">
            <div class="w-12 h-12 bg-gv-brand-light rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-gv-brand">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">My Orders</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400">Review and acknowledge pending purchase orders.</p>
        </a>

        <a asp-action="SupplierProfile" class="group bg-white dark:bg-[#111113] p-6 rounded-2xl border border-slate-200 dark:border-[#1e1e24] hover:border-gv-brand dark:hover:border-gv-brand transition-all duration-300 no-underline">
            <div class="w-12 h-12 bg-gv-brand-light rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-gv-brand">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">Company Info</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400">Update your contact details and business information.</p>
        </a>

        <div class="bg-gv-brand p-6 rounded-2xl border border-transparent shadow-lg shadow-gv-brand/20">
            <h3 class="text-lg font-bold text-white mb-2">Need Support?</h3>
            <p class="text-sm text-white/80 mb-4 leading-relaxed">Our procurement team is available to assist you with any technical issues or order discrepancies.</p>
            <button onclick="openSupportModal()" class="w-full py-2.5 bg-white text-gv-brand font-bold rounded-xl hover:bg-slate-50 transition-colors">Contact Admin</button>
        </div>
    </div>
</div>

<!-- Support Modal -->
<div id="supportModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-[#0c0c0e]/60 backdrop-blur-sm animate-in fade-in duration-200">
    <div class="bg-white dark:bg-[#111113] rounded-2xl w-full max-w-md border border-slate-200 dark:border-[#1e1e24] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-[#1e1e24] flex items-center justify-between">
            <div>
                <h2 class="text-base font-bold text-slate-900 dark:text-white">Contact Administration</h2>
                <p class="text-xs text-slate-400 mt-0.5">Send a quick message to our team.</p>
            </div>
            <button onclick="closeSupportModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form asp-action="SubmitQuickSupport" method="post" class="p-6 space-y-4">
            <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-widest text-slate-400 mb-2">Message Body</label>
                <textarea name="message" rows="4" required placeholder="Describe your issue or request here..."
                    class="w-full bg-slate-50 dark:bg-[#1e1e24]/50 border border-slate-200 dark:border-[#1e1e24]/60 rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:border-gv-brand focus:ring-1 focus:ring-gv-brand transition-all resize-none"></textarea>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeSupportModal()" 
                    class="flex-1 py-2.5 px-4 bg-slate-100 dark:bg-[#1e1e24] text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl hover:bg-slate-200 dark:hover:bg-[#1e1e24] transition-colors">
                    Cancel
                </button>
                <button type="submit" 
                    class="flex-[2] py-2.5 px-4 bg-gv-brand hover:opacity-90 text-white text-sm font-bold rounded-xl shadow-lg transition-all">
                    Send Message
                </button>
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            Swal.fire({
                title: 'Message Sent!',
                text: '@TempData["Success"]',
                icon: 'success',
                confirmButtonColor: 'var(--brand-color)',
                background: document.documentElement.classList.contains('dark') ? '#111113' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
            });
        });
    </script>
}

@section Scripts {
    <script>
        function openSupportModal() {
            const modal = document.getElementById('supportModal');
            modal.classList.remove('hidden');
        }
        function closeSupportModal() {
            const modal = document.getElementById('supportModal');
            modal.classList.add('hidden');
        }

        // Close on backdrop click
        document.getElementById('supportModal').addEventListener('click', function(e) {
            if (e.target === this) closeSupportModal();
        });
    </script>
}
