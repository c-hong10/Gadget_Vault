@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* ─────────────────────────────────────────────
       GOOGLE FONT IMPORT
       ───────────────────────────────────────────── */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@@300;400;500;600;700;800;900&display=swap');

    /* ─────────────────────────────────────────────
       BASE
       ───────────────────────────────────────────── */
    .lp-wrap * {
        box-sizing: border-box;
    }

    .lp-wrap {
        font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        color: var(--text-dark);
        background-color: var(--light-green);
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    /* ─────────────────────────────────────────────
       HERO SECTION
       ───────────────────────────────────────────── */
    .lp-hero {
        position: relative;
        background: linear-gradient(135deg, var(--dark-green) 0%, var(--primary-green) 45%, var(--secondary-green) 100%);
        color: var(--white);
        padding: 90px 20px 160px 20px;
        /* overflow intentionally NOT set here — the demo dropdown must float above sections below */
    }

    /* Animated background grid */
    .lp-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(35, 164, 118, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(35, 164, 118, 0.06) 1px, transparent 1px);
        background-size: 55px 55px;
        -webkit-mask-image: radial-gradient(ellipse 85% 70% at 50% 40%, black 30%, transparent 100%);
        mask-image: radial-gradient(ellipse 85% 70% at 50% 40%, black 30%, transparent 100%);
        z-index: 0;
    }

    /* Ambient glow blobs */
    .lp-hero-blob-1,
    .lp-hero-blob-2 {
        content: '';
        position: absolute;
        border-radius: 50%;
        background: rgba(35, 164, 118, 0.18);
        filter: blur(90px);
        z-index: 0;
        pointer-events: none;
    }
    .lp-hero-blob-1 { width: 560px; height: 560px; top: -120px; left: -120px; }
    .lp-hero-blob-2 { width: 420px; height: 420px; bottom: 30px; right: -60px; background: rgba(35, 164, 118, 0.12); }

    /* Wave cut */
    .lp-hero-wave {
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        overflow: hidden;
        line-height: 0;
        z-index: 2;
    }
    .lp-hero-wave svg {
        display: block;
        width: 100%;
        height: 100px;
    }

    .lp-hero-inner {
        position: relative;
        z-index: 1;
    }

    /* Badge */
    .lp-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(35, 164, 118, 0.12);
        border: 1px solid rgba(35, 164, 118, 0.32);
        border-radius: 40px;
        padding: 6px 18px;
        margin-bottom: 28px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #a8dcc8;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .lp-badge-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #2ecc9a;
        box-shadow: 0 0 8px #2ecc9a;
        animation: lp-blink 2.2s ease-in-out infinite;
        flex-shrink: 0;
    }

    /* Headline */
    .lp-hero-title {
        font-size: 5rem;
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -2px;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #ffffff 0%, #b3e3d1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: lp-fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .lp-hero-title .lp-title-accent {
        background: linear-gradient(135deg, #23a476, #2ecc9a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Sub-headline */
    .lp-hero-subtitle {
        font-size: 1.12rem;
        font-weight: 400;
        color: rgba(209, 232, 223, 0.9);
        line-height: 1.75;
        max-width: 580px;
        margin-bottom: 42px;
        animation: lp-fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
    }

    /* CTA buttons */
    .lp-hero-ctas {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
        animation: lp-fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.28s both;
    }

    .lp-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 15px 36px;
        font-size: 0.97rem;
        font-weight: 700;
        border-radius: 50px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.28s cubic-bezier(0.25, 0.8, 0.25, 1);
        letter-spacing: 0.01em;
        border: 2px solid transparent;
        font-family: inherit;
    }

    .lp-btn-primary {
        background: var(--accent-green);
        color: #ffffff;
        border-color: var(--accent-green);
        box-shadow: 0 8px 30px rgba(35, 164, 118, 0.5);
    }
    .lp-btn-primary:hover {
        background: #ffffff;
        color: var(--accent-green) !important;
        transform: translateY(-3px);
        box-shadow: 0 14px 36px rgba(35, 164, 118, 0.55);
        text-decoration: none;
    }

    .lp-btn-outline {
        background: rgba(255, 255, 255, 0.06);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.28);
        backdrop-filter: blur(6px);
    }
    .lp-btn-outline:hover {
        background: #ffffff;
        color: var(--primary-green) !important;
        border-color: #ffffff;
        transform: translateY(-3px);
        text-decoration: none;
    }

    /* Hero checklist */
    .lp-hero-checks {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 38px;
        animation: lp-fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.22s both;
    }

    .lp-check-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        font-weight: 500;
        color: #a8dcc8;
    }

    .lp-check-item svg {
        flex-shrink: 0;
    }

    /* Hero mockup */
    .lp-hero-mockup-wrap {
        perspective: 1000px;
        animation: lp-fadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
    }

    /* Live dashboard card */
    .lp-dash-card {
        background: rgba(11, 25, 20, 0.75);
        border: 1px solid rgba(35, 164, 118, 0.22);
        border-radius: 22px;
        padding: 28px;
        backdrop-filter: blur(20px);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.04) inset;
        transform: rotateY(-8deg) rotateX(5deg);
        transition: transform 0.8s ease;
        animation: lp-float 7s ease-in-out infinite;
        position: relative;
        overflow: hidden;
    }

    .lp-dash-card::before {
        content: '';
        position: absolute;
        top: 0; left: 30%; right: 30%;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(35, 164, 118, 0.7), transparent);
    }

    .lp-hero-mockup-wrap:hover .lp-dash-card {
        transform: rotateY(0deg) rotateX(0deg) scale(1.02);
    }

    /* Scanline overlay on dash card */
    .lp-dash-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
            0deg,
            transparent,
            transparent 3px,
            rgba(35, 164, 118, 0.015) 3px,
            rgba(35, 164, 118, 0.015) 4px
        );
        border-radius: 22px;
        pointer-events: none;
    }

    .lp-dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 22px;
    }

    .lp-dash-title {
        font-weight: 700;
        font-size: 0.88rem;
        color: #ffffff;
    }

    .lp-live-badge {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        color: #a8dcc8;
        font-weight: 600;
    }

    .lp-live-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #2ecc9a;
        box-shadow: 0 0 7px #2ecc9a;
        animation: lp-blink 1.8s ease-in-out infinite;
    }

    .lp-metric-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 18px;
    }

    .lp-metric {
        background: rgba(35, 164, 118, 0.07);
        border: 1px solid rgba(35, 164, 118, 0.15);
        border-radius: 12px;
        padding: 14px 15px;
    }

    .lp-metric-label {
        font-size: 0.66rem;
        font-weight: 700;
        color: rgba(168, 220, 200, 0.7);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 5px;
    }

    .lp-metric-value {
        font-size: 1.28rem;
        font-weight: 900;
        color: #ffffff;
        line-height: 1;
    }

    .lp-metric-delta {
        font-size: 0.68rem;
        font-weight: 600;
        color: #2ecc9a;
    }

    .lp-feed-item {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 7px 10px;
        border-radius: 9px;
        margin-bottom: 5px;
    }

    .lp-feed-item:first-child {
        background: rgba(35, 164, 118, 0.08);
        border: 1px solid rgba(35, 164, 118, 0.18);
    }

    .lp-feed-text {
        font-size: 0.74rem;
        color: rgba(240, 246, 243, 0.85);
        flex: 1;
    }

    .lp-feed-time {
        font-size: 0.65rem;
        color: rgba(168, 220, 200, 0.6);
        white-space: nowrap;
    }

    /* ─────────────────────────────────────────────
       STATS BAND
       ───────────────────────────────────────────── */
    .lp-stats-band {
        background: var(--white);
        border-top: 1px solid rgba(35, 164, 118, 0.1);
        border-bottom: 1px solid rgba(35, 164, 118, 0.1);
        padding: 48px 20px;
    }

    .lp-stats-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        justify-content: space-around;
        align-items: center;
        flex-wrap: wrap;
        gap: 30px;
    }

    .lp-stat {
        text-align: center;
    }

    .lp-stat-val {
        font-family: 'Inter', sans-serif;
        font-size: 2.6rem;
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 6px;
        background: linear-gradient(135deg, var(--accent-green), #2ecc9a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .lp-stat-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #8ea89e;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .lp-stat-divider {
        width: 1px;
        height: 50px;
        background: rgba(35, 164, 118, 0.15);
    }

    /* ─────────────────────────────────────────────
       FEATURES (MODULES) SECTION
       ───────────────────────────────────────────── */
    .lp-features {
        padding: 100px 20px;
        background: var(--light-green);
        position: relative;
    }

    .lp-section-tag {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(35, 164, 118, 0.1);
        border: 1px solid rgba(35, 164, 118, 0.25);
        border-radius: 40px;
        padding: 5px 16px;
        margin-bottom: 18px;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent-green);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .lp-section-title {
        font-size: 2.8rem;
        font-weight: 900;
        color: var(--primary-green);
        letter-spacing: -0.04em;
        line-height: 1.15;
        margin-bottom: 16px;
    }

    .lp-section-subtitle {
        font-size: 1.05rem;
        color: #5d7068;
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.72;
    }

    /* 3-column feature cards */
    .lp-feat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 26px;
        max-width: 1180px;
        margin: 0 auto;
    }

    .lp-feat-card {
        background: var(--white);
        border-radius: 24px;
        padding: 40px 34px;
        box-shadow: 0 8px 40px rgba(11, 61, 44, 0.05);
        border: 1px solid rgba(35, 164, 118, 0.1);
        transition: all 0.38s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
    }

    /* Top glow bar */
    .lp-feat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 20%;
        right: 20%;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
        opacity: 0;
        transition: opacity 0.35s ease;
    }

    /* Green overlay on hover */
    .lp-feat-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(35, 164, 118, 0.04) 0%, rgba(35, 164, 118, 0) 100%);
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
        z-index: 0;
    }

    .lp-feat-card > * {
        position: relative;
        z-index: 1;
    }

    .lp-feat-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 24px 55px rgba(10, 49, 36, 0.12);
        border-color: rgba(35, 164, 118, 0.35);
    }

    .lp-feat-card:hover::before,
    .lp-feat-card:hover::after {
        opacity: 1;
    }

    .lp-feat-icon-box {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #e4f0ec 0%, #f8fdfb 100%);
        box-shadow: 0 4px 16px rgba(35, 164, 118, 0.12), inset 0 2px 4px rgba(255,255,255,0.9);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 26px;
    }

    .lp-feat-icon-box img {
        width: 38px;
        height: 38px;
        filter: drop-shadow(0px 2px 4px rgba(35, 164, 118, 0.25));
    }

    .lp-feat-tag {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--accent-green);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 8px;
    }

    .lp-feat-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--primary-green);
        margin-bottom: 14px;
        letter-spacing: -0.02em;
        line-height: 1.3;
    }

    .lp-feat-desc {
        font-size: 0.92rem;
        color: #5d7068;
        line-height: 1.72;
        margin-bottom: 22px;
    }

    .lp-feat-bullets {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .lp-feat-bullet {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #5d7068;
    }

    .lp-bullet-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent-green);
        box-shadow: 0 0 5px rgba(35, 164, 118, 0.5);
        flex-shrink: 0;
    }

    /* ─────────────────────────────────────────────
       RBAC / ROLES SECTION
       ───────────────────────────────────────────── */
    .lp-roles {
        padding: 100px 20px 110px;
        background: linear-gradient(180deg, var(--white) 0%, #e8f4ef 100%);
        border-top: 1px solid rgba(0, 0, 0, 0.03);
    }

    .lp-roles-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        max-width: 1180px;
        margin: 0 auto;
    }

    .lp-role-card {
        background: var(--white);
        border-radius: 20px;
        padding: 36px 28px;
        box-shadow: 0 6px 30px rgba(11, 61, 44, 0.05);
        border: 1px solid rgba(35, 164, 118, 0.1);
        border-top: 4px solid var(--accent-green);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .lp-role-card::after {
        content: '';
        position: absolute;
        bottom: -30px;
        right: -30px;
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, rgba(35, 164, 118, 0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .lp-role-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 18px 45px rgba(11, 61, 44, 0.1);
    }

    .lp-role-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, rgba(35, 164, 118, 0.12), rgba(35, 164, 118, 0.06));
        border: 1px solid rgba(35, 164, 118, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 1.4rem;
    }

    .lp-role-name {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--primary-green);
        margin-bottom: 12px;
        letter-spacing: -0.01em;
    }

    .lp-role-access-badge {
        display: inline-block;
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 14px;
    }

    .lp-role-desc {
        font-size: 0.88rem;
        color: #5d7068;
        line-height: 1.65;
    }

    .badge-full    { background: rgba(35, 164, 118, 0.12); color: #0a7a56; }
    .badge-senior  { background: rgba(17, 87, 64, 0.1);    color: #115740; }
    .badge-floor   { background: rgba(10, 49, 36, 0.08);   color: #0a3124; }
    .badge-biz     { background: rgba(46, 204, 154, 0.12); color: #1a7a5a; }

    /* ─────────────────────────────────────────────
       CTA BANNER
       ───────────────────────────────────────────── */
    .lp-cta-banner {
        background: linear-gradient(135deg, var(--dark-green) 0%, var(--primary-green) 50%, var(--secondary-green) 100%);
        padding: 90px 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .lp-cta-banner::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(35, 164, 118, 0.2) 0%, transparent 70%);
        pointer-events: none;
    }

    .lp-cta-inner {
        position: relative;
        z-index: 1;
        max-width: 660px;
        margin: 0 auto;
    }

    /* ─────────────────────────────────────────────
       DEMO DROPDOWN
       ───────────────────────────────────────────── */
    .lp-demo-wrap {
        /* Layout handled by Tailwind classes (relative inline-block) */
    }

    .lp-demo-dropdown {
        display: none;
        background: #061f17;       /* solid background to prevent transparency overlap */
        border: 1px solid rgba(35, 164, 118, 0.4);
        border-radius: 16px;
        padding: 10px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.70), 0 0 0 1px rgba(35,164,118,0.15);
    }

    .lp-demo-dropdown.open {
        display: block;
        animation: lp-fadeUp 0.22s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .lp-demo-header {
        font-family: 'Inter', sans-serif;
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(168, 220, 200, 0.5);
        padding: 6px 10px 8px;
    }

    .lp-demo-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        font-family: 'Inter', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        color: #d1e8df;
        text-decoration: none;
        transition: background 0.18s ease, color 0.18s ease;
        cursor: pointer;
    }

    .lp-demo-link:hover {
        background: rgba(35, 164, 118, 0.15);
        color: #2ecc9a;
        text-decoration: none;
    }

    .lp-demo-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .lp-cta-title {
        font-size: 2.8rem;
        font-weight: 900;
        color: var(--white);
        letter-spacing: -0.04em;
        line-height: 1.15;
        margin-bottom: 18px;
    }

    .lp-cta-sub {
        font-size: 1.05rem;
        color: rgba(209, 232, 223, 0.85);
        margin-bottom: 40px;
        line-height: 1.7;
    }

    /* ─────────────────────────────────────────────
       FOOTER OVERRIDE (extra dark themed)
       ───────────────────────────────────────────── */
    .lp-footer-override {
        background-color: var(--dark-green) !important;
    }

    /* ─────────────────────────────────────────────
       KEYFRAMES
       ───────────────────────────────────────────── */
    @@keyframes lp-fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes lp-blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
    }

    @@keyframes lp-float {
        0%, 100% { transform: translateY(0px)    rotateY(-8deg) rotateX(5deg); }
        50%       { transform: translateY(-14px) rotateY(-8deg) rotateX(5deg); }
    }

    /* ─────────────────────────────────────────────
       RESPONSIVE
       ───────────────────────────────────────────── */
    @@media (max-width: 1100px) {
        .lp-feat-grid { grid-template-columns: repeat(2, 1fr); }
        .lp-roles-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 991px) {
        .lp-hero {
            padding: 70px 20px 120px 20px;
            text-align: center;
        }
        .lp-hero-title { font-size: 3.4rem; letter-spacing: -1px; }
        .lp-hero-subtitle { margin-left: auto; margin-right: auto; }
        .lp-hero-ctas { justify-content: center; }
        .lp-hero-checks { align-items: center; }
        .lp-hero-badge { margin-left: auto; margin-right: auto; }
        .lp-dash-card { transform: none !important; animation: none !important; }
        .lp-hero-mockup-wrap { margin-top: 60px; }
        .lp-stat-divider { display: none; }
    }

